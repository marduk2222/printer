@model printer.Data.Entities.PrinterBillingConfig
@{
    ViewData["Title"] = "編輯計費設定";
    var printer = ViewBag.Printer as printer.Data.Entities.Printer;
    var sheetTiersJson = ViewBag.SheetTiersJson as string ?? "[]";
    var allSheetTypesJson = ViewBag.AllSheetTypesJson as string ?? "[]";
    var sheetPricesJson = ViewBag.SheetPricesJson as string ?? "[]";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>編輯計費設定</h4>
    <div class="d-flex gap-2">
        <button type="submit" form="billingConfigForm" class="btn btn-success btn-sm">儲存變更</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">取消</a>
        @if (Model.Id > 0)
        {
            <button type="submit" form="deleteBillingConfigForm" class="btn btn-outline-danger btn-sm"
                    onclick="return confirm('確定要刪除此計費設定嗎？')">刪除</button>
        }
    </div>
</div>

@if (Model.Id > 0)
{
    <form asp-action="Delete" asp-route-printerId="@Model.PrinterId" method="post" id="deleteBillingConfigForm" class="d-none"></form>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">

        @{
            var printerGroup = ViewBag.PrinterGroup as printer.Data.Entities.PrinterBillingGroup;
        }

        @if (printerGroup != null)
        {
            <div class="alert alert-info">
                <strong>此事務機已加入計費群組「@printerGroup.Name」</strong>
                （結帳客戶：@printerGroup.BillingPartner?.Name）<br />
                <small>
                    張數計費（單價／誤印率／贈送張數／階梯）由群組統一計算；<strong>月租費仍以本頁為準</strong>，亦可在群組編輯頁集中修改。
                    <a asp-controller="BillingGroup" asp-action="Edit" asp-route-id="@printerGroup.Id">前往群組設定</a>
                </small>
            </div>
        }

        <!-- 事務機資訊 -->
        <div class="card mb-3">
            <div class="card-header">事務機資訊</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-2">事務機</dt>
                    <dd class="col-sm-4"><strong>@printer?.Name</strong> (@printer?.Code)</dd>
                    <dt class="col-sm-2">客戶</dt>
                    <dd class="col-sm-4">@printer?.Partner?.Name</dd>
                    @if (printer?.ContractStartDate != null || printer?.ContractEndDate != null)
                    {
                        <dt class="col-sm-2">合約期間</dt>
                        <dd class="col-sm-4">
                            @printer?.ContractStartDate?.ToString("yyyy-MM-dd") ~ @printer?.ContractEndDate?.ToString("yyyy-MM-dd")
                            @if (printer?.ContractStatus == "expired")
                            {
                                <span class="badge bg-danger ms-1">已到期</span>
                            }
                            else if (printer?.ContractStatus == "expiring")
                            {
                                <span class="badge bg-warning text-dark ms-1">即將到期</span>
                            }
                        </dd>
                    }
                </dl>
            </div>
        </div>

        <!-- ===== 主要計費設定 form ===== -->
        <form asp-action="Edit" method="post" id="billingConfigForm">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="PrinterId" />
            <input type="hidden" asp-for="CreatedAt" />

            <!-- 啟用 -->
            <div class="card mb-3">
                <div class="card-header"><span class="badge bg-primary me-2">1</span>啟用設定</div>
                <div class="card-body">
                    <div class="form-check form-switch">
                        <input asp-for="IsEnabled" class="form-check-input" type="checkbox" id="isEnabled" />
                        <label class="form-check-label fw-bold" for="isEnabled">啟用計費</label>
                    </div>
                </div>
            </div>

            <!-- 月租費 -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><span class="badge bg-primary me-2">2</span>月租費</span>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="monthlyToggle" />
                        <label class="form-check-label" for="monthlyToggle">啟用</label>
                    </div>
                </div>
                <div class="card-body" id="monthlyContent">
                    <div class="row">
                        <div class="col-md-3">
                            <label class="form-label">月租費</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="MonthlyFee" type="number" class="form-control" step="1" min="0" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">計費週期</label>
                            <div class="input-group">
                                <input asp-for="MonthlyFeeCycle" type="number" class="form-control" min="1" max="60" />
                                <span class="input-group-text">個月</span>
                            </div>
                            <small class="text-muted">1=每月, 3=每季, 6=半年</small>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">起算日期</label>
                            <input asp-for="MonthlyStartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">作帳日期</label>
                            <input asp-for="LastMonthlyBilledDate" type="date" class="form-control" readonly />
                            <small class="text-muted">系統自動更新</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 張數計費 -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><span class="badge bg-primary me-2">3</span>張數計費</span>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="pageToggle" />
                        <label class="form-check-label" for="pageToggle">啟用</label>
                    </div>
                </div>
                <div class="card-body" id="pageContent">
                    <input type="hidden" name="PageMethod" id="pageMethod" value="@((int)Model.PageMethod)" />
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label class="form-label">計費週期</label>
                            <div class="input-group">
                                <input asp-for="PageFeeCycle" type="number" class="form-control" min="1" max="60" />
                                <span class="input-group-text">個月</span>
                            </div>
                            <small class="text-muted">1=每月, 3=每季, 6=半年</small>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">起算日期</label>
                            <input asp-for="PageStartDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">作帳日期</label>
                            <input asp-for="LastPageBilledDate" type="date" class="form-control" readonly />
                            <small class="text-muted">系統自動更新</small>
                        </div>
                    </div>

                    <!-- 動態張數類型計費 -->
                    <input type="hidden" name="sheetTiersJson" id="sheetTiersJson" />
                    <table class="table table-bordered table-sm align-middle mb-1" id="sheetPriceTable">
                        <thead class="table-light">
                            <tr>
                                <th style="width:30px"></th>
                                <th>張數類型</th>
                                <th style="width:18%">單價</th>
                                <th style="width:14%">誤印率</th>
                                <th style="width:12%">贈送張數</th>
                                <th style="width:14%" title="換算值：1 個基本單位需幾張本類型，值越小越貴（例：彩色 1、大張 2、黑白 10 → 1 張彩色 = 2 張大張 = 10 張黑白）。填 0 = 不參與互換">換算值</th>
                                <th style="width:14%" title="折抵順序：小者優先享用折抵">折抵順序</th>
                                <th style="width:8%" class="text-center">階梯</th>
                                <th style="width:6%" class="text-center"></th>
                            </tr>
                        </thead>
                        <tbody id="sheetPriceBody">
                            <!-- JS 動態產生 -->
                        </tbody>
                    </table>
                    <small class="text-muted d-block mb-2">
                        計費張數 = 實際張數 × (1 - 誤印率%) - 贈送張數；剩餘贈送依「換算值 + 折抵順序」自動折抵其他類型超印（不足 1 張不計）
                    </small>
                    <!-- 新增張數類型 -->
                    <div class="d-flex gap-2 align-items-center mt-2">
                        <select id="addSheetTypeSelect" class="form-select form-select-sm" style="max-width:200px">
                            <option value="">選擇張數類型...</option>
                        </select>
                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="addSheetPriceRow()">+ 新增</button>
                    </div>
                </div>
            </div>

            <!-- 備註 -->
            <div class="card mb-3">
                <div class="card-header"><span class="badge bg-primary me-2">4</span>備註</div>
                <div class="card-body">
                    <textarea asp-for="Note" class="form-control" rows="2" placeholder="計費相關備註..."></textarea>
                </div>
            </div>

        </form>


    </div>

    <div class="col-md-4">
        <!-- 計費群組設定 -->
        <div class="card mb-3">
            <div class="card-header">計費群組</div>
            <div class="card-body">
                @{
                    var availableGroups = ViewBag.AvailableGroups as List<printer.Data.Entities.PrinterBillingGroup>
                        ?? new List<printer.Data.Entities.PrinterBillingGroup>();
                }
                @if (printerGroup != null)
                {
                    <div class="mb-2">
                        <small class="text-muted d-block">目前所屬群組</small>
                        <a asp-controller="BillingGroup" asp-action="Edit" asp-route-id="@printerGroup.Id"
                           class="badge bg-info text-dark text-decoration-none fs-6">
                            @printerGroup.Name
                        </a>
                        <small class="d-block text-muted mt-1">結帳客戶：@printerGroup.BillingPartner?.Name</small>
                    </div>
                    <form asp-action="SetGroup" method="post" class="mb-2"
                          onsubmit="return confirm('確定移出此群組？張數計費將恢復獨立計費。');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="printerId" value="@Model.PrinterId" />
                        <input type="hidden" name="groupId" value="" />
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">移出群組</button>
                    </form>
                }
                else
                {
                    <small class="text-muted d-block mb-2">目前獨立計費</small>
                }

                @if (availableGroups.Any())
                {
                    <hr class="my-2" />
                    <form asp-action="SetGroup" method="post"
                          onsubmit="return confirm('加入群組後，張數計費（單價／誤印率／贈送／階梯）將改由群組統一計算。確定要加入嗎？');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="printerId" value="@Model.PrinterId" />
                        <label class="form-label small mb-1">@(printerGroup != null ? "切換到" : "加入") 群組</label>
                        <select name="groupId" class="form-select form-select-sm mb-2" required>
                            <option value="">選擇群組...</option>
                            @foreach (var g in availableGroups.Where(g => g.Id != printerGroup?.Id))
                            {
                                <option value="@g.Id">@g.Name @(g.BillingPartner != null ? $"（{g.BillingPartner.Name}）" : "")</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-outline-primary btn-sm w-100">套用</button>
                    </form>
                }
                <hr class="my-2" />
                <a asp-controller="BillingGroup" asp-action="Create" class="btn btn-outline-secondary btn-sm w-100">
                    建立新群組
                </a>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">快速套用模板</div>
            <div class="card-body">
                <form asp-action="ApplyTemplate" method="post">
                    <input type="hidden" name="printerId" value="@Model.PrinterId" />
                    <div class="mb-3">
                        <select name="templateId" class="form-select" asp-items="@ViewBag.Templates">
                            <option value="">選擇模板...</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-outline-primary w-100">套用模板</button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">計費方式說明</div>
            <div class="card-body small">
                <div class="alert alert-success py-2 mb-2">
                    <strong>目前使用：張數類型計費</strong><br />
                    依各類型張數 × 單價計算
                </div>
                <p class="mb-1"><strong>張數類型計費流程：</strong></p>
                <ol class="mb-2 ps-3">
                    <li>設定各類型單價（左方）</li>
                    <li>上傳抄表資料</li>
                    <li>系統自動依驅動參數分類累加</li>
                    <li>生成帳單時自動計算</li>
                </ol>
                <hr />
                <p class="mb-1"><strong>月租費</strong>：固定金額 × 週期</p>
                <p class="mb-1"><strong>單價計費</strong>：張數 × 單價</p>
                <p class="mb-0"><strong>合計</strong> = 月租費 + 張數費</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    // ─── 資料初始化 ───────────────────────────────────────────
    var allSheetTypes = @Html.Raw(allSheetTypesJson);  // [{id, name}, ...]
    var initSheetPrices = @Html.Raw(sheetPricesJson);  // [{sheetTypeId, sheetTypeName, unitPrice, discountPercent, freePages, weight, offsetOrder}, ...]
    var sheetTierSets = {};  // sheetTypeId → [{fromPages, toPages, price}, ...]

    (function() {
        var raw = @Html.Raw(sheetTiersJson);
        raw.forEach(function(t) {
            if (!sheetTierSets[t.sheetTypeId]) sheetTierSets[t.sheetTypeId] = [];
            sheetTierSets[t.sheetTypeId].push(t);
        });
    })();

    // ─── 已加入的 sheetTypeId 集合（避免重複新增）──────────────
    var addedSheetTypeIds = new Set();

    document.addEventListener('DOMContentLoaded', function() {
        // 月租費開關
        var monthlyToggle = document.getElementById('monthlyToggle');
        var monthlyContent = document.getElementById('monthlyContent');
        var hasMonthly = parseFloat(document.querySelector('[name="MonthlyFee"]').value) > 0;
        monthlyToggle.checked = hasMonthly;
        monthlyContent.style.display = hasMonthly ? '' : 'none';
        monthlyToggle.addEventListener('change', function() {
            monthlyContent.style.display = this.checked ? '' : 'none';
            if (!this.checked) document.querySelector('[name="MonthlyFee"]').value = '0';
        });

        // 張數計費開關
        var pageToggle = document.getElementById('pageToggle');
        var pageContent = document.getElementById('pageContent');
        var pageMethod = document.getElementById('pageMethod');
        var hasPage = parseInt(pageMethod.value) > 0;
        pageToggle.checked = hasPage;
        pageContent.style.display = hasPage ? '' : 'none';
        pageToggle.addEventListener('change', function() {
            pageContent.style.display = this.checked ? '' : 'none';
            pageMethod.value = this.checked ? '1' : '0';
        });

        // 初始化：渲染已設定的張數類型列
        initSheetPrices.forEach(function(p) {
            appendSheetPriceRow(p.sheetTypeId, p.sheetTypeName, p.unitPrice, p.discountPercent, p.freePages, p.weight, p.offsetOrder);
        });

        // 初始化下拉選單（所有可用類型）
        refreshAddDropdown();

        // 渲染階梯
        addedSheetTypeIds.forEach(function(stId) { renderSheetTiers(stId); });
        updateSheetTiersJson();

        initSheetPriceSortable();
    });

    // ─── 拖曳排序 ──────────────────────────────────────────────
    function initSheetPriceSortable() {
        var tbody = document.getElementById('sheetPriceBody');
        if (!tbody || typeof Sortable === 'undefined') return;
        new Sortable(tbody, {
            handle: '.drag-handle',
            draggable: 'tr.sortable-main',
            animation: 150,
            ghostClass: 'table-active',
            onEnd: function () {
                // 主列調整位置後，把對應的階梯 (collapse) tr 重新插到主列之後
                tbody.querySelectorAll('tr.sortable-main').forEach(function (mainTr) {
                    var stId = mainTr.dataset.stid;
                    var tierTr = document.getElementById('sheetTier_' + stId);
                    if (tierTr && mainTr.nextSibling !== tierTr) {
                        tbody.insertBefore(tierTr, mainTr.nextSibling);
                    }
                });
            }
        });
    }

    // ─── 張數類型列 ──────────────────────────────────────────
    function appendSheetPriceRow(stId, stName, unitPrice, discountPercent, freePages, weight, offsetOrder) {
        addedSheetTypeIds.add(stId);
        var tbody = document.getElementById('sheetPriceBody');
        var tierId = 'sheetTier_' + stId;

        var weightVal = (weight === null || weight === undefined) ? '' : weight;
        var offsetVal = (offsetOrder === null || offsetOrder === undefined) ? '' : offsetOrder;
        var weightPh = '預設 0';
        var offsetPh = '預設 0';

        // 主列
        var tr = document.createElement('tr');
        tr.id = 'sheetPriceRow_' + stId;
        tr.className = 'sortable-main';
        tr.dataset.stid = stId;
        tr.innerHTML = `
            <td class="drag-handle text-muted text-center" style="cursor:grab" title="拖曳調整順序">≡</td>
            <td class="fw-bold">
                ${stName}
                <input type="hidden" name="sheetTypeIds" value="${stId}" />
            </td>
            <td>
                <div class="input-group input-group-sm">
                    <span class="input-group-text">$</span>
                    <input type="number" name="unitPrices" class="form-control"
                           value="${parseFloat(unitPrice).toFixed(4)}" step="0.0001" min="0" />
                </div>
            </td>
            <td>
                <div class="input-group input-group-sm">
                    <input type="number" name="discountPercents" class="form-control"
                           value="${parseFloat(discountPercent).toFixed(2)}" step="0.01" min="0" max="100" />
                    <span class="input-group-text">%</span>
                </div>
            </td>
            <td>
                <input type="number" name="freePagesList" class="form-control form-control-sm"
                       value="${freePages}" min="0" />
            </td>
            <td>
                <input type="number" name="weights" class="form-control form-control-sm"
                       value="${weightVal}" placeholder="${weightPh}" step="0.01" min="0" />
            </td>
            <td>
                <input type="number" name="offsetOrders" class="form-control form-control-sm"
                       value="${offsetVal}" placeholder="${offsetPh}" min="0" />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-secondary py-0"
                        data-bs-toggle="collapse" data-bs-target="#${tierId}">&#8597;</button>
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger py-0"
                        onclick="removeSheetPriceRow(${stId})">×</button>
            </td>
        `;
        tbody.appendChild(tr);

        // 階梯展開列
        var tierTr = document.createElement('tr');
        tierTr.className = 'collapse sortable-tier';
        tierTr.id = tierId;
        tierTr.dataset.for = stId;
        tierTr.innerHTML = `
            <td colspan="9" class="p-2 bg-light">
                <table class="table table-sm mb-2">
                    <thead><tr><th>從 (張)</th><th>到 (張)</th><th>單價</th><th></th></tr></thead>
                    <tbody id="sheetTierBody_${stId}"></tbody>
                </table>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="addSheetTier(${stId})">+ 新增階梯</button>
            </td>
        `;
        tbody.appendChild(tierTr);
    }

    function removeSheetPriceRow(stId) {
        addedSheetTypeIds.delete(stId);
        delete sheetTierSets[stId];
        var row = document.getElementById('sheetPriceRow_' + stId);
        var tierRow = document.getElementById('sheetTier_' + stId);
        if (row) row.remove();
        if (tierRow) tierRow.remove();
        refreshAddDropdown();
        updateSheetTiersJson();
    }

    function addSheetPriceRow() {
        var sel = document.getElementById('addSheetTypeSelect');
        var stId = parseInt(sel.value);
        if (!stId) return;
        var st = allSheetTypes.find(function(s) { return s.id === stId; });
        if (!st || addedSheetTypeIds.has(stId)) return;

        appendSheetPriceRow(stId, st.name, 0, 0, 0, null, null);
        renderSheetTiers(stId);
        refreshAddDropdown();
        sel.value = '';
    }

    function refreshAddDropdown() {
        var sel = document.getElementById('addSheetTypeSelect');
        sel.innerHTML = '<option value="">選擇張數類型...</option>';
        allSheetTypes.forEach(function(st) {
            if (!addedSheetTypeIds.has(st.id)) {
                var opt = document.createElement('option');
                opt.value = st.id;
                opt.text = st.name;
                sel.appendChild(opt);
            }
        });
    }

    // ─── 階梯計費 ─────────────────────────────────────────────
    function renderSheetTiers(stId) {
        var tbody = document.getElementById('sheetTierBody_' + stId);
        if (!tbody) return;
        tbody.innerHTML = '';
        var set = sheetTierSets[stId] || [];
        set.forEach(function(tier, index) { addSheetTierRow(stId, tier, index); });
    }

    function addSheetTier(stId) {
        if (!sheetTierSets[stId]) sheetTierSets[stId] = [];
        var set = sheetTierSets[stId];
        var last = set.length > 0 ? set[set.length - 1] : null;
        var from = last && last.toPages ? last.toPages + 1 : (last ? last.fromPages + 500 : 1);
        set.push({ sheetTypeId: stId, fromPages: from, toPages: null, price: 0 });
        renderSheetTiers(stId);
        updateSheetTiersJson();
    }

    function addSheetTierRow(stId, tier, index) {
        var tbody = document.getElementById('sheetTierBody_' + stId);
        var row = document.createElement('tr');
        var toVal = tier.toPages != null ? tier.toPages : '';
        row.innerHTML = `
            <td><input type="number" class="form-control form-control-sm" value="${tier.fromPages}" min="1"
                onchange="updateSheetTier(${stId}, ${index}, 'fromPages', this.value)" /></td>
            <td><input type="number" class="form-control form-control-sm" value="${toVal}" min="0" placeholder="無上限"
                onchange="updateSheetTier(${stId}, ${index}, 'toPages', this.value)" /></td>
            <td><div class="input-group input-group-sm"><span class="input-group-text">$</span>
                <input type="number" class="form-control" value="${tier.price}" step="0.0001" min="0"
                onchange="updateSheetTier(${stId}, ${index}, 'price', this.value)" /></div></td>
            <td><button type="button" class="btn btn-sm btn-outline-danger"
                onclick="removeSheetTier(${stId}, ${index})">刪除</button></td>
        `;
        tbody.appendChild(row);
    }

    function updateSheetTier(stId, index, field, value) {
        if (field === 'toPages') sheetTierSets[stId][index][field] = value === '' ? null : parseInt(value);
        else if (field === 'fromPages') sheetTierSets[stId][index][field] = parseInt(value);
        else sheetTierSets[stId][index][field] = parseFloat(value);
        updateSheetTiersJson();
    }

    function removeSheetTier(stId, index) {
        sheetTierSets[stId].splice(index, 1);
        renderSheetTiers(stId);
        updateSheetTiersJson();
    }

    function updateSheetTiersJson() {
        var all = [];
        addedSheetTypeIds.forEach(function(stId) {
            (sheetTierSets[stId] || []).forEach(function(t) { all.push(t); });
        });
        var el = document.getElementById('sheetTiersJson');
        if (el) el.value = JSON.stringify(all);
    }
</script>
}
