@model List<printer.Data.Entities.SheetTypeConversionRate>
@{
    ViewData["Title"] = "張數互換比例設定";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>張數互換比例設定</h2>
        <p class="text-muted small mb-0">設定不同張數類型贈送頁數之間的折抵換算比例</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">新增比例</a>
        <div class="btn-group">
            <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" id="btnExport" href="#"><i class="bi bi-download me-2"></i>匯出 Excel</a></li>
                <li><a class="dropdown-item" asp-action="Import"><i class="bi bi-upload me-2"></i>匯入 Excel</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" asp-action="DownloadSample"><i class="bi bi-file-earmark-text me-2"></i>下載範本</a></li>
            </ul>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- 說明 -->
<div class="alert alert-info mb-3">
    <strong>折抵邏輯說明：</strong>
    若某類型（來源）的贈送張數有剩餘，可依比例折抵另一類型（目標）的計費張數。<br/>
    <strong>範例：</strong>彩色→黑白，比例 10：1 彩色贈送剩餘 = 10 黑白可被折抵
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary">目前尚未設定任何互換比例</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:36px;"><input type="checkbox" id="selectAll" /></th>
                    <th>被折抵類型（目標）</th>
                    <th>折抵來源（贈送）</th>
                    <th class="text-end">換算比例</th>
                    <th>說明</th>
                    <th>狀態</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rate in Model)
                {
                    <tr class="@(!rate.IsActive ? "table-secondary" : "")">
                        <td><input type="checkbox" class="row-check" value="@rate.Id" /></td>
                        <td>
                            <span class="badge bg-primary">@(rate.FromSheetType?.Name ?? "-")</span>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@(rate.ToSheetType?.Name ?? "-")</span>
                        </td>
                        <td class="text-end">
                            <strong>1 : @rate.Ratio.ToString("G")</strong>
                            <div class="small text-muted">1 @(rate.ToSheetType?.Name) 贈送 = @rate.Ratio @(rate.FromSheetType?.Name) 折抵</div>
                        </td>
                        <td class="small text-muted">@(rate.Note ?? "-")</td>
                        <td>
                            @if (rate.IsActive)
                            {
                                <span class="badge bg-success">啟用</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">停用</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Edit" asp-route-id="@rate.Id"
                                   class="btn btn-sm btn-warning">編輯</a>
                                <form asp-action="Delete" method="post"
                                      onsubmit="return confirm('確認刪除此互換比例？')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@rate.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">刪除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    const selectAll = document.getElementById('selectAll');
    const rowChecks = () => document.querySelectorAll('.row-check');
    if (selectAll) {
        selectAll.addEventListener('change', function () {
            rowChecks().forEach(cb => cb.checked = this.checked);
        });
    }
    const btnExport = document.getElementById('btnExport');
    if (btnExport) {
        btnExport.addEventListener('click', function (e) {
            e.preventDefault();
            const ids = Array.from(document.querySelectorAll('.row-check:checked')).map(cb => cb.value);
            const baseUrl = '@Url.Action("Export", "SheetTypeConversion")';
            const urlParams = new URLSearchParams(window.location.search);
            if (ids.length > 0) {
                urlParams.delete('ids');
                ids.forEach(id => urlParams.append('ids', id));
            }
            window.location = baseUrl + (urlParams.toString() ? '?' + urlParams.toString() : '');
        });
    }
});
</script>
}
