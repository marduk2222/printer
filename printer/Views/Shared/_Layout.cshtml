@inject printer.Services.IPermissionService PermissionService
@{
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var perms = User.Identity?.IsAuthenticated == true
        ? await PermissionService.GetRolePermissionsAsync(userRole)
        : new Dictionary<string, bool>();
    bool Can(string code) => perms.TryGetValue(code, out var v) && v;

    var roleDisplayNames = new Dictionary<string, string>
    {
        ["employee"] = "員工",
        ["supervisor"] = "主管",
        ["admin"] = "系統管理員"
    };
}
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 印表機雲端抄表</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/printer.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">印表機雲端抄表</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (Can("home"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">首頁</a>
                            </li>
                        }
                        @if (Can("partner"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Partner" asp-action="Index">客戶管理</a>
                            </li>
                        }
                        @if (Can("printer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Printer" asp-action="Index">事務機管理</a>
                            </li>
                        }
                        @if (Can("print_record"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="PrintRecord" asp-action="Index">抄表記錄</a>
                            </li>
                        }
                        @if (Can("billing") || Can("invoice") || Can("billing_report") || Can("work_order"))
                        {
                            @await Component.InvokeAsync("ModuleMenu")
                        }
                        @{
                            var hasSystemMenu = Can("system_brand") || Can("system_model") || Can("system_user") || Can("system_module") || Can("system_permission");
                        }
                        @if (hasSystemMenu)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                    系統設定
                                </a>
                                <ul class="dropdown-menu">
                                    @if (Can("system_user"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="AppUser" asp-action="Index">人員管理</a></li>
                                    }
                                    @if (Can("system_permission"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Permission" asp-action="Index">權限設定</a></li>
                                    }
                                    @if (Can("system_brand") || Can("system_model"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    @if (Can("system_brand"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="Brand" asp-action="Index">廠牌管理</a></li>
                                    }
                                    @if (Can("system_model"))
                                    {
                                        <li><a class="dropdown-item" asp-controller="PrinterModel" asp-action="Index">型號管理</a></li>
                                        <li><a class="dropdown-item" asp-controller="SheetType" asp-action="Index">張數類型</a></li>
                                    }
                                    @if (Can("system_module"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        @if (Can("system_module"))
                                        {
                                            <li><a class="dropdown-item" asp-controller="SystemModule" asp-action="Index">模組管理</a></li>
                                        }
                                    }
                                    @if (Can("system_module"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="/swagger">API 文件</a></li>
                                    }
                                </ul>
                            </li>
                        }
                    </ul>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center gap-2 ms-2">
                            <span class="navbar-text text-white-50 small d-none d-md-inline">
                                @User.Identity.Name
                                <span class="badge bg-secondary ms-1">@(roleDisplayNames.GetValueOrDefault(userRole, userRole))</span>
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                                <button type="submit" class="btn btn-outline-light btn-sm">登出</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm ms-2">登入</a>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - 印表機雲端抄表系統
        </div>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('select.ts-select').forEach(function (el) {
                new TomSelect(el, {
                    allowEmptyOption: true,
                    create: false
                });
            });
            document.querySelectorAll('select.ts-multi').forEach(function (el) {
                new TomSelect(el, {
                    plugins: ['remove_button'],
                    create: false,
                    placeholder: el.dataset.placeholder || '請選擇...'
                });
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
