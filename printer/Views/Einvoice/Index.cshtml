@model List<printer.Data.Entities.Einvoice>
@{
    ViewData["Title"] = "發票管理";
    var statusNames = new Dictionary<string, (string Name, string Class)>
    {
        ["draft"] = ("草稿", "bg-secondary"),
        ["issued"] = ("已開立", "bg-success"),
        ["void"] = ("已作廢", "bg-danger"),
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>發票管理</h4>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">開立發票</a>
        <a asp-action="Platforms" class="btn btn-outline-secondary">平台設定</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <select name="partnerId" class="form-select ts-select">
                    <option value="">全部客戶</option>
                    @foreach (SelectListItem item in ViewBag.Partners)
                    {
                        <option value="@item.Value" selected="@(ViewBag.PartnerId?.ToString() == item.Value)">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="status" class="form-select">
                    <option value="">全部狀態</option>
                    <option value="draft" selected="@(ViewBag.Status == "draft")">草稿</option>
                    <option value="issued" selected="@(ViewBag.Status == "issued")">已開立</option>
                    <option value="void" selected="@(ViewBag.Status == "void")">已作廢</option>
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="startDate" class="form-control" value="@(((DateOnly)ViewBag.StartDate).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-2">
                <input type="date" name="endDate" class="form-control" value="@(((DateOnly)ViewBag.EndDate).ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">查詢</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>發票號碼</th>
                        <th>日期</th>
                        <th>客戶</th>
                        <th>統編</th>
                        <th class="text-end">未稅</th>
                        <th class="text-end">稅額</th>
                        <th class="text-end">含稅</th>
                        <th>狀態</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in Model)
                    {
                        var status = statusNames.GetValueOrDefault(inv.Status, ("未知", "bg-secondary"));
                        <tr>
                            <td><strong>@inv.InvoiceNumber</strong></td>
                            <td>@inv.InvoiceDate.ToString("yyyy/MM/dd")</td>
                            <td>@inv.Partner?.Name</td>
                            <td>@inv.BuyerTaxId</td>
                            <td class="text-end">@inv.Amount.ToString("N0")</td>
                            <td class="text-end">@inv.TaxAmount.ToString("N0")</td>
                            <td class="text-end"><strong>@inv.TotalAmount.ToString("N0")</strong></td>
                            <td><span class="badge @status.Item2">@status.Item1</span></td>
                            <td>
                                @if (inv.Status == "draft")
                                {
                                    <a asp-action="Edit" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-warning">編輯</a>
                                }
                                <a asp-action="Details" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-primary">檢視</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <div class="text-center py-4 text-muted">
                <p>尚無發票</p>
            </div>
        }
    </div>
</div>
