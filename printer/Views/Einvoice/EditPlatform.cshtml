@model printer.Data.Entities.EinvoicePlatform
@{
    ViewData["Title"] = $"設定 {Model.Name}";
}

<form asp-action="EditPlatform" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>@Model.Name - 金鑰設定</h4>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success btn-sm">儲存變更</button>
            <a asp-action="Platforms" class="btn btn-outline-secondary btn-sm">返回列表</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="alert alert-info mb-3">
                <strong>正式 API：</strong> @(Model.ApiUrl ?? "-")<br />
                <strong>測試 API：</strong> @(Model.SandboxUrl ?? "-")
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">商店代號 / Merchant ID</label>
                    <input name="merchantId" class="form-control" value="@Model.MerchantId" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">API Key / Hash Key</label>
                    <input name="apiKey" class="form-control" type="password" value="@Model.ApiKey" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">API Secret / Hash IV</label>
                    <input name="apiSecret" class="form-control" type="password" value="@Model.ApiSecret" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-0">
                    <div class="form-check form-switch">
                        <input name="isSandbox" class="form-check-input" type="checkbox" value="true"
                               @(Model.IsSandbox ? "checked" : "") />
                        <label class="form-check-label">測試模式（使用測試 API 網址）</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
