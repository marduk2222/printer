@{
    ViewData["Title"] = "開立發票";
}

<form asp-action="Create" method="post" id="createForm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>開立發票</h4>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success btn-sm" id="submitBtn">建立發票</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">取消</a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-header">發票資訊</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label">客戶 <span class="text-danger">*</span></label>
                    <select name="partnerId" id="partnerId" class="form-select ts-select" required>
                        <option value="">請選擇</option>
                        @foreach (SelectListItem item in ViewBag.Partners)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">發票平台</label>
                    <select name="platformId" class="form-select">
                        <option value="">不指定</option>
                        @foreach (SelectListItem item in ViewBag.Platforms)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">發票日期 <span class="text-danger">*</span></label>
                    <input type="date" name="invoiceDate" class="form-control" value="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" required />
                </div>
            </div>
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label class="form-label">買方統編</label>
                    <input type="text" name="buyerTaxId" id="buyerTaxId" class="form-control" placeholder="自動帶入客戶統編" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">買方名稱</label>
                    <input type="text" name="buyerName" id="buyerName" class="form-control" placeholder="自動帶入客戶名稱" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">買方 Email</label>
                    <input type="email" name="buyerEmail" id="buyerEmail" class="form-control" placeholder="發票寄送 Email" />
                </div>
                <div class="col-md-3 mb-3">
                    <label class="form-label">課稅類別</label>
                    <select name="taxType" id="taxType" class="form-select">
                        <option value="taxable">應稅</option>
                        <option value="zero">零稅率</option>
                        <option value="free">免稅</option>
                    </select>
                </div>
            </div>
            <div class="row">
                <div class="col-md-2 mb-3">
                    <label class="form-label">稅率 (%)</label>
                    <input type="number" name="taxRate" id="taxRate" class="form-control" value="5" min="0" />
                </div>
                <div class="col-md-2 mb-3">
                    <label class="form-label">載具類型</label>
                    <select name="carrierType" id="carrierType" class="form-select">
                        <option value="">紙本</option>
                        <option value="mobile">手機條碼</option>
                        <option value="citizen">自然人憑證</option>
                        <option value="donate">捐贈</option>
                    </select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">載具號碼</label>
                    <input type="text" name="carrierId" id="carrierId" class="form-control" placeholder="如 /AB+12.3" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">愛心碼 (捐贈用)</label>
                    <input type="text" name="donationCode" id="donationCode" class="form-control" placeholder="3-7 位數字" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label">備註</label>
                    <input type="text" name="note" id="note" class="form-control" />
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>發票明細</span>
            <button type="button" class="btn btn-sm btn-primary" id="addItemBtn">新增明細</button>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>品名</th>
                            <th class="text-end" style="width:100px">數量</th>
                            <th class="text-end" style="width:120px">單價</th>
                            <th class="text-end" style="width:120px">小計</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody id="itemsBody"></tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end"><strong>未稅合計</strong></td>
                            <td class="text-end"><strong id="totalAmount">0</strong></td>
                            <td></td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end">稅額</td>
                            <td class="text-end" id="taxAmount">0</td>
                            <td></td>
                        </tr>
                        <tr class="table-primary">
                            <td colspan="3" class="text-end"><strong>含稅總計</strong></td>
                            <td class="text-end"><strong id="grandTotal">0</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div id="emptyMessage" class="text-center py-4 text-muted">
                <p class="mb-0">請新增明細</p>
            </div>
        </div>
    </div>

</form>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const addItemBtn = document.getElementById('addItemBtn');
        const itemsBody = document.getElementById('itemsBody');
        const emptyMessage = document.getElementById('emptyMessage');
        const totalAmountEl = document.getElementById('totalAmount');
        const taxAmountEl = document.getElementById('taxAmount');
        const grandTotalEl = document.getElementById('grandTotal');
        const taxTypeSelect = document.getElementById('taxType');
        const taxRateInput = document.getElementById('taxRate');
        const partnerSelect = document.getElementById('partnerId');
        let itemIndex = 0;

        addItemBtn.addEventListener('click', addItem);
        taxTypeSelect.addEventListener('change', updateTotal);
        taxRateInput.addEventListener('input', updateTotal);

        // 切換客戶時自動帶入發票資訊
        partnerSelect.addEventListener('change', function () {
            const id = partnerSelect.value;
            if (!id) return;
            fetch('@Url.Action("GetInvoiceInfo", "Partner")?id=' + encodeURIComponent(id))
                .then(function (r) { return r.ok ? r.json() : null; })
                .then(function (d) {
                    if (!d) return;
                    document.getElementById('buyerTaxId').value = d.buyerTaxId || '';
                    document.getElementById('buyerName').value = d.buyerName || '';
                    document.getElementById('buyerEmail').value = d.buyerEmail || '';
                    document.getElementById('carrierType').value = d.carrierType || '';
                    document.getElementById('carrierId').value = d.carrierId || '';
                    document.getElementById('donationCode').value = d.donationCode || '';
                    if (d.taxType) {
                        taxTypeSelect.value = d.taxType;
                        updateTotal();
                    }
                    document.getElementById('note').value = d.note || '';
                })
                .catch(function () { /* ignore */ });
        });

        function addItem() {
            emptyMessage.style.display = 'none';
            const idx = itemIndex++;
            const tr = document.createElement('tr');

            tr.innerHTML = `
                <td><input name="items[${idx}].Description" class="form-control form-control-sm" placeholder="品名" required /></td>
                <td><input name="items[${idx}].Quantity" type="number" class="form-control form-control-sm text-end item-qty" min="1" value="1" /></td>
                <td><input name="items[${idx}].UnitPrice" type="number" class="form-control form-control-sm text-end item-price" min="0" step="0.01" value="0" /></td>
                <td><input name="items[${idx}].Subtotal" type="number" class="form-control form-control-sm text-end item-subtotal" min="0" step="0.01" value="0" readonly /></td>
                <td><button type="button" class="btn btn-sm btn-outline-danger remove-item">X</button></td>
            `;

            const qtyInput = tr.querySelector('.item-qty');
            const priceInput = tr.querySelector('.item-price');
            const subtotalInput = tr.querySelector('.item-subtotal');

            function calcRow() {
                const qty = parseInt(qtyInput.value) || 0;
                const price = parseFloat(priceInput.value) || 0;
                subtotalInput.value = (qty * price).toFixed(2);
                updateTotal();
            }

            qtyInput.addEventListener('input', calcRow);
            priceInput.addEventListener('input', calcRow);

            tr.querySelector('.remove-item').addEventListener('click', function () {
                tr.remove();
                updateTotal();
                if (itemsBody.children.length === 0) emptyMessage.style.display = '';
            });

            itemsBody.appendChild(tr);
            updateTotal();
        }

        function updateTotal() {
            let amount = 0;
            document.querySelectorAll('.item-subtotal').forEach(el => {
                amount += parseFloat(el.value) || 0;
            });

            const taxType = taxTypeSelect.value;
            const taxRate = parseInt(taxRateInput.value) || 0;
            const tax = taxType === 'taxable' ? Math.round(amount * taxRate / 100) : 0;

            totalAmountEl.textContent = amount.toLocaleString('zh-TW');
            taxAmountEl.textContent = tax.toLocaleString('zh-TW');
            grandTotalEl.textContent = (amount + tax).toLocaleString('zh-TW');
        }
    });
</script>
}
