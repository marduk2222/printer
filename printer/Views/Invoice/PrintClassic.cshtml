@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1e6b45";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>帳單 - @Model.Invoice.InvoiceNumber</title>
    <style>
        :root { --p: @primary; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif; color: #222; background: #fff; font-size: 13px; }
        .no-print { display: flex; gap: 8px; padding: 12px; background: #f3f4f6; border-bottom: 1px solid #e5e7eb; }
        .no-print button { padding: 8px 20px; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; }
        .btn-print { background: var(--p); color: #fff; }
        .btn-back { background: #6b7280; color: #fff; }
        .page { max-width: 820px; margin: 20px auto; padding: 30px 36px; border: 2px solid var(--p); }
        .header { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 16px; border-bottom: 3px double var(--p); margin-bottom: 18px; }
        .company-name { font-size: 24px; font-weight: bold; color: var(--p); margin-bottom: 4px; }
        .company-slogan { font-size: 12px; color: #666; margin-bottom: 8px; }
        .company-meta { font-size: 11px; color: #555; line-height: 1.6; }
        .invoice-box { text-align: right; }
        .invoice-title { font-size: 22px; font-weight: bold; color: var(--p); letter-spacing: 4px; }
        .invoice-no { margin-top: 4px; font-size: 13px; color: #444; }
        .meta-row { display: flex; gap: 24px; margin-bottom: 18px; }
        .meta-block { flex: 1; }
        .meta-block h6 { font-size: 11px; color: var(--p); font-weight: bold; letter-spacing: 1px; padding-bottom: 4px; border-bottom: 1px solid var(--p); margin-bottom: 6px; }
        .meta-block p { font-size: 12px; margin: 2px 0; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
        thead tr { background: var(--p); color: #fff; }
        th, td { padding: 8px 10px; border: 1px solid #ccc; font-size: 12px; text-align: center; }
        th { font-weight: bold; }
        td.left { text-align: left; }
        td.right { text-align: right; }
        tbody tr:nth-child(even) { background: #f8faf8; }
        .totals { display: flex; justify-content: flex-end; margin-bottom: 16px; }
        .totals-table { width: 280px; }
        .totals-table td { padding: 6px 10px; border: 1px solid #ccc; font-size: 12px; }
        .totals-table .label { background: #f3f4f6; font-weight: bold; }
        .totals-table .grand { background: var(--p); color: #fff; font-weight: bold; font-size: 14px; }
        .footer { margin-top: 18px; padding-top: 12px; border-top: 1px solid #ddd; }
        .footer h6 { font-size: 12px; font-weight: bold; color: var(--p); margin-bottom: 4px; }
        .footer p { font-size: 11px; color: #555; line-height: 1.6; }
        @@media print { .no-print { display: none !important; } }
        @@page { size: A4; margin: 12mm; }
    </style>
</head>
<body>
    <div class="no-print">
        <button class="btn-print" onclick="window.print()">列印</button>
        <button class="btn-back" onclick="history.back()">返回</button>
    </div>
    <div class="page">
        <div class="header">
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyLogoUrl))
                {
                    <img src="@Model.Settings.CompanyLogoUrl" alt="Logo" style="max-height:50px;margin-bottom:6px;" />
                }
                <div class="company-name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
                @if (!string.IsNullOrEmpty(Model.Settings.CompanySlogan)) { <div class="company-slogan">@Model.Settings.CompanySlogan</div> }
                <div class="company-meta">
                    @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>@Model.Settings.CompanyAddress</div> }
                    @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>電話：@Model.Settings.CompanyPhone　</span> }
                    @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>Email：@Model.Settings.CompanyEmail</span> }
                </div>
            </div>
            <div class="invoice-box">
                <div class="invoice-title">帳　單</div>
                <div class="invoice-no">編號：@Model.Invoice.InvoiceNumber</div>
                <div class="invoice-no">日期：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div>
            </div>
        </div>

        <div class="meta-row">
            <div class="meta-block">
                <h6>客戶資訊</h6>
                <p><strong>@buyerName</strong></p>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統一編號：@buyerTaxId</p> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <p>地址：@partner.Address</p> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
                @if (!string.IsNullOrEmpty(partner?.ContactName)) { <p>聯絡人：@partner.ContactName</p> }
            </div>
            <div class="meta-block">
                <h6>帳單期間</h6>
                <p>計費期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
                @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>付款條件：@Model.Settings.PaymentTerms</p> }
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width:34%">項目說明</th>
                    <th style="width:10%">黑白</th>
                    <th style="width:10%">彩色</th>
                    <th style="width:10%">大張</th>
                    <th style="width:12%">月租費</th>
                    <th style="width:12%">張數費</th>
                    <th style="width:12%">小計</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in Model.Invoice.Items)
                {
                    <tr>
                        <td class="left">@it.Description</td>
                        <td>@it.BlackPages.ToString("N0")</td>
                        <td>@it.ColorPages.ToString("N0")</td>
                        <td>@it.LargePages.ToString("N0")</td>
                        <td class="right">@it.MonthlyFee.ToString("N0")</td>
                        <td class="right">@it.PageFee.ToString("N0")</td>
                        <td class="right">@it.Subtotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="totals">
            <table class="totals-table">
                <tr><td class="label">未稅小計</td><td class="right">$@Model.Invoice.TotalAmount.ToString("N0")</td></tr>
                <tr><td class="label">營業稅 (5%)</td><td class="right">$@Model.Invoice.TaxAmount.ToString("N0")</td></tr>
                <tr><td class="grand">含稅總計</td><td class="right grand">$@Model.Invoice.GrandTotal.ToString("N0")</td></tr>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.BankAccount))
        {
            <div class="footer">
                <h6>匯款資訊</h6>
                @if (!string.IsNullOrEmpty(Model.Settings.BankName)) { <p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</p> }
                @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> }
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.Settings.FooterNote))
        {
            <div class="footer"><p style="text-align:center;color:#666;">@Model.Settings.FooterNote</p></div>
        }
    </div>
</body>
</html>
