@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#b45309";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; --gold: #d4a017; --dark: #1c1917; --paper: #fffbeb; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Cormorant Garamond", "Noto Serif TC", serif; color: #1c1917; background: #292524; font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: var(--dark); border-bottom: 1px solid var(--gold); }
.no-print button { padding: 8px 22px; border: 1px solid var(--gold); background: transparent; color: var(--gold); cursor: pointer; font-size: 14px; letter-spacing: 2px; }
.btn-print { background: var(--gold) !important; color: var(--dark) !important; }
.page { max-width: 820px; margin: 24px auto; background: var(--paper); padding: 0; border: 2px solid var(--gold); position: relative; }
.gold-bar { background: var(--dark); padding: 28px 36px; border-bottom: 3px solid var(--gold); position: relative; }
.gold-bar::after { content: ''; position: absolute; bottom: -7px; left: 0; right: 0; height: 1px; background: var(--gold); }
.gold-bar .name { color: var(--gold); font-size: 30px; font-weight: 600; letter-spacing: 4px; }
.gold-bar .slogan { color: #a8a29e; font-size: 12px; font-style: italic; margin-top: 4px; letter-spacing: 2px; }
.gold-bar .meta { color: #d4d4d8; font-size: 11px; margin-top: 8px; line-height: 1.7; }
.gold-bar .doc { position: absolute; top: 28px; right: 36px; text-align: right; }
.gold-bar .doc .lbl { color: var(--gold); font-size: 11px; letter-spacing: 6px; }
.gold-bar .doc .num { color: #fff; font-size: 18px; margin-top: 4px; }
.body { padding: 32px 36px; }
.title { text-align: center; font-size: 32px; color: var(--p); letter-spacing: 12px; margin-bottom: 6px; font-weight: 500; }
.divider { text-align: center; color: var(--gold); font-size: 14px; letter-spacing: 6px; margin-bottom: 24px; }
.info { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; padding: 18px 22px; background: #fff; border: 1px solid var(--gold); margin-bottom: 22px; }
.info h6 { color: var(--p); font-size: 11px; letter-spacing: 4px; margin-bottom: 8px; font-family: "Noto Serif TC", serif; }
.info p { font-family: "Noto Sans TC", sans-serif; font-size: 12px; color: #44403c; margin: 3px 0; }
table { width: 100%; border-collapse: collapse; margin-bottom: 22px; font-family: "Noto Sans TC", sans-serif; background: #fff; border: 1px solid var(--gold); }
thead tr { background: var(--dark); color: var(--gold); }
th { padding: 12px 12px; font-size: 12px; letter-spacing: 1px; text-align: center; border-bottom: 2px solid var(--gold); }
th:first-child { text-align: left; }
td { padding: 11px 12px; border-bottom: 1px solid #f5e8c8; font-size: 12px; text-align: center; color: #292524; }
td.left { text-align: left; }
td.right { text-align: right; color: var(--p); font-weight: 600; }
.totals { display: flex; justify-content: flex-end; margin-bottom: 24px; }
.totals-card { width: 320px; background: #fff; border: 2px solid var(--gold); padding: 6px 0; }
.totals-row { display: flex; justify-content: space-between; padding: 10px 18px; font-family: "Noto Sans TC", sans-serif; font-size: 13px; color: #44403c; border-bottom: 1px solid #fef3c7; }
.totals-row.grand { background: var(--dark); color: var(--gold); border: none; font-size: 16px; font-weight: 700; padding: 14px 18px; }
.foot { padding-top: 18px; border-top: 1px solid var(--gold); display: grid; grid-template-columns: 1fr 1fr; gap: 24px; font-family: "Noto Sans TC", sans-serif; font-size: 11px; color: #57534e; }
.foot h6 { color: var(--p); font-size: 11px; letter-spacing: 3px; margin-bottom: 4px; }
.foot p { line-height: 1.7; }
@@media print { body { background: var(--paper) !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; } .no-print { display: none !important; } .page { margin: 0; max-width: none; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">PRINT</button><button onclick="history.back()">BACK</button></div>
<div class="page">
    <div class="gold-bar">
        <div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
        @if (!string.IsNullOrEmpty(Model.Settings.CompanySlogan)) { <div class="slogan">— @Model.Settings.CompanySlogan —</div> }
        <div class="meta">
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>@Model.Settings.CompanyAddress</div> }
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>電話 @Model.Settings.CompanyPhone　</span> }
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>@Model.Settings.CompanyEmail</span> }
        </div>
        <div class="doc"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div>
    </div>
    <div class="body">
        <div class="title">帳　單</div>
        <div class="divider">◆ ◆ ◆</div>
        <div class="info">
            <div>
                <h6>致 客 戶</h6>
                <p><strong>@buyerName</strong></p>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統一編號：@buyerTaxId</p> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
            </div>
            <div>
                <h6>帳 單 資 訊</h6>
                <p>開立：@Model.Invoice.CreatedAt.ToString("yyyy / MM / dd")</p>
                <p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
                @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>條件：@Model.Settings.PaymentTerms</p> }
            </div>
        </div>
        <table>
            <thead><tr><th style="width:36%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
            <tbody>
                @foreach (var it in Model.Invoice.Items) {
                    <tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
                }
            </tbody>
        </table>
        <div class="totals"><div class="totals-card">
            <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
            <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
            <div class="totals-row grand"><span>TOTAL</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
        </div></div>
        <div class="foot">
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.BankName)) {
                    <h6>PAYMENT</h6>
                    <p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</p>
                    @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> }
                }
            </div>
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>NOTE</h6><p>@Model.Settings.FooterNote</p> }
            </div>
        </div>
    </div>
</div></body></html>
