@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1d4ed8";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Inter","Noto Sans TC",sans-serif;color:#1e293b;background:#f8fafc;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e2e8f0}.no-print button{padding:8px 22px;border:none;cursor:pointer;font-size:14px;border-radius:6px;background:var(--p);color:#fff}
.btn-back{background:#94a3b8 !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:36px 40px;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.06)}
.head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px}
.head .name{color:var(--p);font-size:24px;font-weight:700}.head .meta{color:#64748b;font-size:11px;line-height:1.7;margin-top:4px}
.doc-card{background:var(--p);color:#fff;padding:14px 22px;border-radius:6px;text-align:right}
.doc-card .lbl{font-size:11px;opacity:.85;letter-spacing:2px}.doc-card .num{font-size:18px;font-weight:700;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:14px 18px;background:#f1f5f9;border-radius:8px;margin-bottom:22px}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;margin:2px 0;color:#334155}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:#fff;color:var(--p);border-bottom:2px solid var(--p);font-size:12px;text-align:center}
th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #e2e8f0;font-size:12px;text-align:center}
td.left{text-align:left}td.right{text-align:right;font-variant-numeric:tabular-nums}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;background:#f8fafc;border-radius:8px;padding:6px 0}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;color:#475569}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border-radius:0 0 7px 7px}
.sign-card{margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:18px}
.sign-card .col{background:#f8fafc;border-radius:8px;padding:18px;border-top:3px solid var(--p)}
.sign-card .lbl{color:var(--p);font-size:12px;font-weight:600;letter-spacing:2px;margin-bottom:14px}
.sign-card .area{height:80px;background:#fff;border:1px solid #e2e8f0;border-radius:4px;display:flex;align-items:center;justify-content:center;color:#cbd5e1;font-size:11px}
.sign-card .meta{margin-top:10px;display:grid;grid-template-columns:60px 1fr;gap:6px;font-size:11px;color:#64748b}
.sign-card .meta .v{color:#1e293b;font-weight:500}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button onclick="window.print()">列印</button><button class="btn-back" onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　@Model.Settings.CompanyPhone</span>}</div></div><div class="doc-card"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="info"><div><h6>BILL TO</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>DATE</h6><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="sign-card">
    <div class="col">
        <div class="lbl">✍ 客 戶 簽 名</div>
        <div class="area">客戶簽章區</div>
        <div class="meta"><div>姓名</div><div class="v">@buyerName</div><div>日期</div><div class="v">　　　/　　/　　</div></div>
    </div>
    <div class="col">
        <div class="lbl">✓ 承 辦 人 員 簽 名</div>
        <div class="area">承辦人簽章區</div>
        <div class="meta"><div>單位</div><div class="v">@(Model.Settings.CompanyName ?? "")</div><div>日期</div><div class="v">@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
    </div>
</div>
</div></body></html>
