@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#16a34a";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>INVOICE - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"JetBrains Mono","Consolas","Noto Sans Mono CJK TC",monospace;color:#111;background:#fff;font-size:12px;line-height:1.6}
.no-print{display:flex;gap:8px;padding:12px;background:#f5f5f4;border-bottom:1px solid #d6d3d1}.no-print button{padding:8px 22px;border:1px solid #111;background:#fff;color:#111;cursor:pointer;font-size:13px;font-family:inherit}.btn-print{background:#111 !important;color:#fff !important}
.page{max-width:740px;margin:30px auto;padding:36px 40px;border:2px solid #111}
.h1{font-size:18px;font-weight:bold;border-bottom:1px solid #111;padding-bottom:6px;margin-bottom:14px;letter-spacing:1px}
pre{font-family:inherit;font-size:12px;white-space:pre-wrap;margin:0}
.box{border:1px solid #111;padding:10px 14px;margin-bottom:14px}
.box .label{color:var(--p);font-weight:bold;margin-right:6px}
table{width:100%;border-collapse:collapse;margin-bottom:14px}th{padding:6px 8px;border-top:2px solid #111;border-bottom:1px solid #111;font-size:11px;text-align:center;background:#f5f5f4}th:first-child{text-align:left}
td{padding:6px 8px;border-bottom:1px dashed #888;font-size:11px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals{margin-left:auto;width:300px;border:1px solid #111;padding:8px 12px}.totals-row{display:flex;justify-content:space-between;padding:3px 0;font-size:12px}.totals-row.grand{border-top:1px solid #111;padding-top:6px;margin-top:4px;font-weight:bold;font-size:14px}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none}}@@page{size:A4;margin:14mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">[ PRINT ]</button><button onclick="history.back()">[ BACK ]</button></div>
<div class="page">
<div class="h1">================ INVOICE / 帳單 ================</div>
<pre>
公司：@(Model.Settings.CompanyName ?? "公司名稱")
地址：@Model.Settings.CompanyAddress
電話：@Model.Settings.CompanyPhone

----------------------------------------
編號：@Model.Invoice.InvoiceNumber
日期：@Model.Invoice.CreatedAt.ToString("yyyy-MM-dd")
期間：@Model.Invoice.PeriodStart.ToString("yyyy-MM-dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy-MM-dd")
----------------------------------------
</pre>
<div class="box">
<div><span class="label">客戶：</span><strong>@buyerName</strong></div>
@if(!string.IsNullOrEmpty(buyerTaxId)){<div><span class="label">統編：</span>@buyerTaxId</div>}
@if(!string.IsNullOrEmpty(partner?.Address)){<div><span class="label">地址：</span>@partner.Address</div>}
@if(!string.IsNullOrEmpty(partner?.Phone)){<div><span class="label">電話：</span>@partner.Phone</div>}
</div>
<table><thead><tr><th>項目</th><th>黑</th><th>彩</th><th>大</th><th>月租</th><th>張數</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals">
    <div class="totals-row"><span>未稅 ............</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
    <div class="totals-row"><span>稅 (5%) .........</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
    <div class="totals-row grand"><span>>>> TOTAL ......</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
</div>
@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<pre style="margin-top:14px;">

匯款：@Model.Settings.BankName @Model.Settings.BankBranch / 帳號 @Model.Settings.BankAccount
</pre>}
@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<pre>
備註：@Model.Settings.FooterNote
</pre>}
<pre>================================================</pre>
</div></body></html>
