@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#6366f1";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; --pink: #ec4899; --soft: #faf5ff; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Noto Sans TC", "Microsoft JhengHei", sans-serif; color: #312e81; background: var(--soft); font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: #fff; border-bottom: 1px solid #e9d5ff; }
.no-print button { padding: 8px 22px; border: none; cursor: pointer; font-size: 14px; border-radius: 24px; background: linear-gradient(135deg,var(--p),var(--pink)); color: #fff; }
.btn-back { background: #cbd5e1 !important; color: #475569 !important; }
.page { max-width: 820px; margin: 24px auto; background: #fff; padding: 0; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 32px rgba(99,102,241,0.15); }
.hero { background: linear-gradient(135deg,var(--p),var(--pink)); color: #fff; padding: 32px 36px; }
.hero .name { font-size: 26px; font-weight: 700; margin-bottom: 4px; }
.hero .slogan { font-size: 12px; opacity: 0.9; margin-bottom: 8px; }
.hero .meta { font-size: 11px; opacity: 0.85; line-height: 1.7; }
.hero .doc { float: right; text-align: right; padding: 8px 18px; background: rgba(255,255,255,0.18); border-radius: 24px; backdrop-filter: blur(8px); }
.hero .doc .lbl { font-size: 10px; letter-spacing: 3px; opacity: 0.85; }
.hero .doc .num { font-size: 18px; font-weight: 700; margin-top: 2px; }
.body { padding: 28px 36px; }
.info { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 22px; }
.info .card { background: var(--soft); border-radius: 12px; padding: 16px 18px; border-left: 4px solid var(--p); }
.info h6 { color: var(--p); font-size: 11px; letter-spacing: 2px; margin-bottom: 6px; }
.info p { font-size: 12px; color: #4338ca; margin: 2px 0; }
table { width: 100%; border-collapse: separate; border-spacing: 0 4px; margin-bottom: 18px; }
th { padding: 10px 14px; background: linear-gradient(90deg,var(--p),var(--pink)); color: #fff; font-size: 12px; text-align: center; }
th:first-child { text-align: left; border-radius: 8px 0 0 8px; }
th:last-child { border-radius: 0 8px 8px 0; }
td { padding: 10px 14px; background: var(--soft); font-size: 12px; text-align: center; color: #312e81; }
td:first-child { border-radius: 8px 0 0 8px; text-align: left; }
td:last-child { border-radius: 0 8px 8px 0; text-align: right; }
.totals { display: flex; justify-content: flex-end; margin-bottom: 22px; }
.totals-card { width: 320px; }
.totals-row { display: flex; justify-content: space-between; padding: 8px 16px; font-size: 13px; color: #4338ca; }
.totals-row.grand { background: linear-gradient(135deg,var(--p),var(--pink)); color: #fff; padding: 14px 18px; border-radius: 12px; margin-top: 6px; font-weight: 700; font-size: 15px; }
.foot { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; padding-top: 16px; border-top: 1px dashed #e9d5ff; }
.foot h6 { color: var(--p); font-size: 11px; margin-bottom: 4px; }
.foot p { font-size: 11px; color: #6b21a8; line-height: 1.7; }
@@media print { body { background: #fff; } .no-print { display: none !important; } .page { box-shadow: none; margin: 0; max-width: none; -webkit-print-color-adjust: exact; print-color-adjust: exact; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button onclick="window.print()">🖨 列印</button><button class="btn-back" onclick="history.back()">← 返回</button></div>
<div class="page">
    <div class="hero">
        <div class="doc"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div>
        <div class="name">✨ @(Model.Settings.CompanyName ?? "公司名稱")</div>
        @if (!string.IsNullOrEmpty(Model.Settings.CompanySlogan)) { <div class="slogan">@Model.Settings.CompanySlogan</div> }
        <div class="meta">
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>@Model.Settings.CompanyAddress</div> }
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>Tel @Model.Settings.CompanyPhone　</span> }
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>@Model.Settings.CompanyEmail</span> }
        </div>
    </div>
    <div class="body">
        <div class="info">
            <div class="card">
                <h6>客戶資訊</h6>
                <p><strong>@buyerName</strong></p>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統編：@buyerTaxId</p> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
            </div>
            <div class="card">
                <h6>帳單資訊</h6>
                <p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p>
                <p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
                @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>付款：@Model.Settings.PaymentTerms</p> }
            </div>
        </div>
        <table>
            <thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th>小計</th></tr></thead>
            <tbody>
                @foreach (var it in Model.Invoice.Items) {
                    <tr><td>@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td>@it.MonthlyFee.ToString("N0")</td><td>@it.PageFee.ToString("N0")</td><td>$@it.Subtotal.ToString("N0")</td></tr>
                }
            </tbody>
        </table>
        <div class="totals"><div class="totals-card">
            <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
            <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
            <div class="totals-row grand"><span>應付總額</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
        </div></div>
        <div class="foot">
            <div>@if (!string.IsNullOrEmpty(Model.Settings.BankName)) { <h6>💳 匯款資訊</h6><p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</p>@if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> } }</div>
            <div>@if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>📝 備註</h6><p>@Model.Settings.FooterNote</p> }</div>
        </div>
    </div>
</div></body></html>
