@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1d4ed8";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>帳單 - @Model.Invoice.InvoiceNumber</title>
    <style>
        :root { --p: @primary; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif; color: #1f2937; background: #f8fafc; font-size: 13px; }
        .no-print { display: flex; gap: 8px; padding: 12px; background: #fff; border-bottom: 1px solid #e5e7eb; }
        .no-print button { padding: 8px 22px; border: none; border-radius: 6px; cursor: pointer; font-size: 14px; }
        .btn-print { background: var(--p); color: #fff; }
        .btn-back { background: #6b7280; color: #fff; }
        .page { max-width: 820px; margin: 24px auto; background: #fff; padding: 36px 40px; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
        .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; }
        .brand .name { font-size: 26px; font-weight: 700; color: var(--p); }
        .brand .slogan { font-size: 12px; color: #94a3b8; margin-top: 2px; }
        .brand .meta { margin-top: 10px; font-size: 11px; color: #64748b; line-height: 1.7; }
        .doc-tag { background: var(--p); color: #fff; padding: 12px 22px; border-radius: 6px; text-align: right; }
        .doc-tag .lbl { font-size: 11px; opacity: 0.85; letter-spacing: 2px; }
        .doc-tag .num { font-size: 18px; font-weight: 700; margin-top: 2px; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; padding: 16px 18px; background: #f1f5f9; border-radius: 6px; }
        .info-block h6 { font-size: 11px; color: var(--p); font-weight: 700; letter-spacing: 1px; margin-bottom: 6px; }
        .info-block p { font-size: 12px; color: #334155; margin: 2px 0; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
        th { padding: 10px 12px; background: #fff; color: var(--p); border-bottom: 2px solid var(--p); font-size: 12px; text-align: center; font-weight: 600; }
        td { padding: 10px 12px; border-bottom: 1px solid #e2e8f0; font-size: 12px; text-align: center; }
        td.left { text-align: left; }
        td.right { text-align: right; font-variant-numeric: tabular-nums; }
        .totals { display: flex; justify-content: flex-end; }
        .totals-card { width: 280px; background: #f8fafc; border-radius: 8px; padding: 4px 0; }
        .totals-row { display: flex; justify-content: space-between; padding: 8px 16px; font-size: 12px; border-bottom: 1px solid #e2e8f0; }
        .totals-row:last-child { background: var(--p); color: #fff; border-radius: 0 0 8px 8px; border: none; font-weight: 700; font-size: 14px; }
        .footer { margin-top: 24px; padding-top: 16px; border-top: 1px solid #e2e8f0; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .footer h6 { font-size: 11px; color: var(--p); font-weight: 700; letter-spacing: 1px; margin-bottom: 4px; }
        .footer p { font-size: 11px; color: #64748b; line-height: 1.7; }
        @@media print { body { background: #fff; } .no-print { display: none !important; } .page { box-shadow: none; margin: 0; max-width: none; } }
        @@page { size: A4; margin: 12mm; }
    </style>
</head>
<body>
    <div class="no-print">
        <button class="btn-print" onclick="window.print()">列印</button>
        <button class="btn-back" onclick="history.back()">返回</button>
    </div>
    <div class="page">
        <div class="header">
            <div class="brand">
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyLogoUrl))
                {
                    <img src="@Model.Settings.CompanyLogoUrl" alt="Logo" style="max-height:48px;margin-bottom:8px;" />
                }
                <div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
                @if (!string.IsNullOrEmpty(Model.Settings.CompanySlogan)) { <div class="slogan">@Model.Settings.CompanySlogan</div> }
                <div class="meta">
                    @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>@Model.Settings.CompanyAddress</div> }
                    @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>Tel: @Model.Settings.CompanyPhone　</span> }
                    @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>@Model.Settings.CompanyEmail</span> }
                </div>
            </div>
            <div class="doc-tag">
                <div class="lbl">INVOICE / 帳單</div>
                <div class="num">@Model.Invoice.InvoiceNumber</div>
            </div>
        </div>

        <div class="info-grid">
            <div class="info-block">
                <h6>BILL TO / 客戶</h6>
                <p><strong>@buyerName</strong></p>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統一編號：@buyerTaxId</p> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
            </div>
            <div class="info-block">
                <h6>DATE / 日期</h6>
                <p>開立日期：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p>
                <p>計費期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
                @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>付款條件：@Model.Settings.PaymentTerms</p> }
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width:36%;text-align:left;padding-left:12px;">項目</th>
                    <th>黑白</th><th>彩色</th><th>大張</th>
                    <th>月租費</th><th>張數費</th>
                    <th style="text-align:right;">小計</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in Model.Invoice.Items)
                {
                    <tr>
                        <td class="left">@it.Description</td>
                        <td>@it.BlackPages.ToString("N0")</td>
                        <td>@it.ColorPages.ToString("N0")</td>
                        <td>@it.LargePages.ToString("N0")</td>
                        <td class="right">@it.MonthlyFee.ToString("N0")</td>
                        <td class="right">@it.PageFee.ToString("N0")</td>
                        <td class="right">$@it.Subtotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="totals">
            <div class="totals-card">
                <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
                <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
                <div class="totals-row"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.FooterNote))
        {
            <div class="footer">
                <div>
                    <h6>PAYMENT / 匯款資訊</h6>
                    @if (!string.IsNullOrEmpty(Model.Settings.BankName)) { <p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</p> }
                    @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> }
                </div>
                <div>
                    @if (!string.IsNullOrEmpty(Model.Settings.FooterNote))
                    {
                        <h6>NOTE / 備註</h6>
                        <p>@Model.Settings.FooterNote</p>
                    }
                </div>
            </div>
        }
    </div>
</body>
</html>
