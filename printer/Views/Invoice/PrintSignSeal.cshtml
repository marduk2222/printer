@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#be123c";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Serif TC",serif;color:#1f2937;background:#fafaf9;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:34px 40px;border:2px solid var(--p);position:relative}
.head{padding-bottom:14px;border-bottom:2px solid var(--p);margin-bottom:18px;display:flex;justify-content:space-between;align-items:flex-end}
.head .name{font-size:24px;color:var(--p);font-weight:600;letter-spacing:2px}
.head .meta{font-size:11px;color:#525252;font-family:"Noto Sans TC",sans-serif;line-height:1.7;margin-top:6px}
.head .doc{text-align:right;font-family:"Noto Sans TC",sans-serif}
.head .doc .lbl{font-size:11px;color:var(--p);letter-spacing:3px}.head .doc .num{font-size:18px;font-weight:600}
.title{text-align:center;font-size:24px;color:var(--p);letter-spacing:14px;margin:14px 0}
.info{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:14px 18px;background:#fef2f2;border-left:4px solid var(--p);margin-bottom:18px;font-family:"Noto Sans TC",sans-serif}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:18px;border:1px solid var(--p);font-family:"Noto Sans TC",sans-serif}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #fecaca;font-size:12px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals-row{display:flex;justify-content:flex-end;gap:14px;padding:5px 6px;font-family:"Noto Sans TC",sans-serif;font-size:13px}
.totals-row .v{min-width:120px;text-align:right}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;margin-top:6px}
.seal-row{margin-top:32px;display:grid;grid-template-columns:repeat(4,1fr);gap:14px;font-family:"Noto Sans TC",sans-serif}
.seal-cell{text-align:center}
.seal-cell .lbl{font-size:11px;color:var(--p);font-weight:600;margin-bottom:8px;letter-spacing:2px;padding-bottom:4px;border-bottom:1px solid var(--p)}
.seal-cell .stamp{height:80px;border:2px solid var(--p);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fecaca;font-size:10px;margin:6px auto;width:80px}
.seal-cell .name{font-size:11px;color:#525252;margin-top:4px}
.dual-sig{margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:36px;font-family:"Noto Sans TC",sans-serif;padding-top:16px;border-top:2px dashed var(--p)}
.dual-sig .col h6{font-size:12px;color:var(--p);font-weight:600;margin-bottom:14px;letter-spacing:3px;text-align:center}
.dual-sig .col .line{display:grid;grid-template-columns:60px 1fr;gap:8px;align-items:center;margin-bottom:10px;font-size:11px}
.dual-sig .col .line .lbl{color:#525252}
.dual-sig .col .line .v{border-bottom:1px solid #1f2937;height:24px;padding:0 4px}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:14mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　電話 @Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="title">帳　單</div>
<div class="info"><div><h6>客　戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>帳　單</h6><p>編號：@Model.Invoice.InvoiceNumber</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals-row"><span>未稅小計</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
<div class="totals-row"><span>營業稅 (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
<div class="totals-row grand"><span>含稅總計</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
<div class="seal-row">
    <div class="seal-cell"><div class="lbl">經　辦</div><div class="stamp">經辦章</div><div class="name"></div></div>
    <div class="seal-cell"><div class="lbl">覆　核</div><div class="stamp">覆核章</div><div class="name"></div></div>
    <div class="seal-cell"><div class="lbl">會　計</div><div class="stamp">會計章</div><div class="name"></div></div>
    <div class="seal-cell"><div class="lbl">主　管</div><div class="stamp">主管章</div><div class="name"></div></div>
</div>
<div class="dual-sig">
    <div class="col"><h6>客　戶　簽　名</h6><div class="line"><div class="lbl">姓名</div><div class="v">@buyerName</div></div><div class="line"><div class="lbl">日期</div><div class="v">　　　/　　/　　</div></div><div class="line"><div class="lbl">簽章</div><div class="v" style="height:50px"></div></div></div>
    <div class="col"><h6>本公司簽章</h6><div class="line"><div class="lbl">公司</div><div class="v">@(Model.Settings.CompanyName ?? "")</div></div><div class="line"><div class="lbl">承辦</div><div class="v"></div></div><div class="line"><div class="lbl">簽章</div><div class="v" style="height:50px"></div></div></div>
</div>
</div></body></html>
