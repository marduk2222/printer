@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#dc2626";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#fff;font-size:11px;line-height:1.4}
.no-print{display:flex;gap:8px;padding:8px;background:#f9fafb;border-bottom:1px solid #e5e7eb}.no-print button{padding:6px 16px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:12px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:8px auto;padding:14px 18px;border:1px solid var(--p)}
.head{display:flex;justify-content:space-between;align-items:center;padding:6px 10px;background:var(--p);color:#fff;font-size:11px;margin:-14px -18px 8px}
.head .name{font-size:14px;font-weight:700}.head .doc{font-size:11px}
.dense-strip{display:flex;flex-wrap:wrap;gap:0;border:1px solid #d1d5db;margin-bottom:8px;font-size:10px}
.dense-strip span{padding:4px 8px;border-right:1px solid #d1d5db;white-space:nowrap}
.dense-strip span:last-child{border-right:none}
.dense-strip strong{color:var(--p)}
table{width:100%;border-collapse:collapse;margin-bottom:8px}th{padding:5px 6px;background:#fef2f2;color:var(--p);border:1px solid #d1d5db;font-size:10px;text-align:center}th:first-child{text-align:left}
td{padding:5px 6px;border:1px solid #e5e7eb;font-size:10px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals-row{display:flex;justify-content:flex-end;gap:14px;padding:3px 8px;font-size:11px}.totals-row .v{min-width:80px;text-align:right}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:5px 8px;font-size:12px;margin-top:3px}
.foot{display:flex;flex-wrap:wrap;gap:12px;padding-top:6px;border-top:1px dashed #d1d5db;font-size:10px;color:#6b7280}.foot strong{color:var(--p)}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:8mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="doc">INV @Model.Invoice.InvoiceNumber　·　@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
<div class="dense-strip"><span><strong>客戶</strong> @buyerName</span>@if(!string.IsNullOrEmpty(buyerTaxId)){<span><strong>統編</strong> @buyerTaxId</span>}@if(!string.IsNullOrEmpty(partner?.Address)){<span><strong>地址</strong> @partner.Address</span>}@if(!string.IsNullOrEmpty(partner?.Phone)){<span><strong>電話</strong> @partner.Phone</span>}<span><strong>期間</strong> @Model.Invoice.PeriodStart.ToString("yyyy/MM/dd")~@Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</span></div>
<table><thead><tr><th>#</th><th style="width:30%">項目</th><th>黑</th><th>彩</th><th>大</th><th>月租</th><th>張數</th><th style="text-align:right;">小計</th></tr></thead><tbody>@{int i=1;}@foreach(var it in Model.Invoice.Items){<tr><td>@i</td><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>i++;}</tbody></table>
<div class="totals-row"><span>未稅</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
<div class="totals-row"><span>稅 (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
<div class="totals-row grand"><span>含稅總計</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
<div class="foot">@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<div><strong>匯款</strong> @Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</div>}@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<div><strong>條件</strong> @Model.Settings.PaymentTerms</div>}@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<div>@Model.Settings.FooterNote</div>}</div>
</div></body></html>
