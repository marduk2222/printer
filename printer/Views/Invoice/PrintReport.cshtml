@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1e40af";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#f3f4f6;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:24px 32px;border:1px solid var(--p)}
.report-bar{background:var(--p);color:#fff;padding:12px 18px;margin:-24px -32px 18px;display:flex;justify-content:space-between;align-items:center;font-size:11px;letter-spacing:2px}
.report-bar .title{font-size:15px;font-weight:700;letter-spacing:4px}
.head{display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:12px;border-bottom:1px solid var(--p);margin-bottom:18px}
.head .name{color:var(--p);font-size:20px;font-weight:600}.head .meta{font-size:11px;color:#6b7280;line-height:1.7;margin-top:4px}
.head .doc{text-align:right;font-size:12px}.head .doc strong{color:var(--p);font-size:15px}
.info-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid #d1d5db;margin-bottom:18px}
.info-grid div{padding:10px 12px;border-right:1px solid #d1d5db;font-size:12px}.info-grid div:last-child{border-right:none}
.info-grid .lbl{color:#6b7280;font-size:10px;letter-spacing:2px;margin-bottom:4px}
table{width:100%;border-collapse:collapse;margin-bottom:16px}th{padding:8px 10px;background:#eff6ff;color:var(--p);border:1px solid #d1d5db;font-size:11px;text-align:center}
td{padding:8px 10px;border:1px solid #e5e7eb;font-size:11px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals-table{width:100%;border-collapse:collapse;margin-bottom:14px;border:1px solid var(--p)}
.totals-table td{padding:8px 14px;border-right:1px solid var(--p);font-size:13px}
.totals-table td.lbl{background:#eff6ff;color:var(--p);font-weight:600;width:18%}
.totals-table tr:last-child td{background:var(--p);color:#fff;font-weight:700;font-size:14px}
.foot{padding-top:10px;border-top:1px dashed #d1d5db;font-size:11px;color:#6b7280;display:flex;gap:24px}
.foot strong{color:var(--p)}
@@media print{body{background:#fff}.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:10mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="report-bar"><span>REPORT_ID: @Model.Invoice.InvoiceNumber</span><span class="title">帳單明細報表</span><span>GENERATED @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</span></div>
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　@Model.Settings.CompanyPhone</span>}</div></div><div class="doc">編號 <strong>@Model.Invoice.InvoiceNumber</strong><br/>開立 @Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
<div class="info-grid">
    <div><div class="lbl">客戶</div><strong>@buyerName</strong></div>
    <div><div class="lbl">統編</div>@(buyerTaxId ?? "—")</div>
    <div><div class="lbl">期間起</div>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd")</div>
    <div><div class="lbl">期間迄</div>@Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</div>
</div>
<table><thead><tr><th>序</th><th style="width:30%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@{int i=1;}@foreach(var it in Model.Invoice.Items){<tr><td>@i</td><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>i++;}</tbody></table>
<table class="totals-table">
    <tr><td class="lbl">未稅小計</td><td style="text-align:right;">$@Model.Invoice.TotalAmount.ToString("N0")</td><td class="lbl">營業稅 (5%)</td><td style="text-align:right;border-right:none;">$@Model.Invoice.TaxAmount.ToString("N0")</td></tr>
    <tr><td colspan="3">含稅總計 / TOTAL DUE</td><td style="text-align:right;border-right:none;">$@Model.Invoice.GrandTotal.ToString("N0")</td></tr>
</table>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<text><strong>匯款</strong>：@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</text>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<text><strong>備註</strong>：@Model.Settings.FooterNote</text>}</div></div>
</div></body></html>
