@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#b45309";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Serif TC",serif;color:#1f2937;background:#fafaf9;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #d6d3d1}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:14px;border:4px double var(--p)}
.inner{border:1px solid var(--p);padding:24px 28px}
.head{text-align:center;padding-bottom:14px;border-bottom:2px solid var(--p);margin-bottom:18px}
.head .name{font-size:24px;font-weight:600;color:var(--p);letter-spacing:3px}.head .meta{font-size:11px;color:#78624a;margin-top:6px;font-family:"Noto Sans TC",sans-serif}
.title{text-align:center;font-size:22px;color:var(--p);letter-spacing:14px;margin:14px 0;padding:6px 0;border-top:1px solid var(--p);border-bottom:1px solid var(--p)}
.info{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:14px 18px;border:1px solid var(--p);margin-bottom:18px;font-family:"Noto Sans TC",sans-serif}
.info h6{color:var(--p);font-size:11px;letter-spacing:3px;margin-bottom:6px}.info p{font-size:12px;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:14px;border:2px solid var(--p);font-family:"Noto Sans TC",sans-serif}
th{padding:8px 10px;background:var(--p);color:#fff;font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:8px 10px;border-bottom:1px solid #d6d3d1;font-size:12px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:14px}.totals-card{width:300px;border:2px solid var(--p)}.totals-row{display:flex;justify-content:space-between;padding:8px 14px;font-family:"Noto Sans TC",sans-serif;font-size:13px;border-bottom:1px solid #d6d3d1}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 14px;font-size:15px;border:none}
.foot{padding-top:12px;border-top:2px double var(--p);font-family:"Noto Sans TC",sans-serif;font-size:11px;color:#78624a;display:grid;grid-template-columns:1fr 1fr;gap:18px}.foot h6{color:var(--p);margin-bottom:4px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:10mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page"><div class="inner">
<div class="head"><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　電話 @Model.Settings.CompanyPhone</span>}</div></div>
<div class="title">◆ 帳　單 ◆</div>
<div class="info"><div><h6>客 戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>帳 單</h6><p>編號：@Model.Invoice.InvoiceNumber</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></div></body></html>
