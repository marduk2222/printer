@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#166534";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; --soft: #f0fdf4; --line: #bbf7d0; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Noto Serif TC", "Microsoft JhengHei", serif; color: #14532d; background: var(--soft); font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: #fff; border-bottom: 1px solid var(--line); }
.no-print button { padding: 8px 22px; border: 1px solid var(--p); background: #fff; color: var(--p); cursor: pointer; font-size: 14px; border-radius: 4px; }
.btn-print { background: var(--p) !important; color: #fff !important; }
.page { max-width: 820px; margin: 24px auto; background: #fff; padding: 36px 40px; border: 1px solid var(--line); border-radius: 4px; position: relative; }
.leaf { position: absolute; top: -12px; left: 32px; background: var(--p); color: #fff; padding: 6px 18px; border-radius: 0 0 16px 16px; font-size: 11px; letter-spacing: 4px; }
.head { padding-top: 18px; padding-bottom: 18px; border-bottom: 2px solid var(--p); margin-bottom: 22px; display: flex; justify-content: space-between; align-items: flex-end; }
.brand .name { font-size: 26px; font-weight: 600; color: var(--p); }
.brand .meta { font-size: 11px; color: #15803d; line-height: 1.7; margin-top: 6px; }
.doc { text-align: right; }
.doc .lbl { font-size: 13px; letter-spacing: 8px; color: var(--p); }
.doc .num { font-size: 14px; color: #166534; margin-top: 4px; }
.bill-row { display: grid; grid-template-columns: 1.5fr 1fr; gap: 24px; padding: 16px 18px; background: var(--soft); border-radius: 6px; margin-bottom: 22px; border-left: 4px solid var(--p); }
.bill-row h6 { font-size: 11px; color: var(--p); letter-spacing: 3px; margin-bottom: 6px; }
.bill-row p { font-family: "Noto Sans TC", sans-serif; font-size: 12px; color: #15803d; margin: 2px 0; }
table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-family: "Noto Sans TC", sans-serif; }
thead tr { background: var(--p); color: #fff; }
th { padding: 10px 12px; font-size: 12px; text-align: center; }
th:first-child { text-align: left; }
td { padding: 10px 12px; border-bottom: 1px dotted var(--line); font-size: 12px; text-align: center; color: #14532d; }
td.left { text-align: left; }
td.right { text-align: right; }
tbody tr:nth-child(even) { background: var(--soft); }
.totals { display: flex; justify-content: flex-end; margin-bottom: 22px; }
.totals-card { width: 300px; background: var(--soft); border: 1px solid var(--p); border-radius: 6px; padding: 6px 0; }
.totals-row { display: flex; justify-content: space-between; padding: 8px 16px; font-family: "Noto Sans TC", sans-serif; font-size: 13px; }
.totals-row.grand { background: var(--p); color: #fff; font-weight: 600; font-size: 15px; border-radius: 0 0 5px 5px; padding: 12px 16px; }
.foot { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding-top: 16px; border-top: 2px dotted var(--line); font-family: "Noto Sans TC", sans-serif; }
.foot h6 { font-size: 11px; color: var(--p); letter-spacing: 2px; margin-bottom: 4px; }
.foot p { font-size: 11px; color: #15803d; line-height: 1.7; }
@@media print { body { background: #fff; } .no-print { display: none !important; } .page { border: 1px solid var(--p); margin: 0; max-width: none; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
    <div class="leaf">🌿 NATURE</div>
    <div class="head">
        <div class="brand">
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyLogoUrl)) { <img src="@Model.Settings.CompanyLogoUrl" alt="Logo" style="max-height:42px;margin-bottom:6px;" /> }
            <div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
            <div class="meta">
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>@Model.Settings.CompanyAddress</div> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>電話 @Model.Settings.CompanyPhone　</span> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>@Model.Settings.CompanyEmail</span> }
            </div>
        </div>
        <div class="doc">
            <div class="lbl">帳　單</div>
            <div class="num">@Model.Invoice.InvoiceNumber</div>
            <div class="num" style="font-size:11px;color:#15803d;">@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div>
        </div>
    </div>
    <div class="bill-row">
        <div>
            <h6>致 客 戶</h6>
            <p><strong>@buyerName</strong></p>
            @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統編：@buyerTaxId</p> }
            @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
            @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
        </div>
        <div>
            <h6>計 費 期 間</h6>
            <p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~</p>
            <p>@Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
            @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>付款條件：@Model.Settings.PaymentTerms</p> }
        </div>
    </div>
    <table>
        <thead><tr><th style="width:36%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
        <tbody>
            @foreach (var it in Model.Invoice.Items) {
                <tr><td class="left">🌱 @it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
            }
        </tbody>
    </table>
    <div class="totals"><div class="totals-card">
        <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    <div class="foot">
        <div>
            @if (!string.IsNullOrEmpty(Model.Settings.BankName)) {
                <h6>🌿 匯款資訊</h6>
                <p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</p>
                @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> }
            }
        </div>
        <div>
            @if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>🍀 備註</h6><p>@Model.Settings.FooterNote</p> }
        </div>
    </div>
</div></body></html>
