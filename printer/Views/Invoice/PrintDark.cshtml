@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#38bdf8";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary;--bg:#0f172a;--panel:#1e293b;--line:#334155;--txt:#e2e8f0;--muted:#94a3b8}
*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:var(--txt);background:var(--bg);font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:var(--panel);border-bottom:1px solid var(--line)}.no-print button{padding:8px 22px;border:1px solid var(--p);background:transparent;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:var(--bg) !important}
.page{max-width:820px;margin:24px auto;background:var(--panel);padding:32px 36px;border-radius:8px;border:1px solid var(--line)}
.head{padding-bottom:18px;border-bottom:1px solid var(--line);margin-bottom:22px;display:flex;justify-content:space-between;align-items:flex-end}
.head .name{color:var(--p);font-size:24px;font-weight:600}.head .meta{color:var(--muted);font-size:11px;line-height:1.7;margin-top:6px}
.doc{text-align:right}.doc .lbl{color:var(--muted);font-size:11px;letter-spacing:3px}.doc .num{color:var(--p);font-size:18px;font-weight:700;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:14px 18px;background:var(--bg);border-radius:6px;margin-bottom:22px;border:1px solid var(--line)}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;color:var(--txt);margin:2px 0}.info p .k{color:var(--muted);display:inline-block;min-width:60px}
table{width:100%;border-collapse:collapse;margin-bottom:18px}th{padding:10px 12px;background:var(--bg);color:var(--p);border-bottom:1px solid var(--p);font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid var(--line);font-size:12px;text-align:center;color:var(--txt)}td.left{text-align:left}td.right{text-align:right;color:var(--p)}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;background:var(--bg);border-radius:6px;border:1px solid var(--line)}.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;color:var(--muted);border-bottom:1px solid var(--line)}.totals-row .v{color:var(--p)}.totals-row.grand{background:var(--p);color:var(--bg);font-weight:700;padding:12px 16px;font-size:15px;border:none;border-radius:0 0 5px 5px}.totals-row.grand .v{color:var(--bg)}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:1px dashed var(--line);font-size:11px;color:var(--muted)}.foot h6{color:var(--p);margin-bottom:4px}
@@media print{body{background:var(--bg) !important;-webkit-print-color-adjust:exact;print-color-adjust:exact}.no-print{display:none !important}.page{margin:0;max-width:none}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　@Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="info"><div><h6>客戶</h6><p><span class="k">名稱：</span><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p><span class="k">統編：</span>@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p><span class="k">地址：</span>@partner.Address</p>}</div><div><h6>期間</h6><p><span class="k">起：</span>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd")</p><p><span class="k">迄：</span>@Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p><p><span class="k">開立：</span>@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>TOTAL</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></body></html>
