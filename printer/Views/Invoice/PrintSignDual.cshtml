@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#0e7490";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#155e75;background:#f0f9ff;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #67e8f9}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:32px 36px;border-radius:8px;border:1px solid var(--p);box-shadow:0 4px 16px rgba(14,116,144,0.1)}
.split-head{display:grid;grid-template-columns:1fr 1fr;gap:0;border-radius:6px;overflow:hidden;margin-bottom:18px}
.split-head .panel{padding:18px 22px;color:#fff}
.split-head .left{background:var(--p)}
.split-head .right{background:#0c5b71;text-align:right}
.split-head h6{font-size:11px;letter-spacing:3px;opacity:.85;margin-bottom:6px}
.split-head .name{font-size:18px;font-weight:600}
.split-head p{font-size:11px;opacity:.9;margin:2px 0;line-height:1.5}
.split-head .num{font-size:22px;font-weight:700;margin-top:2px}
.title{text-align:center;font-size:22px;color:var(--p);letter-spacing:14px;margin:14px 0;padding:6px 0;border-top:1px solid var(--p);border-bottom:1px solid var(--p)}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:#ecfeff;color:var(--p);border-bottom:2px solid var(--p);font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #ecfeff;font-size:12px;text-align:center;color:#155e75}td.left{text-align:left}td.right{text-align:right}
.totals-row{display:flex;justify-content:flex-end;gap:14px;padding:5px 6px;font-size:13px}.totals-row .v{min-width:120px;text-align:right}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;margin-top:6px}
.dual-area{margin-top:24px;display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--p);border-radius:6px;overflow:hidden}
.dual-area .col{padding:18px 22px}
.dual-area .col.l{background:#ecfeff;border-right:1px solid var(--p)}
.dual-area .col.r{background:#fff}
.dual-area h6{font-size:12px;color:var(--p);font-weight:700;letter-spacing:3px;margin-bottom:14px;padding-bottom:6px;border-bottom:2px solid var(--p);text-align:center}
.dual-area .meta{font-size:11px;color:#0e7490;margin-bottom:10px}
.dual-area .meta .k{color:#155e75;font-weight:600;margin-right:6px}
.dual-area .area{height:80px;background:rgba(255,255,255,0.5);border:1px dashed var(--p);display:flex;align-items:center;justify-content:center;color:#67e8f9;font-size:11px;border-radius:4px}
.dual-area .col.r .area{background:#ecfeff}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="split-head">
    <div class="panel left">
        <h6>BILL FROM 開單方</h6>
        <div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
        @if(!string.IsNullOrEmpty(Model.Settings.CompanyAddress)){<p>@Model.Settings.CompanyAddress</p>}
        @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<p>電話：@Model.Settings.CompanyPhone</p>}
    </div>
    <div class="panel right">
        <h6>BILL TO 客戶</h6>
        <div class="name">@buyerName</div>
        @if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}
        @if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}
    </div>
</div>
<div class="title">帳　單</div>
<div style="font-family:'Noto Sans TC',sans-serif;font-size:12px;text-align:center;color:#0e7490;margin-bottom:16px;">編號 @Model.Invoice.InvoiceNumber　·　開立 @Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")　·　期間 @Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals-row"><span>未稅小計</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
<div class="totals-row"><span>營業稅 (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
<div class="totals-row grand"><span>含稅總計</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
<div class="dual-area">
    <div class="col l">
        <h6>客　戶　確　認　簽　名</h6>
        <div class="meta"><span class="k">姓名：</span>@buyerName</div>
        <div class="meta"><span class="k">日期：</span>　　　/　　/　　</div>
        <div class="area">客戶簽章區</div>
    </div>
    <div class="col r">
        <h6>承　辦　人　員　簽　名</h6>
        <div class="meta"><span class="k">單位：</span>@(Model.Settings.CompanyName ?? "")</div>
        <div class="meta"><span class="k">日期：</span>@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div>
        <div class="area">承辦人簽章區</div>
    </div>
</div>
</div></body></html>
