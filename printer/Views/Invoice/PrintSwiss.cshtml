@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#dc2626";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Helvetica","Arial","Noto Sans TC",sans-serif;color:#000;background:#fff;font-size:13px;line-height:1.4}
.no-print{display:flex;gap:8px;padding:12px;background:#f5f5f5;border-bottom:1px solid #e5e5e5}.no-print button{padding:8px 22px;border:1px solid #000;background:#fff;color:#000;cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important;border-color:var(--p) !important}
.page{max-width:780px;margin:30px auto;padding:36px 40px}
.swiss-grid{display:grid;grid-template-columns:2fr 1fr 1fr;gap:18px;border-bottom:2px solid #000;padding-bottom:14px;margin-bottom:18px}
.swiss-grid .name{font-size:24px;font-weight:700;color:#000;letter-spacing:-1px}
.swiss-grid .meta{font-size:11px;color:#525252;margin-top:4px}
.swiss-grid h6{font-size:9px;letter-spacing:3px;color:var(--p);text-transform:uppercase;margin-bottom:4px}
.swiss-grid p{font-size:12px;margin:1px 0}
.bar{height:3px;background:var(--p);margin-bottom:14px}
table{width:100%;border-collapse:collapse;margin-bottom:14px}
th{padding:10px 0;font-size:9px;letter-spacing:2px;color:var(--p);text-transform:uppercase;text-align:left;border-bottom:1px solid #000}
th.r{text-align:right}
td{padding:10px 8px;border-bottom:1px solid #d4d4d4;font-size:12px}
td.r{text-align:right}td.c{text-align:center;color:#525252;font-size:11px}
.totals{margin-left:auto;width:280px;padding-top:14px}
.totals-row{display:flex;justify-content:space-between;padding:6px 0;font-size:13px}
.totals-row.grand{border-top:3px solid var(--p);margin-top:6px;padding-top:14px;font-size:20px;font-weight:700;color:var(--p)}
.foot{margin-top:36px;padding-top:14px;border-top:1px solid #000;display:grid;grid-template-columns:1fr 1fr;gap:18px;font-size:11px;color:#525252}
.foot h6{font-size:9px;letter-spacing:3px;color:var(--p);text-transform:uppercase;margin-bottom:4px}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none}}@@page{size:A4;margin:14mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="swiss-grid">
    <div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<div>@Model.Settings.CompanyPhone</div>}</div></div>
    <div><h6>Bill To</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編 @buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div>
    <div><h6>Invoice</h6><p><strong>@Model.Invoice.InvoiceNumber</strong></p><p>開立 @Model.Invoice.CreatedAt.ToString("yyyy.MM.dd")</p><p>期間 @Model.Invoice.PeriodStart.ToString("yyyy.MM.dd") – @Model.Invoice.PeriodEnd.ToString("yyyy.MM.dd")</p></div>
</div>
<div class="bar"></div>
<table><thead><tr><th style="width:38%">項目</th><th class="r">黑白</th><th class="r">彩色</th><th class="r">大張</th><th class="r">月租</th><th class="r">張數費</th><th class="r">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td>@it.Description</td><td class="c">@it.BlackPages.ToString("N0")</td><td class="c">@it.ColorPages.ToString("N0")</td><td class="c">@it.LargePages.ToString("N0")</td><td class="r">@it.MonthlyFee.ToString("N0")</td><td class="r">@it.PageFee.ToString("N0")</td><td class="r">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>TOTAL</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>Payment</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch</p>@if(!string.IsNullOrEmpty(Model.Settings.BankAccount)){<p>@Model.Settings.BankAccount</p>}}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>Note</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></body></html>
