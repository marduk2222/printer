@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#7c3aed";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>帳單 - @Model.Invoice.InvoiceNumber</title>
    <style>
        :root { --p: @primary; }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: "Playfair Display", "Noto Serif TC", "Times New Roman", serif; color: #2d1b4e; background: linear-gradient(135deg,#faf5ff,#f5f3ff); font-size: 13px; }
        .no-print { display: flex; gap: 8px; padding: 12px; background: rgba(255,255,255,0.7); border-bottom: 1px solid #e9d5ff; }
        .no-print button { padding: 8px 22px; border: 1px solid var(--p); background: #fff; color: var(--p); cursor: pointer; font-size: 14px; border-radius: 24px; }
        .btn-print { background: var(--p) !important; color: #fff !important; }
        .page { max-width: 820px; margin: 30px auto; background: #fff; padding: 50px 56px; border-radius: 4px; box-shadow: 0 8px 32px rgba(124,58,237,0.15); position: relative; }
        .page::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 6px; background: linear-gradient(90deg,#a78bfa,var(--p),#a78bfa); border-radius: 4px 4px 0 0; }
        .header { text-align: center; padding-bottom: 24px; border-bottom: 1px solid #e9d5ff; margin-bottom: 28px; }
        .ornament { color: var(--p); font-size: 18px; letter-spacing: 8px; margin-bottom: 8px; }
        .company { font-size: 28px; font-weight: 400; color: var(--p); margin-bottom: 4px; letter-spacing: 2px; }
        .slogan { font-size: 12px; color: #6b21a8; font-style: italic; margin-bottom: 10px; }
        .meta { font-size: 11px; color: #6b21a8; line-height: 1.6; }
        .doc-title { text-align: center; font-size: 32px; color: var(--p); letter-spacing: 16px; margin: 24px 0 12px; font-weight: 400; }
        .doc-num { text-align: center; font-size: 13px; color: #6b21a8; margin-bottom: 28px; font-style: italic; }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 28px; padding: 18px 24px; background: linear-gradient(135deg,#faf5ff,#fff); border: 1px solid #e9d5ff; border-radius: 6px; }
        .info-block h6 { font-size: 11px; color: var(--p); letter-spacing: 4px; margin-bottom: 8px; font-weight: 600; }
        .info-block p { font-family: "Noto Sans TC", sans-serif; font-size: 12px; color: #4a3568; margin: 3px 0; line-height: 1.6; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 22px; font-family: "Noto Sans TC", sans-serif; }
        thead tr { background: linear-gradient(90deg,var(--p),#a78bfa); color: #fff; }
        th { padding: 12px 10px; font-size: 12px; font-weight: 500; letter-spacing: 1px; text-align: center; }
        th:first-child { text-align: left; padding-left: 18px; border-radius: 6px 0 0 0; }
        th:last-child { border-radius: 0 6px 0 0; }
        td { padding: 12px 10px; border-bottom: 1px solid #f3e8ff; font-size: 12px; text-align: center; color: #4a3568; }
        td.left { text-align: left; padding-left: 18px; }
        td.right { text-align: right; }
        tbody tr:nth-child(even) { background: #faf5ff; }
        .totals { display: flex; justify-content: flex-end; margin-bottom: 24px; }
        .totals-card { width: 320px; padding: 0; border: 2px solid var(--p); border-radius: 6px; overflow: hidden; }
        .totals-row { display: flex; justify-content: space-between; padding: 10px 18px; font-family: "Noto Sans TC", sans-serif; font-size: 13px; color: #4a3568; }
        .totals-row.grand { background: var(--p); color: #fff; font-size: 16px; font-weight: 600; }
        .footer { margin-top: 28px; padding-top: 20px; border-top: 1px solid #e9d5ff; text-align: center; }
        .footer .ornament { color: var(--p); font-size: 14px; letter-spacing: 6px; margin-bottom: 8px; }
        .footer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; text-align: left; font-family: "Noto Sans TC", sans-serif; }
        .footer-grid h6 { font-size: 11px; color: var(--p); letter-spacing: 3px; margin-bottom: 4px; }
        .footer-grid p { font-size: 11px; color: #6b21a8; line-height: 1.7; }
        @@media print { body { background: #fff; } .no-print { display: none !important; } .page { box-shadow: none; margin: 0; max-width: none; } }
        @@page { size: A4; margin: 12mm; }
    </style>
</head>
<body>
    <div class="no-print">
        <button class="btn-print" onclick="window.print()">列印</button>
        <button onclick="history.back()">返回</button>
    </div>
    <div class="page">
        <div class="header">
            <div class="ornament">❦ ❦ ❦</div>
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyLogoUrl))
            {
                <img src="@Model.Settings.CompanyLogoUrl" alt="Logo" style="max-height:50px;margin-bottom:8px;" />
            }
            <div class="company">@(Model.Settings.CompanyName ?? "公司名稱")</div>
            @if (!string.IsNullOrEmpty(Model.Settings.CompanySlogan)) { <div class="slogan">— @Model.Settings.CompanySlogan —</div> }
            <div class="meta">
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <span>@Model.Settings.CompanyAddress　</span> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>電話 @Model.Settings.CompanyPhone</span> }
            </div>
        </div>

        <div class="doc-title">帳　單</div>
        <div class="doc-num">No. @Model.Invoice.InvoiceNumber　·　@Model.Invoice.CreatedAt.ToString("yyyy / MM / dd")</div>

        <div class="info-grid">
            <div class="info-block">
                <h6>致 客 戶</h6>
                <p><strong>@buyerName</strong></p>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統一編號：@buyerTaxId</p> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
            </div>
            <div class="info-block">
                <h6>計 費 期 間</h6>
                <p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd")</p>
                <p>~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
                @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p style="margin-top:6px;">付款條件：@Model.Settings.PaymentTerms</p> }
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width:36%">項目</th>
                    <th>黑白</th><th>彩色</th><th>大張</th>
                    <th>月租</th><th>張數費</th>
                    <th style="text-align:right;padding-right:18px;">小計</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var it in Model.Invoice.Items)
                {
                    <tr>
                        <td class="left">@it.Description</td>
                        <td>@it.BlackPages.ToString("N0")</td>
                        <td>@it.ColorPages.ToString("N0")</td>
                        <td>@it.LargePages.ToString("N0")</td>
                        <td class="right">@it.MonthlyFee.ToString("N0")</td>
                        <td class="right">@it.PageFee.ToString("N0")</td>
                        <td class="right" style="padding-right:18px;">$@it.Subtotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="totals">
            <div class="totals-card">
                <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
                <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
                <div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
            </div>
        </div>

        <div class="footer">
            <div class="ornament">❦ ❦ ❦</div>
            <div class="footer-grid">
                <div>
                    @if (!string.IsNullOrEmpty(Model.Settings.BankName))
                    {
                        <h6>匯 款 資 訊</h6>
                        <p>@Model.Settings.BankName @Model.Settings.BankBranch</p>
                        @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> }
                    }
                </div>
                <div>
                    @if (!string.IsNullOrEmpty(Model.Settings.FooterNote))
                    {
                        <h6>備　　註</h6>
                        <p>@Model.Settings.FooterNote</p>
                    }
                </div>
            </div>
        </div>
    </div>
</body>
</html>
