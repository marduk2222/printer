@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#0f766e";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#f3f4f6;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff}
.bar{background:var(--p);color:#fff;padding:14px 28px;display:flex;justify-content:space-between;align-items:center}
.bar.alt{background:#f3f4f6;color:#1f2937;border-bottom:1px solid #d1d5db}
.bar .name{font-size:18px;font-weight:600}.bar .lbl{font-size:11px;letter-spacing:3px;opacity:.85}
.bar.alt .name{color:var(--p)}.bar.alt .lbl{color:#6b7280}
.section{padding:18px 28px;border-bottom:1px solid #e5e7eb}
.section h6{font-size:11px;color:var(--p);letter-spacing:2px;margin-bottom:8px}
.section p{font-size:12px;margin:2px 0;color:#4b5563}
.kv{display:grid;grid-template-columns:90px 1fr;gap:4px 12px;font-size:12px}
.kv .k{color:#6b7280;font-size:11px}
table{width:100%;border-collapse:collapse}th{padding:10px 12px;background:#f3f4f6;color:var(--p);border-bottom:2px solid var(--p);font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals-row{display:flex;justify-content:space-between;padding:8px 28px;font-size:13px;border-top:1px solid #e5e7eb}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;font-size:16px;padding:14px 28px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:0}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="bar"><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div><span class="lbl">INVOICE</span> <strong>@Model.Invoice.InvoiceNumber</strong></div></div>
<div class="bar alt"><div class="name">📋 帳單摘要</div><div><span class="lbl">DATE</span> @Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
<div class="section"><h6>★ 客戶資訊</h6><div class="kv"><div class="k">名稱</div><div><strong>@buyerName</strong></div>@if(!string.IsNullOrEmpty(buyerTaxId)){<div class="k">統編</div><div>@buyerTaxId</div>}@if(!string.IsNullOrEmpty(partner?.Address)){<div class="k">地址</div><div>@partner.Address</div>}@if(!string.IsNullOrEmpty(partner?.Phone)){<div class="k">電話</div><div>@partner.Phone</div>}</div></div>
<div class="section"><h6>★ 計費期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy 年 MM 月 dd 日") ~ @Model.Invoice.PeriodEnd.ToString("yyyy 年 MM 月 dd 日")@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<span>　·　付款條件：@Model.Settings.PaymentTerms</span>}</p></div>
<div class="section" style="padding:0">
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
</div>
<div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
<div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
<div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
@if(!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.FooterNote)){<div class="section"><h6>★ 匯款 / 備註</h6>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch　·　帳號：@Model.Settings.BankAccount</p>}@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<p>@Model.Settings.FooterNote</p>}</div>}
</div></body></html>
