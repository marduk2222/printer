@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1e3a5f";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Serif TC",serif;color:#1f2937;background:#fafaf9;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #d6d3d1}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:32px 40px;border:1px solid var(--p)}
.head{padding-bottom:14px;border-bottom:2px solid var(--p);margin-bottom:18px;display:flex;justify-content:space-between;align-items:flex-end}
.head .name{font-size:24px;color:var(--p);font-weight:600;letter-spacing:2px}.head .meta{font-size:11px;color:#525252;margin-top:6px;font-family:"Noto Sans TC",sans-serif;line-height:1.7}
.doc{text-align:right;font-family:"Noto Sans TC",sans-serif}.doc .lbl{font-size:11px;color:var(--p);letter-spacing:3px}.doc .num{font-size:18px;font-weight:600;margin-top:2px}
.title{text-align:center;font-size:24px;color:var(--p);letter-spacing:14px;margin:14px 0}
.info{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:14px 18px;background:#f3f4f6;margin-bottom:18px;border-left:4px solid var(--p);font-family:"Noto Sans TC",sans-serif}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:14px;border:1px solid var(--p);font-family:"Noto Sans TC",sans-serif}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;border:1px solid var(--p)}.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-family:"Noto Sans TC",sans-serif;font-size:13px;border-bottom:1px solid #e5e7eb}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border:none}
.sign-area{display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-top:32px;padding-top:24px;border-top:2px double var(--p);font-family:"Noto Sans TC",sans-serif}
.sign-box{padding:8px 14px}
.sign-box h6{font-size:11px;color:var(--p);letter-spacing:3px;margin-bottom:30px}
.sign-line{border-bottom:1px solid #1f2937;height:50px;display:flex;align-items:flex-end;justify-content:flex-end;padding:0 6px;font-size:10px;color:#9ca3af}
.sign-meta{margin-top:6px;font-size:11px;color:#6b7280;display:flex;justify-content:space-between}
.foot{margin-top:18px;padding-top:12px;border-top:1px dashed #d6d3d1;font-family:"Noto Sans TC",sans-serif;font-size:11px;color:#6b7280}
.foot strong{color:var(--p)}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none}}@@page{size:A4;margin:14mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　電話 @Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="title">帳　單</div>
<div class="info"><div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}@if(!string.IsNullOrEmpty(partner?.Phone)){<p>電話：@partner.Phone</p>}</div><div><h6>帳單</h6><p>編號：@Model.Invoice.InvoiceNumber</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="sign-area">
    <div class="sign-box">
        <h6>客　戶　簽　名</h6>
        <div class="sign-line">客戶確認簽章</div>
        <div class="sign-meta"><span>姓名：@buyerName</span><span>日期：　　/　　/　　</span></div>
    </div>
    <div class="sign-box">
        <h6>承　辦　人　員　簽　名</h6>
        <div class="sign-line">經辦人簽章</div>
        <div class="sign-meta"><span>單位：@(Model.Settings.CompanyName ?? "")</span><span>日期：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</span></div>
    </div>
</div>
@if(!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.FooterNote)){<div class="foot">@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<text><strong>匯款</strong>：@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount　</text>}@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<text>@Model.Settings.FooterNote</text>}</div>}
</div></body></html>
