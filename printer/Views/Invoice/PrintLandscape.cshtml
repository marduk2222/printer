@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#0369a1";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#f9fafb;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:1180px;margin:24px auto;background:#fff;padding:28px 36px;border-top:6px solid var(--p)}
.head{display:grid;grid-template-columns:2fr 1fr 1fr;gap:24px;align-items:end;padding-bottom:14px;border-bottom:2px solid var(--p);margin-bottom:18px}
.head .name{font-size:22px;color:var(--p);font-weight:600}.head .meta{font-size:11px;color:#6b7280;line-height:1.7;margin-top:4px}
.head h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:4px}
.head p{font-size:12px;margin:1px 0}
table{width:100%;border-collapse:collapse;margin-bottom:14px}th{padding:8px 10px;background:var(--p);color:#fff;font-size:11px;text-align:center}th:first-child{text-align:left}
td{padding:8px 10px;border-bottom:1px solid #e5e7eb;font-size:11px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.bottom{display:grid;grid-template-columns:1fr 320px;gap:24px;padding-top:12px}
.bottom-left{font-size:11px;color:#6b7280;line-height:1.7}.bottom-left h6{color:var(--p);font-size:11px;margin-bottom:4px;letter-spacing:2px}
.totals-card{border:1px solid var(--p)}.totals-row{display:flex;justify-content:space-between;padding:6px 14px;font-size:12px;border-bottom:1px solid #e5e7eb}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:10px 14px;font-size:14px;border:none}
@@media print{body{background:#fff}.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4 landscape;margin:10mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印 (橫式)</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head">
    <div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　@Model.Settings.CompanyPhone</span>}@if(!string.IsNullOrEmpty(Model.Settings.CompanyEmail)){<span>　·　@Model.Settings.CompanyEmail</span>}</div></div>
    <div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div>
    <div><h6>帳單</h6><p>編號：@Model.Invoice.InvoiceNumber</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("MM/dd")</p></div>
</div>
<table><thead><tr><th style="width:30%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="bottom">
    <div class="bottom-left">
        @if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款資訊</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / 帳號 @Model.Settings.BankAccount</p>}
        @if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<p>付款條件：@Model.Settings.PaymentTerms</p>}
        @if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<p>@Model.Settings.FooterNote</p>}
    </div>
    <div class="totals-card">
        <div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div>
</div>
</div></body></html>
