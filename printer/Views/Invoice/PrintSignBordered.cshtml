@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#0f766e";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#134e4a;background:#fafaf9;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #5eead4}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:14px;border:4px double var(--p)}
.inner{border:1px solid var(--p);padding:24px 32px}
.head{padding-bottom:14px;border-bottom:2px solid var(--p);margin-bottom:18px;display:flex;justify-content:space-between;align-items:flex-end}
.head .name{color:var(--p);font-size:24px;font-weight:600}.head .meta{color:#0f766e;font-size:11px;line-height:1.7;margin-top:6px}
.head .doc{text-align:right}.head .doc .lbl{color:var(--p);font-size:13px;letter-spacing:8px}.head .doc .num{color:#134e4a;font-size:18px;font-weight:600;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:14px 18px;border:1px solid var(--p);background:#f0fdfa;margin-bottom:18px}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;margin:2px 0;color:#0f766e}
table{width:100%;border-collapse:collapse;margin-bottom:18px;border:2px solid var(--p)}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #ccfbf1;font-size:12px;text-align:center;color:#134e4a}td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;border:2px solid var(--p);background:#f0fdfa}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;border-bottom:1px solid #ccfbf1}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border:none}
.sig-area{margin-top:24px;border:2px double var(--p);padding:18px 22px;background:#f0fdfa;display:grid;grid-template-columns:1fr 1fr;gap:24px}
.sig-area .col{padding:0 8px}
.sig-area h6{font-size:12px;color:var(--p);font-weight:600;letter-spacing:3px;margin-bottom:14px;padding-bottom:6px;border-bottom:1px solid var(--p);text-align:center}
.sig-area .field{display:grid;grid-template-columns:60px 1fr;gap:8px;align-items:center;margin-bottom:8px;font-size:11px}
.sig-area .field .lbl{color:#0f766e}
.sig-area .field .v{border-bottom:1px solid #134e4a;height:26px;padding:0 4px;font-weight:500}
.sig-area .stamp{margin-top:14px;height:60px;border:2px dashed var(--p);display:flex;align-items:center;justify-content:center;color:#5eead4;font-size:11px}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page"><div class="inner">
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　@Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">帳　單</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="info"><div><h6>客戶資訊</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>帳單資訊</h6><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="sig-area">
    <div class="col">
        <h6>客　戶　簽　名</h6>
        <div class="field"><div class="lbl">姓名</div><div class="v">@buyerName</div></div>
        <div class="field"><div class="lbl">統編</div><div class="v">@(buyerTaxId ?? "")</div></div>
        <div class="field"><div class="lbl">日期</div><div class="v">　　　/　　/　　</div></div>
        <div class="stamp">客戶簽章 / 公司大小章</div>
    </div>
    <div class="col">
        <h6>承　辦　人　員　簽　名</h6>
        <div class="field"><div class="lbl">單位</div><div class="v">@(Model.Settings.CompanyName ?? "")</div></div>
        <div class="field"><div class="lbl">承辦</div><div class="v"></div></div>
        <div class="field"><div class="lbl">日期</div><div class="v">@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
        <div class="stamp">承辦人簽章 / 公司印鑑</div>
    </div>
</div>
</div></div></body></html>
