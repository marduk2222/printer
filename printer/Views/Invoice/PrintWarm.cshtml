@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#ea580c";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; --soft: #fff7ed; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif; color: #44403c; background: var(--soft); font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: rgba(255,255,255,0.7); border-bottom: 1px solid #fed7aa; }
.no-print button { padding: 8px 22px; border: none; background: #fff; color: var(--p); cursor: pointer; font-size: 14px; border-radius: 24px; box-shadow: 0 2px 4px rgba(234,88,12,0.15); }
.btn-print { background: var(--p) !important; color: #fff !important; }
.page { max-width: 820px; margin: 24px auto; background: #fff; padding: 36px 40px; border-radius: 16px; box-shadow: 0 8px 32px rgba(234,88,12,0.12); }
.greet { background: linear-gradient(135deg,var(--p),#fb923c); color: #fff; padding: 18px 24px; border-radius: 12px; margin-bottom: 24px; display: flex; justify-content: space-between; align-items: center; }
.greet .text { font-size: 14px; }
.greet .text .h { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.greet .num { background: rgba(255,255,255,0.25); padding: 8px 14px; border-radius: 20px; font-size: 13px; }
.who { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 22px; }
.who .card { background: var(--soft); border-radius: 12px; padding: 16px 18px; border-left: 4px solid var(--p); }
.who h6 { font-size: 11px; color: var(--p); font-weight: 700; letter-spacing: 2px; margin-bottom: 6px; }
.who p { font-size: 12px; margin: 2px 0; color: #57534e; }
table { width: 100%; border-collapse: separate; border-spacing: 0; margin-bottom: 18px; }
th { padding: 12px 14px; background: var(--p); color: #fff; font-size: 12px; text-align: center; font-weight: 600; }
th:first-child { border-radius: 8px 0 0 0; text-align: left; }
th:last-child { border-radius: 0 8px 0 0; }
td { padding: 11px 14px; border-bottom: 1px solid #fef3c7; font-size: 12px; text-align: center; }
td.left { text-align: left; } td.right { text-align: right; }
tbody tr:hover { background: var(--soft); }
.totals { display: flex; justify-content: flex-end; margin-bottom: 20px; }
.totals-card { width: 300px; background: var(--soft); border-radius: 12px; padding: 6px 0; border: 2px dashed var(--p); }
.totals-row { display: flex; justify-content: space-between; padding: 10px 18px; font-size: 13px; }
.totals-row.grand { background: var(--p); color: #fff; border-radius: 10px; margin: 4px 8px; padding: 12px 16px; font-weight: 700; font-size: 15px; }
.foot { margin-top: 18px; padding: 16px 20px; background: linear-gradient(135deg,#fff7ed,#ffedd5); border-radius: 12px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; font-size: 12px; }
.foot h6 { font-size: 11px; color: var(--p); font-weight: 700; letter-spacing: 1px; margin-bottom: 4px; }
.foot p { color: #57534e; line-height: 1.7; }
@@media print { body { background: #fff; } .no-print { display: none !important; } .page { box-shadow: none; margin: 0; max-width: none; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
    <div class="greet">
        <div class="text">
            <div class="h">您好，@buyerName ☀️</div>
            <div>感謝您的支持！這是 @Model.Invoice.PeriodStart.ToString("M") 月的帳單明細。</div>
        </div>
        <div class="num">📋 @Model.Invoice.InvoiceNumber</div>
    </div>
    <div class="who">
        <div class="card">
            <h6>📍 服務提供者</h6>
            <p><strong>@(Model.Settings.CompanyName ?? "公司名稱")</strong></p>
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <p>@Model.Settings.CompanyAddress</p> }
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <p>📞 @Model.Settings.CompanyPhone</p> }
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <p>✉️ @Model.Settings.CompanyEmail</p> }
        </div>
        <div class="card">
            <h6>📅 帳單資訊</h6>
            <p>開立日期：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p>
            <p>計費期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
            @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統一編號：@buyerTaxId</p> }
            @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>付款條件：@Model.Settings.PaymentTerms</p> }
        </div>
    </div>
    <table>
        <thead><tr><th style="width:36%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
        <tbody>
            @foreach (var it in Model.Invoice.Items) {
                <tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
            }
        </tbody>
    </table>
    <div class="totals"><div class="totals-card">
        <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>應付總額</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    @if (!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.FooterNote)) {
        <div class="foot">
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.BankName)) {
                    <h6>💰 匯款資訊</h6>
                    <p>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</p>
                    @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>帳號：@Model.Settings.BankAccount</p> }
                }
            </div>
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>📝 備註</h6><p>@Model.Settings.FooterNote</p> }
            </div>
        </div>
    }
</div></body></html>
