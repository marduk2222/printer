@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#2980b9";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root{--p:@primary;--soft:#eff6ff}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Noto Sans TC","Microsoft JhengHei",sans-serif;color:#1e3a5f;background:linear-gradient(180deg,#dbeafe,#fff);font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #93c5fd}
.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px;border-radius:4px}
.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:36px 40px;border-top:6px solid var(--p);border-bottom:6px solid var(--p);box-shadow:0 4px 16px rgba(41,128,185,0.1)}
.head{display:flex;justify-content:space-between;align-items:flex-start;padding-bottom:18px;border-bottom:2px solid var(--p);margin-bottom:22px}
.head .name{font-size:24px;font-weight:600;color:var(--p)}
.head .meta{font-size:11px;color:#1e40af;line-height:1.7;margin-top:6px}
.head .doc{text-align:right}
.head .doc .lbl{font-size:13px;color:var(--p);letter-spacing:8px}
.head .doc .num{font-size:16px;color:#1e3a5f;margin-top:4px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:22px;padding:14px 18px;background:var(--soft);border-radius:4px}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}
.info p{font-size:12px;color:#1e3a5f;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:18px;border:1px solid var(--p)}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}
th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid var(--soft);font-size:12px;text-align:center;color:#1e3a5f}
td.left{text-align:left} td.right{text-align:right;font-weight:500}
.totals{display:flex;justify-content:flex-end;margin-bottom:20px}
.totals-card{width:300px}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;border-bottom:1px dotted #93c5fd}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border:none}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:1px dashed #93c5fd;font-size:11px;color:#1e40af}
.foot h6{color:var(--p);margin-bottom:4px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}
@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
    <div class="head">
        <div><div class="name">⛵ @(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　電話 @Model.Settings.CompanyPhone</span>}</div></div>
        <div class="doc"><div class="lbl">帳　單</div><div class="num">@Model.Invoice.InvoiceNumber</div><div class="num" style="font-size:11px;">@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
    </div>
    <div class="info">
        <div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}@if(!string.IsNullOrEmpty(partner?.Phone)){<p>電話：@partner.Phone</p>}</div>
        <div><h6>計費期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<p>付款條件：@Model.Settings.PaymentTerms</p>}</div>
    </div>
    <table>
        <thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th>小計</th></tr></thead>
        <tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody>
    </table>
    <div class="totals"><div class="totals-card">
        <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    <div class="foot">
        <div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款資訊</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div>
        <div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div>
    </div>
</div></body></html>
