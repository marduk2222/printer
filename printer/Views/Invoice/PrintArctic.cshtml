@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#0284c7";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root{--p:@primary;--ice:#e0f2fe;--frost:#f0f9ff}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Noto Sans TC",sans-serif;color:#0c4a6e;background:linear-gradient(180deg,#f0f9ff,#e0f2fe);font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #bae6fd}
.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px;border-radius:24px}
.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:36px 40px;border-radius:16px;box-shadow:0 8px 24px rgba(2,132,199,0.1);border:1px solid #bae6fd}
.head{display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:16px;border-bottom:2px solid var(--p);margin-bottom:22px}
.head .name{color:var(--p);font-size:24px;font-weight:600}
.head .meta{color:#0369a1;font-size:11px;line-height:1.7;margin-top:6px}
.head .doc{text-align:right}
.head .doc .lbl{font-size:14px;color:var(--p);letter-spacing:8px}
.head .doc .num{font-size:16px;color:#0c4a6e;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:16px 18px;background:linear-gradient(135deg,var(--frost),var(--ice));border-radius:12px;margin-bottom:22px}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}
.info p{font-size:12px;color:#0c4a6e;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:linear-gradient(180deg,#7dd3fc,var(--p));color:#fff;font-size:12px;text-align:center}
th:first-child{text-align:left;border-radius:10px 0 0 0}
th:last-child{border-radius:0 10px 0 0;text-align:right}
td{padding:10px 12px;border-bottom:1px solid var(--ice);font-size:12px;text-align:center;color:#0c4a6e}
td.left{text-align:left} td.right{text-align:right}
tbody tr:nth-child(even){background:var(--frost)}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}
.totals-card{width:300px;background:var(--frost);border-radius:12px;padding:6px 0;border:1px solid #bae6fd}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;color:#0369a1}
.totals-row.grand{background:linear-gradient(135deg,var(--p),#0369a1);color:#fff;border-radius:0 0 11px 11px;padding:12px 16px;font-weight:700;font-size:15px}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:1px dashed #7dd3fc;font-size:11px;color:#0369a1}
.foot h6{color:var(--p);margin-bottom:4px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}
@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
    <div class="head"><div><div class="name">❄ @(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　電話 @Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">帳　單</div><div class="num">@Model.Invoice.InvoiceNumber</div><div class="num" style="font-size:11px;">@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div></div>
    <div class="info">
        <div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div>
        <div><h6>計費期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<p>付款條件：@Model.Settings.PaymentTerms</p>}</div>
    </div>
    <table>
        <thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th>小計</th></tr></thead>
        <tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody>
    </table>
    <div class="totals"><div class="totals-card">
        <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    <div class="foot">
        <div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款資訊</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div>
        <div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div>
    </div>
</div></body></html>
