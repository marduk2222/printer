@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#38bdf8";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>INVOICE - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; --bg: #0f172a; --panel: #1e293b; --line: #334155; --muted: #94a3b8; --txt: #e2e8f0; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "JetBrains Mono", "Consolas", "Noto Sans TC", monospace; color: var(--txt); background: var(--bg); font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: var(--panel); border-bottom: 1px solid var(--line); }
.no-print button { padding: 8px 22px; border: 1px solid var(--p); background: transparent; color: var(--p); cursor: pointer; font-size: 14px; font-family: inherit; }
.btn-print { background: var(--p) !important; color: #0f172a !important; }
.page { max-width: 820px; margin: 24px auto; background: var(--panel); padding: 32px 36px; border: 1px solid var(--line); border-radius: 4px; }
.head { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 18px; border-bottom: 1px solid var(--line); margin-bottom: 22px; }
.brand .logo { color: var(--p); font-size: 22px; font-weight: 700; letter-spacing: 1px; }
.brand .meta { color: var(--muted); font-size: 11px; line-height: 1.7; margin-top: 6px; }
.doc { text-align: right; }
.doc .lbl { color: var(--muted); font-size: 11px; }
.doc .num { color: var(--p); font-size: 20px; font-weight: 700; margin-top: 2px; }
.doc .badge { display: inline-block; margin-top: 6px; padding: 3px 10px; background: rgba(56,189,248,0.15); color: var(--p); border: 1px solid var(--p); border-radius: 2px; font-size: 10px; letter-spacing: 2px; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 22px; }
.grid .panel { background: rgba(15,23,42,0.5); border: 1px solid var(--line); border-radius: 4px; padding: 14px 16px; }
.grid h6 { color: var(--p); font-size: 10px; letter-spacing: 3px; margin-bottom: 8px; }
.grid p { font-size: 12px; color: var(--txt); margin: 2px 0; }
.grid p .k { color: var(--muted); display: inline-block; min-width: 70px; }
table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
thead { background: rgba(56,189,248,0.1); }
th { padding: 10px 12px; color: var(--p); font-size: 11px; letter-spacing: 1px; text-align: center; border-top: 1px solid var(--p); border-bottom: 1px solid var(--p); }
th:first-child { text-align: left; }
td { padding: 10px 12px; border-bottom: 1px solid var(--line); font-size: 12px; text-align: center; color: var(--txt); }
td.left { text-align: left; }
td.right { text-align: right; color: var(--p); }
.totals { display: flex; justify-content: flex-end; }
.totals-block { width: 320px; }
.totals-row { display: flex; justify-content: space-between; padding: 8px 14px; font-size: 12px; border-bottom: 1px solid var(--line); }
.totals-row .v { color: var(--p); font-variant-numeric: tabular-nums; }
.totals-row.grand { background: var(--p); color: #0f172a; padding: 12px 14px; font-weight: 700; font-size: 15px; border: none; border-radius: 2px; margin-top: 6px; }
.totals-row.grand .v { color: #0f172a; }
.foot { margin-top: 22px; padding-top: 18px; border-top: 1px dashed var(--line); display: grid; grid-template-columns: 1fr 1fr; gap: 24px; font-size: 11px; color: var(--muted); }
.foot h6 { color: var(--p); font-size: 10px; letter-spacing: 3px; margin-bottom: 4px; }
.foot p { line-height: 1.7; }
@@media print { body { background: var(--bg) !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; } .no-print { display: none !important; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">> PRINT</button><button onclick="history.back()">< BACK</button></div>
<div class="page">
    <div class="head">
        <div class="brand">
            <div class="logo">▸ @(Model.Settings.CompanyName ?? "公司名稱")</div>
            <div class="meta">
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>// @Model.Settings.CompanyAddress</div> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>tel: @Model.Settings.CompanyPhone　</span> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>@Model.Settings.CompanyEmail</span> }
            </div>
        </div>
        <div class="doc">
            <div class="lbl">// invoice_id</div>
            <div class="num">@Model.Invoice.InvoiceNumber</div>
            <div class="badge">@Model.Invoice.Status.ToUpper()</div>
        </div>
    </div>
    <div class="grid">
        <div class="panel">
            <h6>// CLIENT</h6>
            <p><span class="k">name:</span><strong>@buyerName</strong></p>
            @if (!string.IsNullOrEmpty(buyerTaxId)) { <p><span class="k">tax_id:</span>@buyerTaxId</p> }
            @if (!string.IsNullOrEmpty(partner?.Address)) { <p><span class="k">addr:</span>@partner.Address</p> }
            @if (!string.IsNullOrEmpty(partner?.Phone)) { <p><span class="k">tel:</span>@partner.Phone</p> }
        </div>
        <div class="panel">
            <h6>// META</h6>
            <p><span class="k">issued:</span>@Model.Invoice.CreatedAt.ToString("yyyy-MM-dd")</p>
            <p><span class="k">period:</span>@Model.Invoice.PeriodStart.ToString("yyyy-MM-dd") → @Model.Invoice.PeriodEnd.ToString("yyyy-MM-dd")</p>
            @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p><span class="k">terms:</span>@Model.Settings.PaymentTerms</p> }
        </div>
    </div>
    <table>
        <thead><tr><th style="width:36%">item</th><th>black</th><th>color</th><th>large</th><th>monthly</th><th>page_fee</th><th style="text-align:right;">subtotal</th></tr></thead>
        <tbody>
            @foreach (var it in Model.Invoice.Items) {
                <tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
            }
        </tbody>
    </table>
    <div class="totals"><div class="totals-block">
        <div class="totals-row"><span>subtotal</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>tax (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>TOTAL_DUE</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    @if (!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.FooterNote)) {
        <div class="foot">
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.BankName)) {
                    <h6>// PAYMENT</h6>
                    <p>bank: @Model.Settings.BankName @Model.Settings.BankBranch</p>
                    @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <p>account: @Model.Settings.BankAccount</p> }
                }
            </div>
            <div>
                @if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>// NOTE</h6><p>@Model.Settings.FooterNote</p> }
            </div>
        </div>
    }
</div></body></html>
