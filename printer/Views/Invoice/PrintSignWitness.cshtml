@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#7c3aed";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#fafaf9;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:32px 36px;box-shadow:0 4px 16px rgba(0,0,0,0.05)}
.head{text-align:center;padding-bottom:14px;border-bottom:3px double var(--p);margin-bottom:18px}
.head .name{font-size:24px;color:var(--p);font-weight:700;letter-spacing:2px}
.head .meta{font-size:11px;color:#6b7280;margin-top:6px;line-height:1.7}
.title{text-align:center;font-size:22px;color:var(--p);letter-spacing:14px;margin:14px 0;padding:6px 0;border-top:1px solid var(--p);border-bottom:1px solid var(--p)}
.parties{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:14px 16px;background:#faf5ff;border:1px solid #e9d5ff;margin-bottom:18px}
.parties h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}
.parties p{font-size:12px;margin:2px 0;color:#4b5563}
table{width:100%;border-collapse:collapse;margin-bottom:18px;border:1px solid var(--p)}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}
th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #f3e8ff;font-size:12px;text-align:center}
td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;border:1px solid var(--p)}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;border-bottom:1px solid #f3e8ff}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border:none}
.witness-area{margin-top:24px;padding-top:20px;border-top:3px double var(--p)}
.witness-title{text-align:center;font-size:13px;color:var(--p);letter-spacing:6px;margin-bottom:18px;font-weight:600}
.sig-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.sig-cell{text-align:center;padding:0 8px}
.sig-cell .role{font-size:12px;color:var(--p);font-weight:600;margin-bottom:8px;letter-spacing:3px;padding:6px 12px;background:#faf5ff;border-radius:4px}
.sig-cell .info{font-size:11px;color:#6b7280;margin-bottom:8px}
.sig-cell .area{height:80px;border:1px solid #1f2937;display:flex;align-items:flex-end;justify-content:center;color:#d1d5db;font-size:10px;padding:4px;background:#fafaf9}
.sig-cell .date{margin-top:6px;font-size:11px;color:#6b7280}
@@media print{.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none}}@@page{size:A4;margin:14mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　電話 @Model.Settings.CompanyPhone</span>}</div></div>
<div class="title">帳　單</div>
<div class="parties">
    <div><h6>買　方</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}@if(!string.IsNullOrEmpty(partner?.Phone)){<p>電話：@partner.Phone</p>}</div>
    <div><h6>賣　方</h6><p><strong>@(Model.Settings.CompanyName ?? "")</strong></p><p>編號：@Model.Invoice.InvoiceNumber</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div>
</div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="witness-area">
    <div class="witness-title">⊰ 三 方 簽 證 ⊱</div>
    <div class="sig-grid">
        <div class="sig-cell"><div class="role">買 方 簽 名</div><div class="info">@buyerName</div><div class="area">客戶簽章</div><div class="date">日期：　　/　　/　　</div></div>
        <div class="sig-cell"><div class="role">賣 方 簽 名</div><div class="info">@(Model.Settings.CompanyName ?? "")</div><div class="area">承辦人簽章</div><div class="date">日期：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
        <div class="sig-cell"><div class="role">見 證 人</div><div class="info">主管 / 第三方</div><div class="area">見證人簽章</div><div class="date">日期：　　/　　/　　</div></div>
    </div>
</div>
</div></body></html>
