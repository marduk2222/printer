@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#7c3aed";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#fff;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:0 auto;padding:0}
.hero{background:linear-gradient(135deg,var(--p),#a855f7);color:#fff;padding:60px 40px;text-align:center;position:relative}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 30% 50%,rgba(255,255,255,0.15),transparent 50%);pointer-events:none}
.hero .name{font-size:36px;font-weight:700;letter-spacing:2px;margin-bottom:8px;position:relative}
.hero .slogan{font-size:14px;opacity:.9;font-style:italic;margin-bottom:20px;position:relative}
.hero .doc{display:inline-block;padding:8px 24px;background:rgba(255,255,255,0.2);border-radius:24px;backdrop-filter:blur(8px);font-size:14px;letter-spacing:2px;position:relative}
.hero .doc strong{font-size:18px}
.body{padding:32px 40px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;padding-bottom:18px;border-bottom:1px solid #e5e7eb}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:13px;margin:2px 0;color:#4b5563}
table{width:100%;border-collapse:collapse;margin-bottom:18px}th{padding:12px 12px;background:#faf5ff;color:var(--p);border-bottom:2px solid var(--p);font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:12px 12px;border-bottom:1px solid #e5e7eb;font-size:13px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:320px;background:#faf5ff;border-radius:12px;padding:8px 0;border:2px solid var(--p)}.totals-row{display:flex;justify-content:space-between;padding:10px 18px;font-size:13px;color:#6b7280}.totals-row.grand{background:linear-gradient(135deg,var(--p),#a855f7);color:#fff;padding:14px 18px;border-radius:0 0 10px 10px;margin-top:6px;font-weight:700;font-size:18px}
.foot{padding:18px 40px;background:#faf5ff;display:grid;grid-template-columns:1fr 1fr;gap:24px;font-size:11px;color:#6b7280}.foot h6{color:var(--p);margin-bottom:4px;letter-spacing:2px}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:0}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="hero">
    <div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
    @if(!string.IsNullOrEmpty(Model.Settings.CompanySlogan)){<div class="slogan">— @Model.Settings.CompanySlogan —</div>}
    <div class="doc">INVOICE　<strong>@Model.Invoice.InvoiceNumber</strong></div>
</div>
<div class="body">
<div class="info"><div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}@if(!string.IsNullOrEmpty(partner?.Phone)){<p>電話：@partner.Phone</p>}</div><div><h6>期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p>@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<p>付款：@Model.Settings.PaymentTerms</p>}</div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
</div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></body></html>
