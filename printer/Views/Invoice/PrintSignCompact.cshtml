@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#475569";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1e293b;background:#fff;font-size:12px;line-height:1.4}
.no-print{display:flex;gap:8px;padding:8px;background:#f1f5f9;border-bottom:1px solid #cbd5e1}.no-print button{padding:6px 16px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:13px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:12px auto;padding:18px 24px;border:1px solid var(--p)}
.head{display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:8px;border-bottom:2px solid var(--p);margin-bottom:10px}
.head .name{font-size:16px;font-weight:700;color:var(--p)}.head .meta{font-size:10px;color:#64748b;line-height:1.4}
.head .doc{text-align:right;font-size:11px}.head .doc strong{font-size:14px;color:var(--p)}
dl{display:grid;grid-template-columns:80px 1fr 80px 1fr;gap:4px 12px;padding:6px 0;border-bottom:1px dashed #cbd5e1;margin-bottom:8px;font-size:11px}
dt{color:#64748b}dd{color:#1e293b;font-weight:500}
table{width:100%;border-collapse:collapse;margin-bottom:8px;font-size:11px}
th{padding:4px 6px;background:var(--p);color:#fff;text-align:center}th:first-child{text-align:left;padding-left:8px}
td{padding:4px 6px;border-bottom:1px solid #e2e8f0;text-align:center}td.left{text-align:left;padding-left:8px}td.right{text-align:right}
.totals-row{display:flex;justify-content:flex-end;gap:16px;padding:3px 8px;font-size:11px}.totals-row .v{min-width:80px;text-align:right}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:5px 8px;font-size:12px;margin-top:3px}
.sign-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:14px;padding-top:8px;border-top:1px dashed #cbd5e1}
.sign-row .col{font-size:10px}
.sign-row .lbl{color:var(--p);font-weight:600;letter-spacing:1px;margin-bottom:4px;font-size:11px}
.sign-row .area{height:40px;border-bottom:1px solid #1e293b;margin-bottom:4px;display:flex;align-items:flex-end;color:#cbd5e1;padding:0 4px}
.sign-row .meta{color:#64748b;display:flex;justify-content:space-between}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:10mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　Tel @Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div>編號 <strong>@Model.Invoice.InvoiceNumber</strong></div><div>開立 @Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div></div>
<dl>
    <dt>客戶</dt><dd><strong>@buyerName</strong></dd><dt>統編</dt><dd>@(buyerTaxId ?? "—")</dd>
    <dt>地址</dt><dd colspan="3">@(partner?.Address ?? "—")</dd>
    <dt>電話</dt><dd>@(partner?.Phone ?? "—")</dd><dt>期間</dt><dd>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</dd>
</dl>
<table><thead><tr><th style="width:32%">項目</th><th>黑</th><th>彩</th><th>大</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals-row"><span>未稅</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
<div class="totals-row"><span>稅 (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
<div class="totals-row grand"><span>含稅總計</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
<div class="sign-row">
    <div class="col"><div class="lbl">客戶簽收</div><div class="area">客戶簽章</div><div class="meta"><span>@buyerName</span><span>　/　/　</span></div></div>
    <div class="col"><div class="lbl">承辦人簽章</div><div class="area">經辦人簽章</div><div class="meta"><span>@(Model.Settings.CompanyName ?? "")</span><span>@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</span></div></div>
</div>
</div></body></html>
