@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1a1a1a";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"DFKai-SB","Noto Serif TC",serif;color:#1a1a1a;background:#fff;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#f5f5f4;border-bottom:1px solid #d6d3d1}.no-print button{padding:8px 22px;border:1px solid #1a1a1a;background:#fff;color:#1a1a1a;cursor:pointer;font-size:14px}.btn-print{background:#1a1a1a !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:32px 40px;border:1px solid #1a1a1a}
.head-table{width:100%;border-collapse:collapse;margin-bottom:18px;border:1px solid #000}
.head-table td{padding:8px 12px;border:1px solid #000;font-size:12px;font-family:"Noto Sans TC",sans-serif}
.head-table .lbl{background:#f5f5f4;font-weight:bold;width:90px;font-family:"Noto Serif TC",serif}
.title{text-align:center;font-size:30px;font-weight:bold;letter-spacing:24px;padding:14px 0;border-top:3px solid #000;border-bottom:3px double #000;margin-bottom:18px}
table{width:100%;border-collapse:collapse;margin-bottom:14px;border:1px solid #000;font-family:"Noto Sans TC",sans-serif}
th{padding:8px 10px;background:#f5f5f4;color:#000;border:1px solid #000;font-size:12px;text-align:center;font-weight:bold}
td{padding:8px 10px;border:1px solid #000;font-size:12px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals-table{width:100%;border-collapse:collapse;margin-bottom:18px;border:1px solid #000;font-family:"Noto Sans TC",sans-serif}
.totals-table td{padding:8px 12px;border:1px solid #000;font-size:13px}
.totals-table .lbl{background:#f5f5f4;font-weight:bold;width:75%;text-align:right}
.totals-table .grand .lbl{background:#1a1a1a;color:#fff}
.totals-table .grand td{font-weight:bold;font-size:14px}
.sigs{margin-top:36px;display:grid;grid-template-columns:repeat(4,1fr);gap:14px;font-family:"Noto Sans TC",sans-serif;font-size:11px;text-align:center;color:#525252}
.sigs div{padding-top:32px;border-top:1px solid #000}
.note{margin-top:14px;padding:8px 12px;font-size:11px;font-family:"Noto Sans TC",sans-serif;color:#525252;border:1px dashed #888}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none}}@@page{size:A4;margin:14mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<table class="head-table">
    <tr><td class="lbl">發行單位</td><td><strong>@(Model.Settings.CompanyName ?? "公司名稱")</strong>　@Model.Settings.CompanyAddress</td><td class="lbl">編號</td><td>@Model.Invoice.InvoiceNumber</td></tr>
    <tr><td class="lbl">受文者</td><td><strong>@buyerName</strong>　@if(!string.IsNullOrEmpty(buyerTaxId)){<span>（統編 @buyerTaxId）</span>}</td><td class="lbl">日期</td><td>@Model.Invoice.CreatedAt.ToString("yyyy 年 MM 月 dd 日")</td></tr>
</table>
<div class="title">帳　單</div>
<table>
    <thead><tr><th style="width:6%">項次</th><th style="width:30%">品名規格</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租費</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
    <tbody>@{int i=1;}@foreach(var it in Model.Invoice.Items){<tr><td>@i</td><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>i++;}</tbody>
</table>
<table class="totals-table">
    <tr><td class="lbl">未稅小計</td><td style="text-align:right;">$@Model.Invoice.TotalAmount.ToString("N0")</td></tr>
    <tr><td class="lbl">營業稅 (5%)</td><td style="text-align:right;">$@Model.Invoice.TaxAmount.ToString("N0")</td></tr>
    <tr class="grand"><td class="lbl">含稅總計</td><td style="text-align:right;">$@Model.Invoice.GrandTotal.ToString("N0")</td></tr>
</table>
@if(!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.FooterNote)){
<div class="note">@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<text>匯款：@Model.Settings.BankName @Model.Settings.BankBranch / 帳號 @Model.Settings.BankAccount　</text>}@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<text>@Model.Settings.FooterNote</text>}</div>
}
<div class="sigs"><div>承辦人</div><div>覆核</div><div>會計</div><div>主管</div></div>
</div></body></html>
