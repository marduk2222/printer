@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#059669";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#f9fafb;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px;border-radius:4px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff}
.split-head{display:grid;grid-template-columns:1fr 1fr;background:var(--p)}
.split-head .panel{padding:24px 28px;color:#fff}
.split-head .panel.right{background:rgba(0,0,0,0.15);text-align:right}
.split-head .name{font-size:22px;font-weight:600}.split-head .meta{font-size:11px;opacity:.85;line-height:1.7;margin-top:6px}
.split-head .lbl{font-size:11px;letter-spacing:4px;opacity:.85}.split-head .num{font-size:22px;font-weight:700;margin-top:2px}
.body{padding:28px 32px}
.info-strip{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:14px 18px;background:#f3f4f6;margin-bottom:22px;border-left:4px solid var(--p)}
.info-strip h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info-strip p{font-size:12px;margin:2px 0;color:#4b5563}
table{width:100%;border-collapse:collapse;margin-bottom:18px}th{padding:10px 12px;background:#f3f4f6;color:var(--p);border-bottom:2px solid var(--p);font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;text-align:center}td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;border:1px solid var(--p)}.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;border-bottom:1px solid #e5e7eb}.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border:none}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:1px dashed #e5e7eb;font-size:11px;color:#6b7280}.foot h6{color:var(--p);margin-bottom:4px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:0}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="split-head">
    <div class="panel"><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<div>電話 @Model.Settings.CompanyPhone</div>}@if(!string.IsNullOrEmpty(Model.Settings.CompanyEmail)){<div>@Model.Settings.CompanyEmail</div>}</div></div>
    <div class="panel right"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div><div style="margin-top:6px;font-size:11px;opacity:.85;">開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
</div>
<div class="body">
<div class="info-strip"><div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<p>付款：@Model.Settings.PaymentTerms</p>}</div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></div></body></html>
