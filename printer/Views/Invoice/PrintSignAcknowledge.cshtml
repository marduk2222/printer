@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#166534";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單確認 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#14532d;background:#f0fdf4;font-size:13px;line-height:1.6}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #86efac}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px;border-radius:24px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:32px 36px;border-radius:12px;box-shadow:0 4px 16px rgba(22,101,52,0.1)}
.head{padding-bottom:14px;border-bottom:1px solid #86efac;margin-bottom:18px;display:flex;justify-content:space-between;align-items:flex-end}
.head .name{color:var(--p);font-size:24px;font-weight:600}.head .meta{color:#15803d;font-size:11px;line-height:1.7;margin-top:6px}
.doc{text-align:right}.doc .lbl{color:var(--p);font-size:13px;letter-spacing:8px}.doc .num{color:#14532d;font-size:18px;font-weight:600;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:14px 18px;background:#f0fdf4;border-radius:8px;margin-bottom:18px;border-left:4px solid var(--p)}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;margin:2px 0;color:#15803d}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}
th:first-child{text-align:left;border-radius:8px 0 0 0}th:last-child{border-radius:0 8px 0 0;text-align:right}
td{padding:10px 12px;border-bottom:1px solid #f0fdf4;font-size:12px;text-align:center;color:#14532d}
td.left{text-align:left}td.right{text-align:right}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;background:#f0fdf4;border-radius:8px;border:1px solid var(--p)}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;color:#15803d}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border-radius:0 0 7px 7px}
.ack-section{margin-top:24px;padding:18px 22px;background:linear-gradient(135deg,#dcfce7,#f0fdf4);border-radius:12px;border:2px solid var(--p)}
.ack-text{font-size:13px;color:#14532d;line-height:1.8;margin-bottom:18px}
.ack-text strong{color:var(--p)}
.checkbox-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:18px;margin-bottom:18px;font-size:11px;color:#15803d}
.checkbox-row .item{display:flex;align-items:center;gap:6px}
.checkbox-row .box{width:14px;height:14px;border:2px solid var(--p);border-radius:2px;flex-shrink:0}
.sig-row{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding-top:14px;border-top:1px dashed var(--p)}
.sig-cell .lbl{color:var(--p);font-size:12px;font-weight:600;letter-spacing:2px;margin-bottom:14px;text-align:center}
.sig-cell .area{height:70px;background:#fff;border:1px solid var(--p);border-radius:6px;display:flex;align-items:flex-end;padding:6px;color:#86efac;font-size:11px}
.sig-cell .meta{margin-top:6px;display:flex;justify-content:space-between;font-size:10px;color:#15803d}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">✓ @(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　·　@Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">帳　單</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="info"><div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th>小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>應付總額</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="ack-section">
    <div class="ack-text">本人 <strong>@buyerName</strong> 已收到並確認上列帳單明細，金額共計新台幣 <strong>$@Model.Invoice.GrandTotal.ToString("N0")</strong> 元整，確認無誤後簽章為證。</div>
    <div class="checkbox-row">
        <div class="item"><div class="box">✓</div><span>項目正確</span></div>
        <div class="item"><div class="box">✓</div><span>金額確認</span></div>
        <div class="item"><div class="box"></div><span>需再洽談</span></div>
    </div>
    <div class="sig-row">
        <div class="sig-cell"><div class="lbl">客　戶　簽　名</div><div class="area">客戶簽章</div><div class="meta"><span>@buyerName</span><span>　/　/　</span></div></div>
        <div class="sig-cell"><div class="lbl">承　辦　人　員</div><div class="area">承辦人簽章</div><div class="meta"><span>@(Model.Settings.CompanyName ?? "")</span><span>@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</span></div></div>
    </div>
</div>
</div></body></html>
