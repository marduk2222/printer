@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#94a3b8";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root{--p:@primary;--soft:#f8fafc}
*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Inter","Noto Sans TC",sans-serif;color:#334155;background:linear-gradient(180deg,#e2e8f0,#fff);font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid var(--p)}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:#475569;cursor:pointer;font-size:14px;border-radius:24px}.btn-print{background:linear-gradient(135deg,#cbd5e1,var(--p)) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:linear-gradient(135deg,#fff,#f1f5f9);padding:32px 36px;border-radius:12px;box-shadow:0 8px 24px rgba(148,163,184,0.2);border:1px solid var(--p)}
.head{display:flex;justify-content:space-between;align-items:flex-end;padding-bottom:16px;border-bottom:2px solid var(--p);margin-bottom:22px}
.head .name{color:#475569;font-size:24px;font-weight:600;background:linear-gradient(135deg,#475569,var(--p));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
.head .meta{color:#64748b;font-size:11px;line-height:1.7;margin-top:6px}
.doc{text-align:right}.doc .lbl{font-size:13px;color:var(--p);letter-spacing:8px}.doc .num{font-size:16px;color:#475569;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:14px 18px;background:rgba(255,255,255,0.7);backdrop-filter:blur(8px);border:1px solid var(--p);border-radius:10px;margin-bottom:22px}
.info h6{color:#475569;font-size:11px;letter-spacing:2px;margin-bottom:6px}.info p{font-size:12px;color:#475569;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:linear-gradient(180deg,#cbd5e1,var(--p));color:#fff;font-size:12px;text-align:center}th:first-child{text-align:left;border-radius:8px 0 0 0}th:last-child{border-radius:0 8px 0 0;text-align:right}
td{padding:10px 12px;border-bottom:1px solid #e2e8f0;font-size:12px;text-align:center;color:#334155}td.left{text-align:left}td.right{text-align:right}tbody tr:nth-child(even){background:rgba(241,245,249,0.5)}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;background:rgba(255,255,255,0.7);border-radius:10px;border:1px solid var(--p)}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px;color:#475569}
.totals-row.grand{background:linear-gradient(135deg,#475569,var(--p));color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border-radius:0 0 9px 9px}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:1px dashed var(--p);font-size:11px;color:#64748b}.foot h6{color:#475569;margin-bottom:4px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div><div class="name">⚙ @(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　@Model.Settings.CompanyPhone</span>}</div></div><div class="doc"><div class="lbl">帳　單</div><div class="num">@Model.Invoice.InvoiceNumber</div></div></div>
<div class="info"><div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th>小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></body></html>
