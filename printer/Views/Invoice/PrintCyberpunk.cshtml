@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#00c770";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>INVOICE - @Model.Invoice.InvoiceNumber</title>
<style>
:root{--p:@primary;--bg:#0a0a0a;--panel:#161616;--neon:#ff00ff}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"JetBrains Mono","Consolas","Noto Sans TC",monospace;color:var(--p);background:var(--bg);font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:var(--panel);border-bottom:1px solid var(--p)}
.no-print button{padding:8px 22px;border:1px solid var(--p);background:transparent;color:var(--p);cursor:pointer;font-size:14px;font-family:inherit;text-shadow:0 0 4px var(--p);box-shadow:0 0 8px rgba(0,199,112,0.3) inset}
.btn-print{background:var(--p) !important;color:var(--bg) !important;text-shadow:none !important}
.page{max-width:820px;margin:24px auto;background:var(--panel);padding:32px 36px;border:1px solid var(--p);box-shadow:0 0 24px rgba(0,199,112,0.2)}
.head{padding-bottom:18px;border-bottom:1px dashed var(--p);margin-bottom:22px;display:flex;justify-content:space-between;align-items:flex-start}
.head .name{color:var(--p);font-size:22px;font-weight:700;letter-spacing:2px;text-shadow:0 0 6px var(--p)}
.head .meta{color:#737373;font-size:11px;margin-top:6px;line-height:1.7}
.doc{text-align:right}
.doc .lbl{color:var(--neon);font-size:10px;letter-spacing:4px}
.doc .num{color:var(--p);font-size:18px;text-shadow:0 0 4px var(--p);margin-top:2px}
.grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:22px}
.grid .panel{background:var(--bg);border:1px solid #404040;padding:14px 16px}
.grid h6{color:var(--neon);font-size:10px;letter-spacing:3px;margin-bottom:6px}
.grid p{color:#d4d4d4;font-size:12px;margin:2px 0}
.grid p .k{color:#737373}
table{width:100%;border-collapse:collapse;margin-bottom:18px;border:1px solid var(--p)}
th{padding:10px 12px;background:var(--bg);color:var(--p);font-size:11px;letter-spacing:2px;text-align:center;border-bottom:1px solid var(--p)}
th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #262626;font-size:12px;text-align:center;color:#d4d4d4}
td.left{text-align:left} td.right{text-align:right;color:var(--p)}
.totals{display:flex;justify-content:flex-end}
.totals-block{width:300px;border:1px solid var(--p);padding:6px 0}
.totals-row{display:flex;justify-content:space-between;padding:8px 14px;font-size:12px;color:#a3a3a3;border-bottom:1px solid #262626}
.totals-row .v{color:var(--p)}
.totals-row.grand{background:var(--p);color:var(--bg);padding:12px 14px;font-weight:700;font-size:15px;border:none}
.totals-row.grand .v{color:var(--bg)}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:1px dashed var(--p);font-size:11px;color:#737373;margin-top:14px}
.foot h6{color:var(--neon);font-size:10px;letter-spacing:3px;margin-bottom:4px}
@@media print{body{background:var(--bg) !important;-webkit-print-color-adjust:exact;print-color-adjust:exact}.no-print{display:none !important}}
@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">>>> PRINT</button><button onclick="history.back()">< BACK</button></div>
<div class="page">
    <div class="head">
        <div><div class="name">▌@(Model.Settings.CompanyName ?? "Company")_</div><div class="meta">// @Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　[@Model.Settings.CompanyPhone]</span>}</div></div>
        <div class="doc"><div class="lbl">[INVOICE_ID]</div><div class="num">@Model.Invoice.InvoiceNumber</div></div>
    </div>
    <div class="grid">
        <div class="panel"><h6>// CLIENT</h6><p><span class="k">name:</span><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p><span class="k">tax_id:</span>@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p><span class="k">addr:</span>@partner.Address</p>}@if(!string.IsNullOrEmpty(partner?.Phone)){<p><span class="k">tel:</span>@partner.Phone</p>}</div>
        <div class="panel"><h6>// META</h6><p><span class="k">issued:</span>@Model.Invoice.CreatedAt.ToString("yyyy.MM.dd")</p><p><span class="k">period:</span>@Model.Invoice.PeriodStart.ToString("yyyy.MM.dd") → @Model.Invoice.PeriodEnd.ToString("yyyy.MM.dd")</p>@if(!string.IsNullOrEmpty(Model.Settings.PaymentTerms)){<p><span class="k">terms:</span>@Model.Settings.PaymentTerms</p>}</div>
    </div>
    <table>
        <thead><tr><th>item</th><th>black</th><th>color</th><th>large</th><th>monthly</th><th>page</th><th style="text-align:right;">subtotal</th></tr></thead>
        <tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody>
    </table>
    <div class="totals"><div class="totals-block">
        <div class="totals-row"><span>subtotal</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>tax (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>>>> TOTAL</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    <div class="foot">
        <div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>// PAY</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div>
        <div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>// NOTE</h6><p>@Model.Settings.FooterNote</p>}</div>
    </div>
</div></body></html>
