@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#7f1d1d";
   var partner = Model.Invoice.Partner; var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root{--p:@primary;--soft:#fef2f2}
*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Serif TC",serif;color:#3f0707;background:#fafaf9;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:2px solid var(--p)}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:0;border:3px solid var(--p)}
.head{background:var(--p);color:#fff;padding:24px 32px;text-align:center;border-bottom:6px double #fef2f2}
.head .name{font-size:26px;font-weight:600;letter-spacing:4px}.head .meta{font-size:11px;opacity:.9;margin-top:6px;font-family:"Noto Sans TC",sans-serif}
.body{padding:24px 32px}
.title{text-align:center;font-size:22px;color:var(--p);letter-spacing:14px;margin-bottom:18px;padding:8px 0;border-top:1px solid var(--p);border-bottom:1px solid var(--p)}
.info{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:16px 18px;background:var(--soft);margin-bottom:22px;border-left:4px solid var(--p);font-family:"Noto Sans TC",sans-serif}
.info h6{color:var(--p);font-size:11px;letter-spacing:3px;margin-bottom:6px}.info p{font-size:12px;color:#7c2d12;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:18px;font-family:"Noto Sans TC",sans-serif;border:1px solid var(--p)}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid var(--soft);font-size:12px;text-align:center;color:#3f0707}td.left{text-align:left}td.right{text-align:right;font-weight:600}
.totals{display:flex;justify-content:flex-end;margin-bottom:18px}.totals-card{width:300px;border:2px solid var(--p)}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-family:"Noto Sans TC",sans-serif;font-size:13px;border-bottom:1px solid var(--soft)}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:15px;border:none}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:2px double var(--p);font-family:"Noto Sans TC",sans-serif;font-size:11px;color:#7c2d12}.foot h6{color:var(--p);margin-bottom:4px}
@@media print{.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="head"><div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div><div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　電話 @Model.Settings.CompanyPhone</span>}</div></div>
<div class="body">
<div class="title">帳　單</div>
<div class="info"><div><h6>客 戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統一編號：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div><div><h6>帳 單 資 訊</h6><p>編號：@Model.Invoice.InvoiceNumber</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p><p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p></div></div>
<table><thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals"><div class="totals-card"><div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div><div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div><div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div></div></div>
<div class="foot"><div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款資訊</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div><div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div></div>
</div></div></body></html>
