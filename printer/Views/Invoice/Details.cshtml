@model printer.Data.Entities.Invoice
@using printer.Data.Enums
@{
    ViewData["Title"] = $"帳單 {Model.InvoiceNumber}";
    var statusNames = new Dictionary<string, (string Name, string Class)>
    {
        ["draft"]     = ("草稿",   "bg-secondary"),
        ["confirmed"] = ("已確認", "bg-primary"),
        ["paid"]      = ("已付款", "bg-success"),
        ["cancelled"] = ("已取消", "bg-danger"),
    };
    var status = statusNames.GetValueOrDefault(Model.Status, ("未知", "bg-secondary"));
    var einvoiceList = ViewBag.Einvoices as List<printer.Data.Entities.Einvoice> ?? new List<printer.Data.Entities.Einvoice>();
    var hasIssuedEinvoice = einvoiceList.Any(e => e.Status == "issued");
    var canEdit = Model.Status == "draft" && !hasIssuedEinvoice;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>帳單詳情</h4>
    <div class="d-flex gap-2">
        @if (canEdit)
        {
            <div id="viewActions" class="gap-2" style="display:flex;">
                <button type="button" class="btn btn-warning btn-sm" onclick="toggleEdit(true)">編輯</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
            </div>
            <div id="editActions" class="gap-2" style="display:none;">
                <button type="submit" form="editForm" class="btn btn-success btn-sm">儲存變更</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleEdit(false)">取消</button>
            </div>
        }
        else
        {
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">返回列表</a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" id="editForm">

            @* 帳單資訊 *@
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>帳單資訊</span>
                    <span class="badge @status.Item2">@status.Item1</span>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">帳單編號</dt>
                        <dd class="col-sm-9"><strong>@Model.InvoiceNumber</strong></dd>

                        <dt class="col-sm-3">客戶</dt>
                        <dd class="col-sm-9">@Model.Partner?.Name</dd>

                        <dt class="col-sm-3">計費期間</dt>
                        <dd class="col-sm-9">
                            <span class="view-mode">@Model.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.PeriodEnd.ToString("yyyy/MM/dd")</span>
                            <div class="edit-mode" style="display:none">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <input type="date" name="periodStart" value="@Model.PeriodStart.ToString("yyyy-MM-dd")"
                                           class="form-control form-control-sm" style="width:160px" />
                                    <span>~</span>
                                    <input type="date" name="periodEnd" value="@Model.PeriodEnd.ToString("yyyy-MM-dd")"
                                           class="form-control form-control-sm" style="width:160px" />
                                </div>
                            </div>
                        </dd>

                        <dt class="col-sm-3">建立時間</dt>
                        <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</dd>

                        @if (Model.ConfirmedAt.HasValue)
                        {
                            <dt class="col-sm-3">確認時間</dt>
                            <dd class="col-sm-9">@Model.ConfirmedAt.Value.ToString("yyyy/MM/dd HH:mm")</dd>
                        }
                        @if (Model.PaidAt.HasValue)
                        {
                            <dt class="col-sm-3">付款時間</dt>
                            <dd class="col-sm-9">@Model.PaidAt.Value.ToString("yyyy/MM/dd HH:mm")</dd>
                        }
                    </dl>
                </div>
            </div>

            @* 帳單明細 *@
            <div class="card mb-3">
                <div class="card-header">帳單明細</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>事務機</th>
                                    <th class="text-end" style="width:110px">月租費</th>
                                    <th class="text-end" style="width:110px">張數費</th>
                                    <th class="text-end" style="width:115px">小計</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="@(item.IsGroupSummary ? "table-info" : "")">
                                        <td>
                                            @if (item.IsGroupSummary)
                                            {
                                                <div class="fw-bold">
                                                    <span class="badge bg-info text-dark me-1">合併</span>
                                                    @(item.BillingGroup?.Name ?? "計費群組")
                                                </div>
                                            }
                                            else if (item.Printer != null)
                                            {
                                                <div class="fw-bold">
                                                    @item.Printer.Name
                                                    @if (item.BillingGroupId.HasValue)
                                                    {
                                                        <span class="badge bg-secondary ms-1" title="此事務機屬於計費群組">群組成員</span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="fw-bold">@item.Description</div>
                                            }
                                            @if (!string.IsNullOrEmpty(item.Breakdown))
                                            {
                                                <small class="text-muted" style="white-space:pre-line">@item.Breakdown</small>
                                            }
                                            else if (item.Printer != null && !string.IsNullOrEmpty(item.Description))
                                            {
                                                <small class="text-muted">@item.Description</small>
                                            }
                                        </td>
                                        <td class="text-end align-top">@(item.MonthlyFee > 0 ? $"${item.MonthlyFee:N0}" : "-")</td>
                                        <td class="text-end align-top">@(item.PageFee > 0 ? $"${item.PageFee:N0}" : "-")</td>
                                        <td class="text-end align-top"><strong>$@item.Subtotal.ToString("N0")</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end"><strong>小計</strong></td>
                                    <td class="text-end"><strong>$@Model.TotalAmount.ToString("N0")</strong></td>
                                </tr>
                                @if (Model.TaxAmount > 0)
                                {
                                    <tr>
                                        <td colspan="3" class="text-end">稅額</td>
                                        <td class="text-end">$@Model.TaxAmount.ToString("N0")</td>
                                    </tr>
                                }
                                <tr class="table-primary">
                                    <td colspan="3" class="text-end"><strong>總計</strong></td>
                                    <td class="text-end"><strong>$@Model.GrandTotal.ToString("N0")</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            @* 備註 *@
            <div class="card mb-3">
                <div class="card-header">備註</div>
                <div class="card-body">
                    <span class="view-mode">@(string.IsNullOrEmpty(Model.Note) ? "（無）" : Model.Note)</span>
                    <textarea name="note" class="form-control edit-mode" rows="3" style="display:none">@Model.Note</textarea>
                </div>
            </div>

        </form>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-bold">列印帳單</div>
            <div class="card-body">
                <a href="@Url.Action("Print", new { id = Model.Id })" target="_blank"
                   class="btn btn-primary btn-sm w-100 mb-3">列印</a>
                <hr />
                @if (Model.Status == "draft")
                {
                    <form asp-action="Confirm" asp-route-id="@Model.Id" method="post" class="mb-2">
                        <button type="submit" class="btn btn-primary w-100">確認帳單</button>
                    </form>
                }
                @if (Model.Status == "draft" || Model.Status == "confirmed")
                {
                    <form asp-action="MarkPaid" asp-route-id="@Model.Id" method="post" class="mb-2">
                        <button type="submit" class="btn btn-success w-100">標記已付款</button>
                    </form>
                }
                @if (Model.Status != "paid" && Model.Status != "cancelled")
                {
                    <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-outline-danger w-100"
                                onclick="return confirm('確定要取消此帳單嗎？')">取消帳單</button>
                    </form>
                }
                @if (Model.Status == "paid" || Model.Status == "cancelled")
                {
                    <p class="text-muted mb-0">此帳單狀態無法變更</p>
                }

                @if (ViewBag.EinvoiceEnabled == true)
                {
                    <hr />
                    <a asp-controller="Einvoice" asp-action="CreateFromBilling" asp-route-billingInvoiceId="@Model.Id"
                       class="btn btn-outline-primary w-100">開立發票</a>
                }
            </div>
        </div>

        @if (einvoiceList.Any())
        {
            var einvStatusNames = new Dictionary<string, (string Name, string Class)>
            {
                ["draft"]  = ("草稿",   "bg-secondary"),
                ["issued"] = ("已開立", "bg-success"),
                ["void"]   = ("已作廢", "bg-danger"),
            };
            <div class="card mt-3">
                <div class="card-header">已開立發票</div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>發票號碼</th>
                                <th class="text-end">金額</th>
                                <th>狀態</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var einv in einvoiceList)
                            {
                                var einvStatus = einvStatusNames.GetValueOrDefault(einv.Status, ("未知", "bg-secondary"));
                                <tr>
                                    <td>
                                        <a asp-controller="Einvoice" asp-action="Details" asp-route-id="@einv.Id">
                                            @einv.InvoiceNumber
                                        </a>
                                    </td>
                                    <td class="text-end">$@einv.TotalAmount.ToString("N0")</td>
                                    <td><span class="badge @einvStatus.Item2">@einvStatus.Item1</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="card mt-3">
            <div class="card-header">金額摘要</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-8">設備數量</dt>
                    <dd class="col-4 text-end">@Model.Items.Count 台</dd>
                    <dt class="col-8">月租費合計</dt>
                    <dd class="col-4 text-end">$@Model.Items.Sum(i => i.MonthlyFee).ToString("N0")</dd>
                    <dt class="col-8">張數費合計</dt>
                    <dd class="col-4 text-end">$@Model.Items.Sum(i => i.PageFee).ToString("N0")</dd>
                    <dt class="col-8">小計</dt>
                    <dd class="col-4 text-end">$@Model.TotalAmount.ToString("N0")</dd>
                    @if (Model.TaxAmount > 0)
                    {
                        <dt class="col-8">稅額</dt>
                        <dd class="col-4 text-end">$@Model.TaxAmount.ToString("N0")</dd>
                    }
                    <dt class="col-8 fs-5">總計</dt>
                    <dd class="col-4 text-end fs-5"><strong>$@Model.GrandTotal.ToString("N0")</strong></dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function toggleEdit(editing) {
        document.querySelectorAll('.view-mode').forEach(el => el.style.display = editing ? 'none' : '');
        document.querySelectorAll('.edit-mode').forEach(el => el.style.display = editing ? '' : 'none');
        var va = document.getElementById('viewActions');
        var ea = document.getElementById('editActions');
        if (va) va.style.display = editing ? 'none' : 'flex';
        if (ea) ea.style.display = editing ? 'flex' : 'none';
    }
</script>
}
