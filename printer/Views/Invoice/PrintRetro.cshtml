@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#92400e";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; --paper: #fef9c3; --line: #fde68a; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Courier Prime", "Courier New", "Noto Serif TC", monospace; color: #44291a; background: #fef3c7; font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: var(--paper); border-bottom: 2px solid var(--p); }
.no-print button { padding: 8px 22px; border: 2px solid var(--p); background: var(--paper); color: var(--p); cursor: pointer; font-size: 14px; font-family: inherit; }
.btn-print { background: var(--p) !important; color: var(--paper) !important; }
.page { max-width: 820px; margin: 24px auto; background: var(--paper); padding: 28px 32px; border: 3px solid var(--p); position: relative; box-shadow: 6px 6px 0 var(--p); }
.head { text-align: center; padding-bottom: 14px; border-bottom: 3px double var(--p); margin-bottom: 18px; }
.head .name { font-size: 24px; font-weight: 700; color: var(--p); letter-spacing: 4px; }
.head .slogan { font-size: 12px; color: #78350f; margin: 4px 0 6px; }
.head .meta { font-size: 11px; color: #78350f; line-height: 1.6; }
.title { text-align: center; font-size: 22px; color: var(--p); letter-spacing: 12px; margin: 14px 0; padding: 8px 0; border-top: 2px solid var(--p); border-bottom: 2px solid var(--p); }
.info { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 18px; }
.info h6 { font-size: 12px; color: var(--p); border-bottom: 1px solid var(--p); padding-bottom: 4px; margin-bottom: 6px; letter-spacing: 2px; }
.info p { font-size: 12px; margin: 2px 0; }
table { width: 100%; border-collapse: collapse; margin-bottom: 16px; border: 2px solid var(--p); }
th { padding: 8px 10px; background: var(--p); color: var(--paper); font-size: 12px; text-align: center; }
th:first-child { text-align: left; }
td { padding: 7px 10px; border-bottom: 1px dashed var(--line); font-size: 12px; text-align: center; color: #44291a; }
td.left { text-align: left; }
td.right { text-align: right; }
.totals { display: flex; justify-content: flex-end; margin-bottom: 14px; }
.totals-block { width: 280px; border: 2px solid var(--p); }
.totals-row { display: flex; justify-content: space-between; padding: 6px 12px; border-bottom: 1px dashed var(--p); font-size: 13px; }
.totals-row:last-child { background: var(--p); color: var(--paper); border-bottom: none; font-weight: 700; padding: 8px 12px; }
.foot { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; padding-top: 12px; border-top: 2px dashed var(--p); font-size: 11px; }
.foot h6 { color: var(--p); letter-spacing: 2px; margin-bottom: 4px; }
.foot p { line-height: 1.7; }
@@media print { body { background: var(--paper) !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; } .no-print { display: none !important; } .page { box-shadow: none; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">[ 列印 ]</button><button onclick="history.back()">[ 返回 ]</button></div>
<div class="page">
    <div class="head">
        <div class="name">★ @(Model.Settings.CompanyName ?? "公司名稱") ★</div>
        @if (!string.IsNullOrEmpty(Model.Settings.CompanySlogan)) { <div class="slogan">— @Model.Settings.CompanySlogan —</div> }
        <div class="meta">
            @Model.Settings.CompanyAddress
            @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>　TEL @Model.Settings.CompanyPhone</span> }
        </div>
    </div>
    <div class="title">≡ 帳　單 ≡</div>
    <div class="info">
        <div>
            <h6>>> 客戶</h6>
            <p><strong>@buyerName</strong></p>
            @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統編：@buyerTaxId</p> }
            @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
            @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
        </div>
        <div>
            <h6>>> 帳單</h6>
            <p>編號：@Model.Invoice.InvoiceNumber</p>
            <p>日期：@Model.Invoice.CreatedAt.ToString("yyyy.MM.dd")</p>
            <p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
        </div>
    </div>
    <table>
        <thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
        <tbody>
            @foreach (var it in Model.Invoice.Items) {
                <tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
            }
        </tbody>
    </table>
    <div class="totals"><div class="totals-block">
        <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>>>> 總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    <div class="foot">
        <div>@if (!string.IsNullOrEmpty(Model.Settings.BankName)) { <h6>>> 匯款</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p> }</div>
        <div>@if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>>> 備註</h6><p>@Model.Settings.FooterNote</p> }</div>
    </div>
</div></body></html>
