@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#1e3a5f";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif; color: #1f2937; background: #fff; font-size: 13px; }
.no-print { display: flex; gap: 8px; padding: 12px; background: #f3f4f6; border-bottom: 1px solid #e5e7eb; }
.no-print button { padding: 8px 22px; border: 1px solid var(--p); background: #fff; color: var(--p); cursor: pointer; font-size: 14px; }
.btn-print { background: var(--p) !important; color: #fff !important; }
.page { max-width: 820px; margin: 20px auto; padding: 0; border: 1px solid #d1d5db; }
.banner { background: var(--p); color: #fff; padding: 24px 32px; display: flex; justify-content: space-between; align-items: center; }
.banner .name { font-size: 24px; font-weight: 700; letter-spacing: 1px; }
.banner .meta { font-size: 11px; opacity: 0.85; line-height: 1.6; margin-top: 4px; }
.banner .doc { text-align: right; }
.banner .doc-lbl { font-size: 11px; opacity: 0.85; letter-spacing: 3px; }
.banner .doc-num { font-size: 18px; font-weight: 700; margin-top: 2px; }
.body { padding: 28px 32px; }
.client-row { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; padding: 16px 0; border-bottom: 1px solid #e5e7eb; margin-bottom: 18px; }
.client-row h6 { font-size: 11px; color: var(--p); font-weight: 700; letter-spacing: 2px; margin-bottom: 6px; }
.client-row p { font-size: 12px; margin: 2px 0; }
table { width: 100%; border-collapse: collapse; margin-bottom: 18px; }
th { padding: 10px 12px; background: #f1f5f9; color: var(--p); border-bottom: 2px solid var(--p); font-size: 12px; text-align: center; }
td { padding: 10px 12px; border-bottom: 1px solid #e5e7eb; font-size: 12px; text-align: center; }
td.left { text-align: left; } td.right { text-align: right; }
.totals { display: flex; justify-content: flex-end; }
.totals-table { border-collapse: collapse; }
.totals-table td { padding: 8px 16px; border: 1px solid #d1d5db; font-size: 12px; }
.totals-table .label { background: #f1f5f9; font-weight: 600; }
.totals-table .grand td { background: var(--p); color: #fff; font-weight: 700; font-size: 14px; border-color: var(--p); }
.foot { padding: 18px 32px; background: #f9fafb; border-top: 1px solid #e5e7eb; display: grid; grid-template-columns: 1fr 1fr; gap: 24px; font-size: 11px; color: #4b5563; }
.foot h6 { font-size: 11px; color: var(--p); font-weight: 700; letter-spacing: 2px; margin-bottom: 4px; }
@@media print { .no-print { display: none !important; } }
@@page { size: A4; margin: 12mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
    <div class="banner">
        <div>
            <div class="name">@(Model.Settings.CompanyName ?? "公司名稱")</div>
            <div class="meta">
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyAddress)) { <div>@Model.Settings.CompanyAddress</div> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>Tel @Model.Settings.CompanyPhone　</span> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>@Model.Settings.CompanyEmail</span> }
            </div>
        </div>
        <div class="doc"><div class="doc-lbl">INVOICE</div><div class="doc-num">@Model.Invoice.InvoiceNumber</div></div>
    </div>
    <div class="body">
        <div class="client-row">
            <div>
                <h6>BILL TO ／ 客戶</h6>
                <p><strong>@buyerName</strong></p>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <p>統一編號：@buyerTaxId</p> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <p>@partner.Address</p> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <p>電話：@partner.Phone</p> }
            </div>
            <div>
                <h6>DATES ／ 日期</h6>
                <p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p>
                <p>期間：@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd")</p>
                <p>　　　~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p>
                @if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <p>條件：@Model.Settings.PaymentTerms</p> }
            </div>
        </div>
        <table>
            <thead><tr><th style="width:36%;text-align:left;padding-left:12px;">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
            <tbody>
                @foreach (var it in Model.Invoice.Items) {
                    <tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
                }
            </tbody>
        </table>
        <div class="totals"><table class="totals-table">
            <tr><td class="label">未稅小計</td><td style="text-align:right;">$@Model.Invoice.TotalAmount.ToString("N0")</td></tr>
            <tr><td class="label">營業稅 (5%)</td><td style="text-align:right;">$@Model.Invoice.TaxAmount.ToString("N0")</td></tr>
            <tr class="grand"><td>含稅總計</td><td style="text-align:right;">$@Model.Invoice.GrandTotal.ToString("N0")</td></tr>
        </table></div>
    </div>
    <div class="foot">
        <div>
            @if (!string.IsNullOrEmpty(Model.Settings.BankName)) {
                <h6>PAYMENT</h6>
                <div>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</div>
                @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <div>帳號：@Model.Settings.BankAccount</div> }
            }
        </div>
        <div>
            @if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <h6>NOTE</h6><div>@Model.Settings.FooterNote</div> }
        </div>
    </div>
</div></body></html>
