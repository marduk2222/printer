@model printer.Models.InvoicePrintViewModel
@{ Layout = null; var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#0369a1";
   var partner = Model.Invoice.Partner;
   var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
   var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat; }
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>簽收單 - @Model.Invoice.InvoiceNumber</title>
<style>:root{--p:@primary}*{box-sizing:border-box;margin:0;padding:0}body{font-family:"Noto Sans TC",sans-serif;color:#1f2937;background:#f9fafb;font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #e5e7eb}.no-print button{padding:8px 22px;border:1px solid var(--p);background:#fff;color:var(--p);cursor:pointer;font-size:14px;border-radius:6px}.btn-print{background:var(--p) !important;color:#fff !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:0;border-top:6px solid var(--p)}
.banner{background:var(--p);color:#fff;padding:18px 28px;display:flex;justify-content:space-between;align-items:center}
.banner .title{font-size:22px;font-weight:700;letter-spacing:6px}
.banner .num{font-size:16px;letter-spacing:1px}
.body{padding:24px 28px}
.party{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:14px 16px;background:#eff6ff;border:1px solid #bfdbfe;margin-bottom:18px}
.party h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}
.party p{font-size:12px;margin:2px 0;color:#1e40af}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:#eff6ff;color:var(--p);border-bottom:2px solid var(--p);font-size:12px;text-align:center}
th:first-child{text-align:left}
td{padding:10px 12px;border-bottom:1px solid #e5e7eb;font-size:12px;text-align:center}
td.left{text-align:left} td.right{text-align:right}
.totals-row{display:flex;justify-content:flex-end;gap:14px;padding:5px 0;font-size:13px}
.totals-row .v{min-width:120px;text-align:right;font-weight:500}
.totals-row.grand{background:var(--p);color:#fff;font-weight:700;padding:12px 16px;font-size:16px;margin-top:6px}
.confirm-box{margin-top:24px;padding:18px 22px;border:2px dashed var(--p);background:#eff6ff}
.confirm-box .ack{font-size:12px;line-height:1.7;color:#1e40af;margin-bottom:14px}
.sig-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.sig-cell{text-align:center}
.sig-cell .lbl{font-size:11px;color:var(--p);font-weight:600;margin-bottom:8px;letter-spacing:2px}
.sig-cell .area{height:60px;border-bottom:2px solid #1e40af;display:flex;align-items:flex-end;justify-content:center;color:#9ca3af;font-size:10px;padding-bottom:4px}
.sig-cell .meta{margin-top:4px;font-size:10px;color:#6b7280}
@@media print{body{background:#fff}.no-print{display:none !important}.page{margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
<div class="banner"><div class="title">📦 簽　收　單</div><div class="num">No. @Model.Invoice.InvoiceNumber</div></div>
<div class="body">
<div class="party">
    <div><h6>📤 寄件方</h6><p><strong>@(Model.Settings.CompanyName ?? "公司名稱")</strong></p>@if(!string.IsNullOrEmpty(Model.Settings.CompanyAddress)){<p>@Model.Settings.CompanyAddress</p>}@if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<p>📞 @Model.Settings.CompanyPhone</p>}</div>
    <div><h6>📥 收件方</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}@if(!string.IsNullOrEmpty(partner?.Phone)){<p>📞 @partner.Phone</p>}</div>
</div>
<table><thead><tr><th style="width:34%">項目／服務</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead><tbody>@foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}</tbody></table>
<div class="totals-row"><span>未稅小計</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
<div class="totals-row"><span>營業稅 (5%)</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
<div class="totals-row grand"><span>含稅應收總額</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
<div class="confirm-box">
    <div class="ack">✓ 本人確認已收到上列服務／物品，且金額無誤。</div>
    <div class="sig-grid">
        <div class="sig-cell"><div class="lbl">客　戶　簽　名</div><div class="area">客戶簽收欄</div><div class="meta">姓名：@buyerName</div></div>
        <div class="sig-cell"><div class="lbl">送　件　人　員</div><div class="area">送件人簽章</div><div class="meta">日期：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div></div>
        <div class="sig-cell"><div class="lbl">簽　收　日　期</div><div class="area"></div><div class="meta">　/　　/　　</div></div>
    </div>
</div>
@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<p style="margin-top:14px;font-size:11px;color:#6b7280;">📝 @Model.Settings.FooterNote</p>}
</div></div></body></html>
