@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <title>帳單 - @Model.Invoice.InvoiceNumber</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: "DFKai-SB", "BiauKai", "Noto Serif TC", "Microsoft JhengHei", serif; color: #000; background: #fff; font-size: 13px; }
        .no-print { display: flex; gap: 8px; padding: 12px; background: #f0f0f0; border-bottom: 1px solid #ccc; }
        .no-print button { padding: 8px 22px; border: 1px solid #555; background: #fff; cursor: pointer; font-size: 14px; }
        .page { max-width: 820px; margin: 20px auto; padding: 16px; border: 3px double #000; }
        .inner { border: 1px solid #000; padding: 24px 28px; }
        .title { text-align: center; font-size: 26px; font-weight: bold; letter-spacing: 16px; padding-bottom: 8px; border-bottom: 2px solid #000; margin-bottom: 16px; }
        .meta-grid { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid #000; margin-bottom: 12px; }
        .meta-cell { padding: 6px 10px; border-right: 1px solid #000; font-size: 12px; }
        .meta-cell:last-child { border-right: none; }
        .meta-cell .lbl { display: inline-block; min-width: 70px; color: #555; }
        .info { border: 1px solid #000; padding: 8px 12px; margin-bottom: 12px; font-size: 12px; line-height: 1.8; }
        .info .lbl { display: inline-block; min-width: 70px; color: #555; }
        table { width: 100%; border-collapse: collapse; border: 1px solid #000; margin-bottom: 12px; }
        thead { background: #f0f0f0; }
        th, td { padding: 6px 8px; border: 1px solid #000; font-size: 12px; text-align: center; }
        th { font-weight: bold; }
        td.left { text-align: left; }
        td.right { text-align: right; }
        .totals-row td { border: 1px solid #000; padding: 6px 10px; font-size: 12px; }
        .totals-row .label { background: #f0f0f0; text-align: right; font-weight: bold; }
        .totals-row .grand { background: #e8e8e8; font-size: 14px; font-weight: bold; }
        .footer { display: flex; justify-content: space-between; gap: 24px; margin-top: 14px; padding-top: 10px; border-top: 1px solid #000; font-size: 12px; }
        .sig-box { text-align: center; min-width: 140px; padding-top: 32px; border-top: 1px solid #000; }
        @@media print { .no-print { display: none !important; } }
        @@page { size: A4; margin: 12mm; }
    </style>
</head>
<body>
    <div class="no-print">
        <button onclick="window.print()">列印</button>
        <button onclick="history.back()">返回</button>
    </div>
    <div class="page">
        <div class="inner">
            <div class="title">帳　單</div>
            <div class="meta-grid">
                <div class="meta-cell"><span class="lbl">帳單編號：</span>@Model.Invoice.InvoiceNumber</div>
                <div class="meta-cell"><span class="lbl">開立日期：</span>@Model.Invoice.CreatedAt.ToString("yyyy 年 MM 月 dd 日")</div>
                <div class="meta-cell"><span class="lbl">計費期間：</span>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</div>
                <div class="meta-cell"><span class="lbl">付款條件：</span>@(Model.Settings.PaymentTerms ?? "—")</div>
            </div>

            <div class="info">
                <div><span class="lbl">客戶名稱：</span><strong>@buyerName</strong></div>
                @if (!string.IsNullOrEmpty(buyerTaxId)) { <div><span class="lbl">統一編號：</span>@buyerTaxId</div> }
                @if (!string.IsNullOrEmpty(partner?.Address)) { <div><span class="lbl">地址：</span>@partner.Address</div> }
                @if (!string.IsNullOrEmpty(partner?.Phone)) { <div><span class="lbl">電話：</span>@partner.Phone</div> }
            </div>

            <table>
                <thead>
                    <tr>
                        <th style="width:6%">項次</th>
                        <th style="width:30%">品名規格</th>
                        <th style="width:8%">黑白</th>
                        <th style="width:8%">彩色</th>
                        <th style="width:8%">大張</th>
                        <th style="width:13%">月租費</th>
                        <th style="width:13%">張數費</th>
                        <th style="width:14%">小計</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int idx = 1; }
                    @foreach (var it in Model.Invoice.Items)
                    {
                        <tr>
                            <td>@idx</td>
                            <td class="left">@it.Description</td>
                            <td>@it.BlackPages.ToString("N0")</td>
                            <td>@it.ColorPages.ToString("N0")</td>
                            <td>@it.LargePages.ToString("N0")</td>
                            <td class="right">@it.MonthlyFee.ToString("N0")</td>
                            <td class="right">@it.PageFee.ToString("N0")</td>
                            <td class="right">@it.Subtotal.ToString("N0")</td>
                        </tr>
                        idx++;
                    }
                </tbody>
                <tfoot>
                    <tr class="totals-row">
                        <td colspan="7" class="label">未稅合計</td>
                        <td class="right">$@Model.Invoice.TotalAmount.ToString("N0")</td>
                    </tr>
                    <tr class="totals-row">
                        <td colspan="7" class="label">營業稅 (5%)</td>
                        <td class="right">$@Model.Invoice.TaxAmount.ToString("N0")</td>
                    </tr>
                    <tr class="totals-row grand">
                        <td colspan="7" class="label">含稅總計</td>
                        <td class="right grand">$@Model.Invoice.GrandTotal.ToString("N0")</td>
                    </tr>
                </tfoot>
            </table>

            <div class="footer">
                <div>
                    @if (!string.IsNullOrEmpty(Model.Settings.BankName) || !string.IsNullOrEmpty(Model.Settings.BankAccount))
                    {
                        <div><strong>匯款資訊</strong></div>
                        @if (!string.IsNullOrEmpty(Model.Settings.BankName)) { <div>銀行：@Model.Settings.BankName @Model.Settings.BankBranch</div> }
                        @if (!string.IsNullOrEmpty(Model.Settings.BankAccount)) { <div>帳號：@Model.Settings.BankAccount</div> }
                    }
                    @if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <div style="margin-top:6px;color:#555;">@Model.Settings.FooterNote</div> }
                </div>
                <div style="display:flex; gap:24px;">
                    <div class="sig-box">經手人</div>
                    <div class="sig-box">主管</div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
