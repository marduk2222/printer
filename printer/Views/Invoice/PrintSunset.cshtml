@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#c2410c";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html><html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; }
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Noto Sans TC","Microsoft JhengHei",sans-serif;color:#7c2d12;background:linear-gradient(135deg,#fff7ed,#ffedd5);font-size:13px}
.no-print{display:flex;gap:8px;padding:12px;background:#fff;border-bottom:1px solid #fed7aa}
.no-print button{padding:8px 22px;border:none;background:linear-gradient(135deg,var(--p),#f59e0b);color:#fff;cursor:pointer;font-size:14px;border-radius:24px}
.btn-back{background:#94a3b8 !important}
.page{max-width:820px;margin:24px auto;background:#fff;padding:32px 36px;border-radius:12px;box-shadow:0 8px 24px rgba(194,65,12,0.1)}
.head{background:linear-gradient(135deg,#fb923c,var(--p));color:#fff;padding:24px 28px;border-radius:10px;margin-bottom:22px;display:flex;justify-content:space-between;align-items:center}
.head .name{font-size:24px;font-weight:700}
.head .meta{font-size:11px;opacity:.9;margin-top:6px;line-height:1.6}
.head .doc{text-align:right}
.head .doc .lbl{font-size:11px;letter-spacing:3px;opacity:.85}
.head .doc .num{font-size:18px;font-weight:700;margin-top:2px}
.info{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:20px;padding:14px 16px;background:#fff7ed;border-radius:8px;border-left:4px solid var(--p)}
.info h6{color:var(--p);font-size:11px;letter-spacing:2px;margin-bottom:6px}
.info p{font-size:12px;color:#9a3412;margin:2px 0}
table{width:100%;border-collapse:collapse;margin-bottom:18px}
th{padding:10px 12px;background:var(--p);color:#fff;font-size:12px;text-align:center}
th:first-child{text-align:left;border-radius:6px 0 0 0}
th:last-child{border-radius:0 6px 0 0;text-align:right}
td{padding:10px 12px;border-bottom:1px solid #ffedd5;font-size:12px;text-align:center;color:#7c2d12}
td.left{text-align:left} td.right{text-align:right}
tbody tr:nth-child(even){background:#fff7ed}
.totals{display:flex;justify-content:flex-end;margin-bottom:20px}
.totals-card{width:300px;background:#fff7ed;border-radius:10px;padding:6px 0;border:1px solid var(--p)}
.totals-row{display:flex;justify-content:space-between;padding:8px 16px;font-size:13px}
.totals-row.grand{background:linear-gradient(135deg,#fb923c,var(--p));color:#fff;font-weight:700;border-radius:0 0 9px 9px;padding:12px 16px;font-size:15px}
.foot{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding-top:14px;border-top:2px dashed #fed7aa;font-size:11px;color:#9a3412}
.foot h6{color:var(--p);margin-bottom:4px}
@@media print{body{background:#fff}.no-print{display:none !important}.page{box-shadow:none;margin:0;max-width:none;-webkit-print-color-adjust:exact;print-color-adjust:exact}}
@@page{size:A4;margin:12mm}
</style></head><body>
<div class="no-print"><button onclick="window.print()">列印</button><button class="btn-back" onclick="history.back()">返回</button></div>
<div class="page">
    <div class="head">
        <div>
            <div class="name">🌅 @(Model.Settings.CompanyName ?? "公司名稱")</div>
            <div class="meta">@Model.Settings.CompanyAddress @if(!string.IsNullOrEmpty(Model.Settings.CompanyPhone)){<span>　電話 @Model.Settings.CompanyPhone</span>}</div>
        </div>
        <div class="doc"><div class="lbl">INVOICE</div><div class="num">@Model.Invoice.InvoiceNumber</div></div>
    </div>
    <div class="info">
        <div><h6>客戶</h6><p><strong>@buyerName</strong></p>@if(!string.IsNullOrEmpty(buyerTaxId)){<p>統編：@buyerTaxId</p>}@if(!string.IsNullOrEmpty(partner?.Address)){<p>@partner.Address</p>}</div>
        <div><h6>帳單期間</h6><p>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</p><p>開立：@Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</p></div>
    </div>
    <table>
        <thead><tr><th style="width:34%">項目</th><th>黑白</th><th>彩色</th><th>大張</th><th>月租</th><th>張數費</th><th>小計</th></tr></thead>
        <tbody>
        @foreach(var it in Model.Invoice.Items){<tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>}
        </tbody>
    </table>
    <div class="totals"><div class="totals-card">
        <div class="totals-row"><span>未稅小計</span><span>$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅 (5%)</span><span>$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>含稅總計</span><span>$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div></div>
    <div class="foot">
        <div>@if(!string.IsNullOrEmpty(Model.Settings.BankName)){<h6>匯款資訊</h6><p>@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</p>}</div>
        <div>@if(!string.IsNullOrEmpty(Model.Settings.FooterNote)){<h6>備註</h6><p>@Model.Settings.FooterNote</p>}</div>
    </div>
</div></body></html>
