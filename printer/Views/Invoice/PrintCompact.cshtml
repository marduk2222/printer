@model printer.Models.InvoicePrintViewModel
@{
    Layout = null;
    var primary = !string.IsNullOrEmpty(Model.Settings.PrimaryColor) ? Model.Settings.PrimaryColor : "#475569";
    var partner = Model.Invoice.Partner;
    var buyerName = !string.IsNullOrWhiteSpace(partner?.InvoiceTitle) ? partner!.InvoiceTitle : partner?.Name;
    var buyerTaxId = !string.IsNullOrWhiteSpace(partner?.InvoiceTaxId) ? partner!.InvoiceTaxId : partner?.Vat;
}
<!DOCTYPE html>
<html lang="zh-Hant"><head><meta charset="utf-8" /><title>帳單 - @Model.Invoice.InvoiceNumber</title>
<style>
:root { --p: @primary; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: "Noto Sans TC", "Microsoft JhengHei", Arial, sans-serif; color: #1e293b; background: #fff; font-size: 12px; }
.no-print { display: flex; gap: 8px; padding: 8px; background: #f1f5f9; border-bottom: 1px solid #cbd5e1; }
.no-print button { padding: 6px 16px; border: 1px solid var(--p); background: #fff; color: var(--p); cursor: pointer; font-size: 13px; }
.btn-print { background: var(--p) !important; color: #fff !important; }
.page { max-width: 820px; margin: 12px auto; padding: 18px 24px; border: 1px solid var(--p); }
.head { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 8px; border-bottom: 2px solid var(--p); margin-bottom: 10px; }
.head .name { font-size: 16px; font-weight: 700; color: var(--p); }
.head .meta { font-size: 10px; color: #64748b; line-height: 1.4; }
.head .doc { text-align: right; font-size: 11px; }
.head .doc strong { font-size: 14px; color: var(--p); }
dl { display: grid; grid-template-columns: 80px 1fr 80px 1fr; gap: 4px 12px; padding: 6px 0; border-bottom: 1px dashed #cbd5e1; margin-bottom: 8px; font-size: 11px; }
dt { color: #64748b; }
dd { color: #1e293b; font-weight: 500; }
table { width: 100%; border-collapse: collapse; margin-bottom: 8px; font-size: 11px; }
th { padding: 4px 6px; background: var(--p); color: #fff; text-align: center; }
th:first-child { text-align: left; padding-left: 8px; }
td { padding: 4px 6px; border-bottom: 1px solid #e2e8f0; text-align: center; }
td.left { text-align: left; padding-left: 8px; }
td.right { text-align: right; }
.totals-row { display: flex; justify-content: flex-end; gap: 16px; padding: 3px 8px; font-size: 11px; }
.totals-row .v { min-width: 80px; text-align: right; font-variant-numeric: tabular-nums; }
.totals-row.grand { background: var(--p); color: #fff; font-weight: 700; padding: 6px 8px; margin-top: 4px; }
.foot { display: flex; gap: 16px; margin-top: 8px; padding-top: 6px; border-top: 1px solid #cbd5e1; font-size: 10px; color: #64748b; }
.foot div { flex: 1; }
.foot strong { color: var(--p); }
@@media print { .no-print { display: none !important; } }
@@page { size: A4; margin: 10mm; }
</style></head><body>
<div class="no-print"><button class="btn-print" onclick="window.print()">列印</button><button onclick="history.back()">返回</button></div>
<div class="page">
    <div class="head">
        <div>
            <div class="name">@(Model.Settings.CompanyName ?? "公司名稱") <span style="font-size:10px;color:#64748b;">／@Model.Settings.CompanySlogan</span></div>
            <div class="meta">
                @Model.Settings.CompanyAddress
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyPhone)) { <span>　Tel @Model.Settings.CompanyPhone</span> }
                @if (!string.IsNullOrEmpty(Model.Settings.CompanyEmail)) { <span>　@Model.Settings.CompanyEmail</span> }
            </div>
        </div>
        <div class="doc">
            <div>帳單編號 <strong>@Model.Invoice.InvoiceNumber</strong></div>
            <div>開立 @Model.Invoice.CreatedAt.ToString("yyyy/MM/dd")</div>
        </div>
    </div>
    <dl>
        <dt>客戶</dt><dd><strong>@buyerName</strong></dd>
        <dt>統編</dt><dd>@(buyerTaxId ?? "—")</dd>
        <dt>地址</dt><dd colspan="3">@(partner?.Address ?? "—")</dd>
        <dt>電話</dt><dd>@(partner?.Phone ?? "—")</dd>
        <dt>期間</dt><dd>@Model.Invoice.PeriodStart.ToString("yyyy/MM/dd") ~ @Model.Invoice.PeriodEnd.ToString("yyyy/MM/dd")</dd>
    </dl>
    <table>
        <thead><tr><th style="width:34%">項目</th><th>黑</th><th>彩</th><th>大</th><th>月租</th><th>張數費</th><th style="text-align:right;">小計</th></tr></thead>
        <tbody>
            @foreach (var it in Model.Invoice.Items) {
                <tr><td class="left">@it.Description</td><td>@it.BlackPages.ToString("N0")</td><td>@it.ColorPages.ToString("N0")</td><td>@it.LargePages.ToString("N0")</td><td class="right">@it.MonthlyFee.ToString("N0")</td><td class="right">@it.PageFee.ToString("N0")</td><td class="right">$@it.Subtotal.ToString("N0")</td></tr>
            }
        </tbody>
    </table>
    <div>
        <div class="totals-row"><span>未稅小計</span><span class="v">$@Model.Invoice.TotalAmount.ToString("N0")</span></div>
        <div class="totals-row"><span>營業稅 5%</span><span class="v">$@Model.Invoice.TaxAmount.ToString("N0")</span></div>
        <div class="totals-row grand"><span>含稅總計</span><span class="v">$@Model.Invoice.GrandTotal.ToString("N0")</span></div>
    </div>
    <div class="foot">
        <div>@if (!string.IsNullOrEmpty(Model.Settings.BankName)) { <text><strong>匯款</strong>：@Model.Settings.BankName @Model.Settings.BankBranch / @Model.Settings.BankAccount</text> }</div>
        <div>@if (!string.IsNullOrEmpty(Model.Settings.PaymentTerms)) { <text><strong>條件</strong>：@Model.Settings.PaymentTerms</text> }</div>
        <div>@if (!string.IsNullOrEmpty(Model.Settings.FooterNote)) { <text>@Model.Settings.FooterNote</text> }</div>
    </div>
</div></body></html>
