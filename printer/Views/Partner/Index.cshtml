@model IEnumerable<printer.Data.Entities.Partner>
@{
    ViewData["Title"] = "客戶管理";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>客戶管理</h4>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-primary">新增客戶</a>
        <div class="btn-group">
            <button type="button" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-file-earmark-excel"></i> Excel
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" id="btnExport" href="#"><i class="bi bi-download me-2"></i>匯出 Excel</a></li>
                <li><a class="dropdown-item" asp-action="Import"><i class="bi bi-upload me-2"></i>匯入 Excel</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><a class="dropdown-item" asp-action="DownloadSample"><i class="bi bi-file-earmark-text me-2"></i>下載範本</a></li>
            </ul>
        </div>
    </div>
</div>

@{
    var contractAlertCount = (int)(ViewBag.ContractAlertCount ?? 0);
}
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card bg-primary text-white h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-white-50">啟用客戶</h6>
                        <h2 class="mb-0">@ViewBag.ActiveCount.ToString("N0")</h2>
                    </div>
                    <div class="fs-1 opacity-50">&#128194;</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-warning text-dark h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="opacity-75">合約到期提醒</h6>
                        <h2 class="mb-0">@contractAlertCount.ToString("N0")</h2>
                    </div>
                    <div class="fs-1 opacity-50">&#128197;</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="keyword" class="form-control" placeholder="搜尋代碼/客戶編號/公司名稱" value="@ViewBag.Keyword" />
            </div>
            <div class="col-md-3">
                <select name="isActive" class="form-select">
                    <option value="">全部狀態</option>
                    <option value="true" selected="@(ViewBag.IsActive == true)">啟用</option>
                    <option value="false" selected="@(ViewBag.IsActive == false)">停用</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">搜尋</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="width:36px;"><input type="checkbox" id="selectAll" /></th>
                        <th>代碼</th>
                        <th>公司名稱</th>
                        <th>統一編號</th>
                        <th>公司電話</th>
                        <th>地址</th>
                        <th>合約</th>
                        <th>資料完整度</th>
                        <th>啟用</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // 資料完整度 (基本資料 + 聯絡資訊)
                        var fields = new List<bool>
                        {
                            !string.IsNullOrEmpty(item.Name),           // 名稱
                            !string.IsNullOrEmpty(item.Vat),            // 統一編號
                            !string.IsNullOrEmpty(item.Phone),          // 電話
                            !string.IsNullOrEmpty(item.Fax),            // 傳真
                            !string.IsNullOrEmpty(item.Mobile),         // 手機
                            !string.IsNullOrEmpty(item.Email),          // Email
                            !string.IsNullOrEmpty(item.Address),        // 地址
                        };
                        var filled = fields.Count(f => f);
                        var totalFields = fields.Count;
                        var pct = (int)Math.Round((double)filled / totalFields * 100);
                        var pctClass = pct >= 80 ? "bg-success" : pct >= 50 ? "bg-warning" : "bg-danger";

                        <tr>
                            <td><input type="checkbox" class="row-check" value="@item.Id" /></td>
                            <td>@item.Code</td>
                            <td><strong>@item.Name</strong></td>
                            <td>@item.Vat</td>
                            <td>@item.Phone</td>
                            <td><small>@item.Address</small></td>
                            <td>
                                @{
                                    var expired = item.Printers.Count(p => p.IsContractExpired);
                                    var expiring = item.Printers.Count(p => p.IsContractExpiringSoon);
                                }
                                @if (expired > 0)
                                {
                                    <span class="badge bg-danger">@expired 已到期</span>
                                }
                                @if (expiring > 0)
                                {
                                    <span class="badge bg-warning text-dark">@expiring 即將到期</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <div class="progress flex-grow-1" style="height: 8px; min-width: 60px;" title="已填 @filled / @totalFields 項">
                                        <div class="progress-bar @pctClass" style="width: @pct%"></div>
                                    </div>
                                    <small class="text-muted" style="min-width: 35px;">@pct%</small>
                                </div>
                            </td>
                            <td>
                                <div class="form-check form-switch">
                                    <input class="form-check-input toggle-active" type="checkbox"
                                           data-id="@item.Id" @(item.IsActive ? "checked" : "") />
                                </div>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">檢視</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('確定要刪除嗎？');">
                                    <button type="submit" class="btn btn-sm btn-danger">刪除</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <span>共 @ViewBag.Total 筆</span>
            <nav>
                <ul class="pagination mb-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-keyword="@ViewBag.Keyword"
                               asp-route-isActive="@ViewBag.IsActive">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.toggle-active').forEach(function(el) {
    el.addEventListener('change', function() {
        fetch('@Url.Action("ToggleActive")' + '?id=' + this.dataset.id, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if (!data.success) alert('操作失敗');
            });
    });
});

document.addEventListener('DOMContentLoaded', function () {
    const selectAll = document.getElementById('selectAll');
    const rowChecks = () => document.querySelectorAll('.row-check');
    if (selectAll) {
        selectAll.addEventListener('change', function () {
            rowChecks().forEach(cb => cb.checked = this.checked);
        });
    }
    const btnExport = document.getElementById('btnExport');
    if (btnExport) {
        btnExport.addEventListener('click', function (e) {
            e.preventDefault();
            const ids = Array.from(document.querySelectorAll('.row-check:checked')).map(cb => cb.value);
            const baseUrl = '@Url.Action("Export", "Partner")';
            const urlParams = new URLSearchParams(window.location.search);
            if (ids.length > 0) {
                urlParams.delete('ids');
                ids.forEach(id => urlParams.append('ids', id));
            }
            window.location = baseUrl + (urlParams.toString() ? '?' + urlParams.toString() : '');
        });
    }
});
</script>
}
