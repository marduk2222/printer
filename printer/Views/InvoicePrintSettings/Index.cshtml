    // 帳單風格模組 30 款（billingstyle 模組啟用時顯示）
    var moduleTemplates = new[]
    {
        // ── 色系風格 7 款 ──
        new { Code = "elegant",      Name = "高端優雅版",       Desc = "深紫色調，高端奢華風格",           Color = "#7c3aed" },
        new { Code = "corporate",    Name = "企業標準版",       Desc = "深藍海軍，嚴肅企業風格",           Color = "#1e3a5f" },
        new { Code = "minimal",      Name = "極簡主義版",       Desc = "純黑白，Typography 為主",          Color = "#111111" },
        new { Code = "gradient",     Name = "漸層橫幅版",       Desc = "漸層色彩頁首，現代視覺張力",       Color = "#6d28d9" },
