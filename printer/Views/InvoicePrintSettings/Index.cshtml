}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>帳單列印設定</h4>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    var current = templates.FirstOrDefault(t => t.Code == Model.TemplateCode) ?? templates[0];
}
<div class="alert alert-info">
    目前使用：<strong>@current.Name</strong>
    <span class="badge ms-2" style="background-color:@current.Color;">@current.Desc</span>
</div>

<!-- 樣式選擇卡片 -->
<h6 class="text-muted mb-2"><i class="bi bi-printer me-1"></i>計費系統基本風格（3 種）</h6>
<div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-3 mb-3">
    @foreach (var tpl in templates.Where(t => t.IsBasic))
    {
        var isActive = Model.TemplateCode == tpl.Code;
        <div class="col">
            <div class="card h-100 @(isActive ? "border-primary border-2" : "")" style="--cp: @tpl.Color">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <small class="fw-bold">@tpl.Name</small>
                    @if (isActive) { <span class="badge bg-primary" style="font-size:10px;">使用中</span> }
                </div>
                <div class="card-body p-2">
                    <!-- Mini Preview -->
                    <div style="height:100px; border:1px solid #e5e7eb; border-radius:3px; overflow:hidden; margin-bottom:8px; position:relative; background:@(tpl.Code == "tech" ? "#0f172a" : tpl.Code == "retro" ? "#fefce8" : "#fff");">
                        @if (tpl.Code == "traditional")
                        {
                            <!-- Traditional: double border, centered title -->
                            <div style="border:2px double #000; height:96px; margin:2px; padding:4px; display:flex; flex-direction:column; gap:2px;">
                                <div style="text-align:center;">
                                    <div style="background:#000; height:7px; width:60px; border-radius:1px; margin:0 auto 2px;"></div>
                                    <div style="background:#333; height:10px; width:40px; border-radius:1px; margin:0 auto;"></div>
                                </div>
                                <div style="border:1px solid #000; display:grid; grid-template-columns:repeat(4,1fr);">
                                    @for (int i = 0; i < 4; i++) {
                                        <div style="border-right:1px solid #000; padding:1px 2px; @(i==3?"border-right:none;":"")">
                                            <div style="background:#999; height:3px; border-radius:1px; margin-bottom:1px;"></div>
                                            <div style="background:#ddd; height:4px; border-radius:1px;"></div>
                                        </div>
                                    }
                                </div>
                                <div style="border:1px solid #000; flex:1;">
                                    <div style="background:#f0f0f0; height:8px; border-bottom:1px solid #ccc; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                        @for (int i = 0; i < 5; i++) { <div style="background:#999; height:4px; flex:1; border-radius:1px;"></div> }
                                    </div>
                                    @for (int r = 0; r < 3; r++) {
                                        <div style="height:8px; border-bottom:1px solid #eee; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                            @for (int c = 0; c < 5; c++) { <div style="background:#f0f0f0; height:4px; flex:1; border-radius:1px;"></div> }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                        else if (tpl.Code == "minimal")
                        {
                            <!-- Minimal: pure typography, no colors -->
                            <div style="padding:8px;">
                                <div style="background:#111; height:14px; width:70%; border-radius:1px; margin-bottom:4px;"></div>
                                <div style="background:#888; height:6px; width:45%; border-radius:1px; margin-bottom:8px;"></div>
                                <div style="border-bottom:1px solid #eee; margin-bottom:4px; display:flex; justify-content:flex-end;">
                                    <div style="background:#111; height:16px; width:40%; border-radius:1px;"></div>
                                </div>
                                @for (int r = 0; r < 3; r++) {
                                    <div style="border-bottom:1px solid #f0f0f0; height:8px; display:flex; gap:2px; padding:1px 0; align-items:center; margin-bottom:1px;">
                                        <div style="background:#ddd; height:5px; flex:2; border-radius:1px;"></div>
                                        <div style="background:#ddd; height:5px; flex:1; border-radius:1px;"></div>
                                    </div>
                                }
                                <div style="display:flex; justify-content:flex-end; margin-top:4px;">
                                    <div style="background:#111; height:10px; width:35%; border-radius:1px;"></div>
                                </div>
                            </div>
                        }
                        else if (tpl.Code == "tech")
                        {
                            <!-- Tech: dark mode -->
                            <div style="background:#1e293b; height:96px; margin:2px; border-radius:2px; padding:5px;">
                                <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
                                    <div style="background:#38bdf8; height:10px; width:50px; border-radius:2px;"></div>
                                    <div style="border:1px solid #38bdf8; border-radius:2px; padding:2px 4px;">
                                        <div style="background:#38bdf8; height:8px; width:35px; border-radius:1px;"></div>
                                    </div>
                                </div>
                                <div style="border-top:1px solid #334155; margin-bottom:3px;"></div>
                                <div style="background:#334155; height:8px; border-radius:1px; margin-bottom:2px; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                    @for (int i = 0; i < 5; i++) { <div style="background:#38bdf8; height:4px; flex:1; border-radius:1px;"></div> }
                                </div>
                                @for (int r = 0; r < 3; r++) {
                                    <div style="height:8px; border-bottom:1px solid #334155; display:flex; gap:1px; padding:0 2px; align-items:center; margin-bottom:1px;">
                                        @for (int c = 0; c < 5; c++) { <div style="background:#334155; height:4px; flex:1; border-radius:1px;"></div> }
                                    </div>
                                }
                                <div style="display:flex; justify-content:flex-end; margin-top:3px;">
                                    <div style="background:#38bdf8; height:8px; width:40px; border-radius:1px;"></div>
                                </div>
                            </div>
                        }
                        else if (tpl.Code == "colorful")
                        {
                            <!-- Colorful: gradient header -->
                            <div style="background:linear-gradient(135deg,var(--cp),#ec4899); height:24px; display:flex; align-items:center; padding:0 6px; margin-bottom:3px;">
                                <div style="background:rgba(255,255,255,0.5); height:9px; width:45px; border-radius:2px;"></div>
                                <div style="flex:1;"></div>
                                <div style="background:rgba(255,255,255,0.3); height:14px; width:30px; border-radius:2px;"></div>
                            </div>
                            <div style="padding:0 5px;">
                                <div style="background:#faf5ff; border-left:3px solid var(--cp); height:10px; padding:2px 4px; margin-bottom:3px; border-radius:0 2px 2px 0;">
                                    <div style="background:#a5b4fc; height:5px; width:60%; border-radius:1px;"></div>
                                </div>
                                <div style="background:linear-gradient(90deg,var(--cp),#8b5cf6); height:8px; border-radius:1px; margin-bottom:2px; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                    @for (int i = 0; i < 5; i++) { <div style="background:rgba(255,255,255,0.5); height:4px; flex:1; border-radius:1px;"></div> }
                                </div>
                                @for (int r = 0; r < 3; r++) {
                                    <div style="height:7px; border-bottom:1px solid #f0e6ff; display:flex; gap:1px; padding:0 2px; align-items:center; margin-bottom:1px;">
                                        @for (int c = 0; c < 5; c++) { <div style="background:#faf5ff; height:4px; flex:1; border-radius:1px;"></div> }
                                    </div>
                                }
                            </div>
                        }
                        else if (tpl.Code == "luxury")
                        {
                            <!-- Luxury: dark bg gold accent -->
                            <div style="background:#1c1917; height:28px; display:flex; align-items:center; padding:0 6px; margin-bottom:3px;">
                                <div style="background:var(--cp); height:10px; width:50px; border-radius:1px;"></div>
                                <div style="flex:1;"></div>
                                <div style="border:1px solid var(--cp); padding:1px 4px; border-radius:1px;">
                                    <div style="background:var(--cp); height:7px; width:28px; border-radius:1px;"></div>
                                </div>
                            </div>
                            <div style="border-top:2px solid var(--cp); margin:0 5px 3px;"></div>
                            <div style="padding:0 5px;">
                                <div style="background:#fffbeb; height:10px; margin-bottom:3px; padding:2px 3px; border-radius:1px;">
                                    <div style="background:#fde68a; height:5px; width:65%; border-radius:1px;"></div>
                                </div>
                                <div style="background:#292524; height:8px; border-radius:1px; margin-bottom:2px; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                    @for (int i = 0; i < 5; i++) { <div style="background:var(--cp); height:4px; flex:1; border-radius:1px;"></div> }
                                </div>
                                @for (int r = 0; r < 2; r++) {
                                    <div style="height:7px; border-bottom:1px solid #f5f0e8; display:flex; gap:1px; padding:0 2px; align-items:center; margin-bottom:1px;">
                                        @for (int c = 0; c < 5; c++) { <div style="background:#f9f5ef; height:4px; flex:1; border-radius:1px;"></div> }
                                    </div>
                                }
                            </div>
                        }
                        else if (tpl.Code == "retro")
                        {
                            <!-- Retro: cream bg, brown accent -->
