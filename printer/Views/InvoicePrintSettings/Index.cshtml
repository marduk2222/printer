@model printer.Data.Entities.InvoicePrintSettings
@{
    ViewData["Title"] = "帳單列印設定";

    // IsBasic=true → 計費系統內建 3 款；IsBasic=false → 帳單風格模組 27 款
    var templates = new[]
    {
