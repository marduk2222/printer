        new { Code = "japanese",     Name = "日式禪風版",       Desc = "白底墨色，朱紅點綴",               Color = "#c0392b" },
        new { Code = "retro",        Name = "復古典雅版",       Desc = "棕色復古，經典文件風格",           Color = "#92400e" },
