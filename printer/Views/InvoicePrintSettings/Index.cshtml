                                    <div style="background:var(--cp); height:11px; width:40px; border-radius:1px; margin:0 auto;"></div>
                                </div>
                                <div style="background:var(--cp); height:7px; border-radius:1px; margin-bottom:2px; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                    @for (int i = 0; i < 5; i++) { <div style="background:rgba(255,255,255,0.5); height:4px; flex:1; border-radius:1px;"></div> }
                                </div>
                                @for (int r = 0; r < 3; r++) {
                                    <div style="height:7px; border-bottom:1px solid #fde68a; display:flex; gap:1px; padding:0 2px; align-items:center; margin-bottom:1px;">
                                        @for (int c = 0; c < 5; c++) { <div style="background:#fef3c7; height:4px; flex:1; border-radius:1px;"></div> }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <!-- Generic colored preview for all other templates -->
                            <div style="background:var(--cp); height:24px; display:flex; align-items:center; padding:0 6px; margin-bottom:3px;">
                                <div style="background:rgba(255,255,255,0.4); height:9px; width:45px; border-radius:2px;"></div>
                                <div style="flex:1;"></div>
                                <div style="background:rgba(255,255,255,0.25); height:13px; width:28px; border-radius:2px;"></div>
                            </div>
                            <div style="padding:0 5px;">
                                <div style="background:var(--cp); opacity:0.12; border-left:3px solid var(--cp); height:10px; margin-bottom:3px; border-radius:0 2px 2px 0;"></div>
                                <div style="background:var(--cp); height:7px; border-radius:1px; margin-bottom:2px; display:flex; gap:1px; padding:0 2px; align-items:center;">
                                    @for (int i = 0; i < 5; i++) { <div style="background:rgba(255,255,255,0.45); height:4px; flex:1; border-radius:1px;"></div> }
                                </div>
                                @for (int r = 0; r < 3; r++) {
                                    <div style="height:7px; border-bottom:1px solid #f0f0f0; display:flex; gap:1px; padding:0 2px; align-items:center; margin-bottom:1px;">
                                        @for (int c = 0; c < 5; c++) { <div style="background:#f5f5f5; height:4px; flex:1; border-radius:1px;"></div> }
                                    </div>
                                }
                                <div style="display:flex; justify-content:flex-end; margin-top:3px;">
                                    <div style="background:var(--cp); height:8px; width:40px; border-radius:1px;"></div>
                                </div>
                            </div>
                        }
                    </div>
                    <p class="text-muted mb-0" style="font-size:11px;">@tpl.Desc</p>
                </div>
                <div class="card-footer py-2 d-flex gap-1">
                    @if (!isActive)
                    {
                        <form asp-action="ActivateTemplate" method="post" class="flex-fill">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="templateCode" value="@tpl.Code" />
                            <button type="submit" class="btn btn-sm btn-success w-100">啟用此樣式</button>
                        </form>
                    }
                    else
                    {
                        <span class="btn btn-sm btn-outline-primary disabled flex-fill">已啟用</span>
                    }
                    <a href="@Url.Action("Preview", "InvoicePrintSettings", new { templateCode = tpl.Code })" target="_blank" class="btn btn-sm btn-outline-secondary flex-fill">
                        <i class="bi bi-eye me-1"></i>檢視
                    </a>
                </div>
            </div>
        </div>
    }
</div>

