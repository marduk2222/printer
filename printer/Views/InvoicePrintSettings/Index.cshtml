        new { Code = "bigheader",    Name = "大型頁首式",       Desc = "滿版色塊頁首，公司名大字疊印",     Color = "#1d4ed8" },
        new { Code = "rightbar",     Name = "右側欄式",         Desc = "右側固定欄放公司資訊",             Color = "#0891b2" },
        new { Code = "split",        Name = "雙欄分割式",       Desc = "頂部雙欄資訊面板",                 Color = "#059669" },
        new { Code = "landscape",    Name = "橫式三欄式",       Desc = "橫向 A4，頁首三欄佈局",           Color = "#0369a1" },
        new { Code = "twostub",      Name = "雙存根式",         Desc = "含上下撕除存根的帳單格式",         Color = "#0369a1" },
        new { Code = "card",         Name = "卡片區塊式",       Desc = "各區塊卡片化，立體層次感",         Color = "#0891b2" },
        new { Code = "report",       Name = "報表標題式",       Desc = "類報表格式，橫幅標題列",           Color = "#1e40af" },
        new { Code = "tabular",      Name = "全表格式",         Desc = "純表格結構，類試算表樣式",         Color = "#047857" },
        new { Code = "dark",         Name = "深色主題式",       Desc = "深色底色，全黑暗模式帳單",         Color = "#38bdf8" },
        new { Code = "stacked",      Name = "堆疊橫條式",       Desc = "各區域以橫條堆疊排版",             Color = "#0f766e" },
        new { Code = "formal",       Name = "公文正式式",       Desc = "頂部格欄，嚴格公文格式",           Color = "#1a1a1a" },
        new { Code = "lines",        Name = "線條分隔式",       Desc = "以線條作為主要分隔元素",           Color = "#374151" },
        new { Code = "mono",         Name = "等寬字體式",       Desc = "ASCII 風格，等寬字體呈現",         Color = "#16a34a" },
        new { Code = "frame",        Name = "雙邊框式",         Desc = "雙線邊框裝飾整頁邊緣",             Color = "#b45309" },
        new { Code = "gridtop",      Name = "頂部格線式",       Desc = "頂部資訊以格線整齊呈現",           Color = "#7c3aed" },
        new { Code = "serif",        Name = "襯線字體式",       Desc = "Serif 字體，出版物精緻風格",       Color = "#6d28d9" },
        new { Code = "dense",        Name = "緊湊行式",         Desc = "頁首緊湊一行，最大化資訊密度",     Color = "#dc2626" },
        new { Code = "accent",       Name = "強調色帶式",       Desc = "以色帶作為視覺強調元素",           Color = "#0891b2" },
        new { Code = "swiss",        Name = "瑞士格線式",       Desc = "三欄格線頁首，Swiss 設計風",       Color = "#dc2626" },
        new { Code = "stamp",        Name = "印章認證式",       Desc = "含印章元素的正式認證帳單",         Color = "#be123c" },
        new { Code = "invoicefirst", Name = "帳單資訊優先式",   Desc = "帳單號碼放最顯眼核心位置",         Color = "#9333ea" },
        new { Code = "hero",         Name = "英雄區塊式",       Desc = "全幅大圖頁首英雄區塊",             Color = "#7c3aed" },
        new { Code = "centered",     Name = "置中標題式",       Desc = "標題置中，資訊對稱排列",           Color = "#2563eb" },
    };

    // 簽名版模組 12 款（含客戶簽名 + 承辦人員簽名欄位）
    var signTemplates = new[]
    {
        new { Code = "sign-formal",      Name = "正式雙簽版",     Desc = "經典正式風格，雙簽名欄位",         Color = "#1e3a5f" },
        new { Code = "sign-contract",    Name = "合約簽署版",     Desc = "甲乙方合約格式 + 公司印鑑",        Color = "#1a1a1a" },
        new { Code = "sign-delivery",    Name = "送件簽收版",     Desc = "寄/收/簽收三方欄位 + 確認語",      Color = "#0369a1" },
        new { Code = "sign-receipt",     Name = "正式收據版",     Desc = "傳統收據格式 + 付/收款雙印章",     Color = "#7f1d1d" },
        new { Code = "sign-witness",     Name = "三方見證版",     Desc = "買方/賣方/見證人三欄簽名",         Color = "#7c3aed" },
        new { Code = "sign-seal",        Name = "印章簽核版",     Desc = "經辦/覆核/會計/主管 4 印章 + 雙簽", Color = "#be123c" },
        new { Code = "sign-compact",     Name = "緊湊簽收版",     Desc = "資訊緊湊一頁 + 雙簽名橫條",        Color = "#475569" },
        new { Code = "sign-modern",      Name = "現代簽名版",     Desc = "卡片設計 + 雙簽名區塊",            Color = "#1d4ed8" },
        new { Code = "sign-bordered",    Name = "雙邊框簽名版",   Desc = "雙線邊框 + 印鑑欄",                Color = "#0f766e" },
        new { Code = "sign-report",      Name = "報表簽名版",     Desc = "報表格式 + 簽名表格欄",            Color = "#1e40af" },
        new { Code = "sign-dual",        Name = "雙欄簽名版",     Desc = "開單方/客戶分欄 + 雙簽名",         Color = "#0e7490" },
