}

<hr class="my-3" />
<h6 class="text-muted mb-2"><i class="bi bi-pen me-1"></i>簽名版（含客戶 / 承辦人員簽名欄位）<span class="badge bg-info ms-2" style="font-size:11px;">12 款</span></h6>
<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-3 mb-4">
@foreach (var tpl in signTemplates)
{
    var isActive = Model.TemplateCode == tpl.Code;
    <div class="col">
        <div class="card h-100 @(isActive ? "border-primary border-2" : "")" style="--cp: @tpl.Color">
            <div class="card-header d-flex justify-content-between align-items-center py-2">
                <small class="fw-bold">@tpl.Name</small>
                @if (isActive) { <span class="badge bg-primary" style="font-size:10px;">使用中</span> }
            </div>
            <div class="card-body p-2">
                <!-- 簽名版 mini preview：上方是常見內容，下方有 2 個簽名格 -->
                <div style="height:100px; border:1px solid #e5e7eb; border-radius:3px; overflow:hidden; margin-bottom:8px; background:#fff; padding:4px;">
                    <div style="background:var(--cp); height:18px; padding:0 4px; display:flex; align-items:center; gap:2px; border-radius:2px; margin-bottom:3px;">
                        <div style="background:rgba(255,255,255,0.6); height:7px; width:30px; border-radius:1px;"></div>
                        <div style="flex:1;"></div>
                        <div style="background:rgba(255,255,255,0.4); height:8px; width:24px; border-radius:1px;"></div>
                    </div>
                    <div style="background:var(--cp); opacity:0.15; height:5px; border-radius:1px; margin-bottom:2px;"></div>
                    @for (int r = 0; r < 2; r++) { <div style="background:#f3f4f6; height:4px; border-radius:1px; margin-bottom:2px;"></div> }
                    <div style="display:flex; gap:3px; margin-top:4px; padding-top:3px; border-top:1px dashed #d1d5db;">
                        <div style="flex:1; height:24px; border:1px solid var(--cp); border-radius:2px; padding:2px 3px;">
                            <div style="background:var(--cp); height:3px; width:50%; margin-bottom:2px; border-radius:1px;"></div>
                            <div style="background:#9ca3af; height:1px; margin-top:6px;"></div>
                        </div>
                        <div style="flex:1; height:24px; border:1px solid var(--cp); border-radius:2px; padding:2px 3px;">
                            <div style="background:var(--cp); height:3px; width:60%; margin-bottom:2px; border-radius:1px;"></div>
                            <div style="background:#9ca3af; height:1px; margin-top:6px;"></div>
                        </div>
                    </div>
                </div>
                <p class="text-muted mb-0" style="font-size:11px;">@tpl.Desc</p>
            </div>
            <div class="card-footer py-2 d-flex gap-1">
                @if (!isActive)
                {
                    <form asp-action="ActivateTemplate" method="post" class="flex-fill">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="templateCode" value="@tpl.Code" />
                        <button type="submit" class="btn btn-sm btn-success w-100">啟用此樣式</button>
                    </form>
                }
                else
                {
                    <span class="btn btn-sm btn-outline-primary disabled flex-fill">已啟用</span>
                }
                <a href="@Url.Action("Preview", "InvoicePrintSettings", new { templateCode = tpl.Code })" target="_blank" class="btn btn-sm btn-outline-secondary flex-fill">
                    <i class="bi bi-eye me-1"></i>檢視
                </a>
            </div>
        </div>
    </div>
}
</div>

<!-- 公司資訊 + 匯款資訊 -->
<form asp-action="Save" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="TemplateCode" />

    <div class="card mb-4">
        <div class="card-header fw-bold">公司資訊</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">公司名稱</label>
                    <input type="text" class="form-control" asp-for="CompanyName" placeholder="例：XX 科技有限公司" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">公司標語</label>
                    <input type="text" class="form-control" asp-for="CompanySlogan" placeholder="例：您的最佳印務夥伴" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">公司地址</label>
                    <input type="text" class="form-control" asp-for="CompanyAddress" placeholder="例：台北市信義區信義路五段7號" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">電話</label>
                    <input type="text" class="form-control" asp-for="CompanyPhone" placeholder="02-1234-5678" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input type="text" class="form-control" asp-for="CompanyEmail" placeholder="info@example.com" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">網站</label>
                    <input type="text" class="form-control" asp-for="CompanyWebsite" placeholder="https://www.example.com" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">公司 Logo</label>
                    @if (!string.IsNullOrEmpty(Model.CompanyLogoUrl))
                    {
                        <div class="mb-2">
                            <img src="@Model.CompanyLogoUrl" alt="Logo" style="max-height:60px; max-width:200px; object-fit:contain; border:1px solid #dee2e6; border-radius:4px; padding:4px; background:#fff;" />
                            <div class="form-text">目前 Logo，上傳新圖片將會取代</div>
                        </div>
                    }
                    <input type="file" class="form-control" name="logoFile" accept="image/*" />
                    <div class="form-text">支援 JPG、PNG、GIF、WebP、SVG，建議尺寸 200×80 px 以內</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header fw-bold">匯款資訊</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">銀行名稱</label>
                    <input type="text" class="form-control" asp-for="BankName" placeholder="例：台灣銀行" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">分行</label>
                    <input type="text" class="form-control" asp-for="BankBranch" placeholder="例：信義分行" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">帳號</label>
                    <input type="text" class="form-control" asp-for="BankAccount" placeholder="例：123-456-789012" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">付款條件</label>
                    <input type="text" class="form-control" asp-for="PaymentTerms" placeholder="例：立即付款 / 30 天內付款" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">頁尾備註</label>
                    <textarea class="form-control" asp-for="FooterNote" rows="2" placeholder="列印在帳單底部的補充說明文字…"></textarea>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">儲存設定</button>
    </div>
</form>
