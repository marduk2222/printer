@model printer.Data.Entities.AppUser
@{
    ViewData["Title"] = $"編輯人員 - {Model.DisplayName}";
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4>編輯人員</h4>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success btn-sm">儲存變更</button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">取消</a>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">帳號 <span class="text-danger">*</span></label>
                    <input asp-for="Username" class="form-control" required />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">新密碼</label>
                    <input type="password" name="newPassword" class="form-control" placeholder="留空則不變更" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">姓名 <span class="text-danger">*</span></label>
                    <input asp-for="DisplayName" class="form-control" required />
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">角色 <span class="text-danger">*</span></label>
                    <select asp-for="Role" class="form-select" asp-items="@ViewBag.Roles"></select>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">電話</label>
                    <input asp-for="Phone" class="form-control" />
                </div>
            </div>
            <div class="row">
                <div class="col-md-8 mb-0">
                    <label class="form-label">備註</label>
                    <input asp-for="Note" class="form-control" />
                </div>
                <div class="col-md-4 mb-0">
                    <label class="form-label">狀態</label>
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label class="form-check-label" asp-for="IsActive">啟用</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
